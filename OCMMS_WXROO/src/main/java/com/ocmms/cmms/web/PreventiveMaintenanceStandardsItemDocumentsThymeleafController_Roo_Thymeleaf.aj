    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceStandard
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceStandardsItemDocumentsThymeleafController.create(@ModelAttribute PreventiveMaintenanceStandard preventiveMaintenanceStandard, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceStandard.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                preventiveMaintenanceStandard.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                preventiveMaintenanceStandard.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceStandard.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceStandard", preventiveMaintenanceStandard);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenancestandards/documents/create");
        }else if(!Objects.equals(version, preventiveMaintenanceStandard.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceStandard", preventiveMaintenanceStandard);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenancestandards/documents/create");
        }
        getPreventiveMaintenanceStandardService().setDocuments(preventiveMaintenanceStandard,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceStandardsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
