    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ImageDocument>> PreventiveMaintenanceStandardsItemImagesThymeleafController.datatables(@ModelAttribute PreventiveMaintenanceStandard preventiveMaintenanceStandard, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ImageDocument> images = getImageDocumentService().findByPreventiveMaintenanceStandard(preventiveMaintenanceStandard, search, pageable);
