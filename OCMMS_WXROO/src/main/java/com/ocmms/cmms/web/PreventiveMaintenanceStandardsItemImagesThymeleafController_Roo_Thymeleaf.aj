    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceStandard
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceStandardsItemImagesThymeleafController.create(@ModelAttribute PreventiveMaintenanceStandard preventiveMaintenanceStandard, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceStandard.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                preventiveMaintenanceStandard.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                preventiveMaintenanceStandard.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceStandard.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceStandard", preventiveMaintenanceStandard);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenancestandards/images/create");
        }else if(!Objects.equals(version, preventiveMaintenanceStandard.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceStandard", preventiveMaintenanceStandard);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenancestandards/images/create");
        }
        getPreventiveMaintenanceStandardService().setImages(preventiveMaintenanceStandard,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceStandardsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
