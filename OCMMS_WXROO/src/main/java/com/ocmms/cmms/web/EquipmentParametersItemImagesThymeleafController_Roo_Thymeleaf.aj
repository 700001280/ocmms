    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentParameter
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentParametersItemImagesThymeleafController.create(@ModelAttribute EquipmentParameter equipmentParameter, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipmentParameter.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                equipmentParameter.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                equipmentParameter.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             equipmentParameter.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipmentParameter", equipmentParameter);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipmentparameters/images/create");
        }else if(!Objects.equals(version, equipmentParameter.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipmentParameter", equipmentParameter);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipmentparameters/images/create");
        }
        getEquipmentParameterService().setImages(equipmentParameter,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentParametersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
