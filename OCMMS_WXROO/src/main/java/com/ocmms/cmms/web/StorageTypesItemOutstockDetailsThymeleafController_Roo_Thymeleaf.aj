    /**
     * TODO Auto-generated method documentation
     * 
     * @param storageType
     * @param outstockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView StorageTypesItemOutstockDetailsThymeleafController.create(@ModelAttribute StorageType storageType, @RequestParam(value = "outstockDetailsIds", required = false) List<Long> outstockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (outstockDetails != null) {
            for (Iterator<Long> iterator = outstockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, storageType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (outstockDetails != null) {
                storageType.setOutstockDetails(new HashSet<OutstockDetail>(getOutstockDetailService().findAll(outstockDetails)));
            }else{
                storageType.setOutstockDetails(new HashSet<OutstockDetail>());
            }
            // Reset the version to prevent update
             storageType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("storageType", storageType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("storagetypes/outstockDetails/create");
        }else if(!Objects.equals(version, storageType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("storageType", storageType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("storagetypes/outstockDetails/create");
        }
        getStorageTypeService().setOutstockDetails(storageType,outstockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(StorageTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
