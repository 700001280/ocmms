    /**
     * TODO Auto-generated method documentation
     * 
     * @param taskHeader
     * @param taskHeaderTexts
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TaskHeadersItemTaskHeaderTextsThymeleafController.create(@ModelAttribute TaskHeader taskHeader, @RequestParam(value = "taskHeaderTextsIds", required = false) List<Long> taskHeaderTexts, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (taskHeaderTexts != null) {
            for (Iterator<Long> iterator = taskHeaderTexts.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, taskHeader.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (taskHeaderTexts != null) {
                taskHeader.setTaskHeaderTexts(new HashSet<TaskHeaderText>(getTaskHeaderTextService().findAll(taskHeaderTexts)));
            }else{
                taskHeader.setTaskHeaderTexts(new HashSet<TaskHeaderText>());
            }
            // Reset the version to prevent update
             taskHeader.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("taskHeader", taskHeader);
            model.addAttribute("concurrency", true);
            return new ModelAndView("taskheaders/taskHeaderTexts/create");
        }else if(!Objects.equals(version, taskHeader.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("taskHeader", taskHeader);
            model.addAttribute("concurrency", false);
            return new ModelAndView("taskheaders/taskHeaderTexts/create");
        }
        getTaskHeaderService().setTaskHeaderTexts(taskHeader,taskHeaderTexts);
        return new ModelAndView("redirect:" + getCollectionLink().to(TaskHeadersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
