    @PostMapping(name = "create")
    public ModelAndView WorkOrderHeadersItemWorkOrderOperationsThymeleafController.create(@ModelAttribute WorkOrderHeader workOrderHeader, @RequestParam(value = "workOrderOperationsIds", required = false) List<Long> workOrderOperations, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (workOrderOperations != null) {
            for (Iterator<Long> iterator = workOrderOperations.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, workOrderHeader.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (workOrderOperations != null) {
                workOrderHeader.setWorkOrderOperations(new HashSet<WorkOrderOperation>(getWorkOrderOperationService().findAll(workOrderOperations)));
            }else{
                workOrderHeader.setWorkOrderOperations(new HashSet<WorkOrderOperation>());
            }
            // Reset the version to prevent update
             workOrderHeader.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workOrderHeader", workOrderHeader);
            model.addAttribute("concurrency", true);
            return new ModelAndView("workorderheaders/workOrderOperations/create");
        }else if(!Objects.equals(version, workOrderHeader.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workOrderHeader", workOrderHeader);
            model.addAttribute("concurrency", false);
            return new ModelAndView("workorderheaders/workOrderOperations/create");
        }
        getWorkOrderHeaderService().setWorkOrderOperations(workOrderHeader,workOrderOperations);
        return new ModelAndView("redirect:" + getCollectionLink().to(WorkOrderHeadersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
