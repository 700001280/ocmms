    /**
     * TODO Auto-generated method documentation
     * 
     * @param storageType
     * @param instockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView StorageTypesItemInstockDetailsThymeleafController.create(@ModelAttribute StorageType storageType, @RequestParam(value = "instockDetailsIds", required = false) List<Long> instockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (instockDetails != null) {
            for (Iterator<Long> iterator = instockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, storageType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (instockDetails != null) {
                storageType.setInstockDetails(new HashSet<InstockDetail>(getInstockDetailService().findAll(instockDetails)));
            }else{
                storageType.setInstockDetails(new HashSet<InstockDetail>());
            }
            // Reset the version to prevent update
             storageType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("storageType", storageType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("storagetypes/instockDetails/create");
        }else if(!Objects.equals(version, storageType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("storageType", storageType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("storagetypes/instockDetails/create");
        }
        getStorageTypeService().setInstockDetails(storageType,instockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(StorageTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
