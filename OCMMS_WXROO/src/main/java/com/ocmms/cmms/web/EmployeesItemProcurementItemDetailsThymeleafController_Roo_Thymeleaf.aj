    /**
     * TODO Auto-generated method documentation
     * 
     * @param employee
     * @param procurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EmployeesItemProcurementItemDetailsThymeleafController.create(@ModelAttribute Employee employee, @RequestParam(value = "procurementItemDetailsIds", required = false) List<Long> procurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (procurementItemDetails != null) {
            for (Iterator<Long> iterator = procurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, employee.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (procurementItemDetails != null) {
                employee.setProcurementItemDetails(new HashSet<ProcurementItemDetail>(getProcurementItemDetailService().findAll(procurementItemDetails)));
            }else{
                employee.setProcurementItemDetails(new HashSet<ProcurementItemDetail>());
            }
            // Reset the version to prevent update
             employee.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", true);
            return new ModelAndView("employees/procurementItemDetails/create");
        }else if(!Objects.equals(version, employee.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", false);
            return new ModelAndView("employees/procurementItemDetails/create");
        }
        getEmployeeService().setProcurementItemDetails(employee,procurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(EmployeesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
