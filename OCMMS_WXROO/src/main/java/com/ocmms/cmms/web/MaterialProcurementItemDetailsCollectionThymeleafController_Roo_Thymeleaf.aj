     * @return ModelAndView
     */
    @GetMapping(value = "/create-form", name = "createForm")
    public ModelAndView MaterialProcurementItemDetailsCollectionThymeleafController.createForm(Model model) {
        populateForm(model);
        
        model.addAttribute("materialProcurementItemDetail", new MaterialProcurementItemDetail());
        return new ModelAndView("materialprocurementitemdetails/create");
    }
    
