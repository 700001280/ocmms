    /**
     * TODO Auto-generated method documentation
     * 
     * @param objectType
     * @param equipments
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ObjectTypesItemEquipmentsThymeleafController.create(@ModelAttribute ObjectType objectType, @RequestParam(value = "equipmentsIds", required = false) List<Long> equipments, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipments != null) {
            for (Iterator<Long> iterator = equipments.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, objectType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipments != null) {
                objectType.setEquipments(new HashSet<Equipment>(getEquipmentService().findAll(equipments)));
            }else{
                objectType.setEquipments(new HashSet<Equipment>());
            }
            // Reset the version to prevent update
             objectType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("objectType", objectType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("objecttypes/equipments/create");
        }else if(!Objects.equals(version, objectType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("objectType", objectType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("objecttypes/equipments/create");
        }
        getObjectTypeService().setEquipments(objectType,equipments);
        return new ModelAndView("redirect:" + getCollectionLink().to(ObjectTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
