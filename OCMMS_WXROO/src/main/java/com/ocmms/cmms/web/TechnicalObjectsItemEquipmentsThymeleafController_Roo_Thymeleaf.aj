    /**
     * TODO Auto-generated method documentation
     * 
     * @param superiorEquipment
     * @param datatablesColumns
     * @param search
     * @param pageable
     * @param draw
     * @return ResponseEntity
     */
    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Equipment>> TechnicalObjectsItemEquipmentsThymeleafController.datatables(@ModelAttribute TechnicalObject superiorEquipment, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Equipment> equipments = getEquipmentService().findBySuperiorEquipment(superiorEquipment, search, pageable);
        long totalEquipmentsCount = getEquipmentService().countBySuperiorEquipment(superiorEquipment);
        ConvertedDatatablesData<Equipment> data =  new ConvertedDatatablesData<Equipment>(equipments, totalEquipmentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
     * TODO Auto-generated method documentation
