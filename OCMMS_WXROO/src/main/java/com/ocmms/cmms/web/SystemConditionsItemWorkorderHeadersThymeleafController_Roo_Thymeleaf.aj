    /**
     * TODO Auto-generated method documentation
     * 
     * @param systemCondition
     * @param workorderHeaders
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView SystemConditionsItemWorkorderHeadersThymeleafController.create(@ModelAttribute SystemCondition systemCondition, @RequestParam(value = "workorderHeadersIds", required = false) List<Long> workorderHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (workorderHeaders != null) {
            for (Iterator<Long> iterator = workorderHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, systemCondition.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (workorderHeaders != null) {
                systemCondition.setWorkorderHeaders(new HashSet<WorkOrderHeader>(getWorkOrderHeaderService().findAll(workorderHeaders)));
            }else{
                systemCondition.setWorkorderHeaders(new HashSet<WorkOrderHeader>());
            }
            // Reset the version to prevent update
             systemCondition.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("systemCondition", systemCondition);
            model.addAttribute("concurrency", true);
            return new ModelAndView("systemconditions/workorderHeaders/create");
        }else if(!Objects.equals(version, systemCondition.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("systemCondition", systemCondition);
            model.addAttribute("concurrency", false);
            return new ModelAndView("systemconditions/workorderHeaders/create");
        }
        getSystemConditionService().setWorkorderHeaders(systemCondition,workorderHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(SystemConditionsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
