    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<WorkOrderHeader>> SystemConditionsItemWorkorderHeadersThymeleafController.datatables(@ModelAttribute SystemCondition systemCondition, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<WorkOrderHeader> workorderHeaders = getWorkOrderHeaderService().findBySystemCondition(systemCondition, search, pageable);
        long totalWorkorderHeadersCount = getWorkOrderHeaderService().countBySystemCondition(systemCondition);
        ConvertedDatatablesData<WorkOrderHeader> data =  new ConvertedDatatablesData<WorkOrderHeader>(workorderHeaders, totalWorkorderHeadersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
