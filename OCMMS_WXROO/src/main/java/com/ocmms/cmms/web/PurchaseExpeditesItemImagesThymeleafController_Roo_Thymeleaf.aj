    /**
     * TODO Auto-generated method documentation
     * 
     * @param purchaseExpedite
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PurchaseExpeditesItemImagesThymeleafController.create(@ModelAttribute PurchaseExpedite purchaseExpedite, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, purchaseExpedite.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                purchaseExpedite.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                purchaseExpedite.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             purchaseExpedite.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("purchaseExpedite", purchaseExpedite);
            model.addAttribute("concurrency", true);
            return new ModelAndView("purchaseexpedites/images/create");
        }else if(!Objects.equals(version, purchaseExpedite.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("purchaseExpedite", purchaseExpedite);
            model.addAttribute("concurrency", false);
            return new ModelAndView("purchaseexpedites/images/create");
        }
        getPurchaseExpediteService().setImages(purchaseExpedite,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(PurchaseExpeditesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
