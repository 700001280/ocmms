    /**
     * TODO Auto-generated method documentation
     * 
     * @param workLog
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView WorkLogsItemDocumentsThymeleafController.create(@ModelAttribute WorkLog workLog, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, workLog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                workLog.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                workLog.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             workLog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workLog", workLog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("worklogs/documents/create");
        }else if(!Objects.equals(version, workLog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workLog", workLog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("worklogs/documents/create");
        }
        getWorkLogService().setDocuments(workLog,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(WorkLogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
