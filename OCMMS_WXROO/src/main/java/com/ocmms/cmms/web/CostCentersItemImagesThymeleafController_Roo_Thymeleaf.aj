    /**
     * TODO Auto-generated method documentation
     * 
     * @param costCenter
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView CostCentersItemImagesThymeleafController.create(@ModelAttribute CostCenter costCenter, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, costCenter.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                costCenter.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                costCenter.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             costCenter.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", true);
            return new ModelAndView("costcenters/images/create");
        }else if(!Objects.equals(version, costCenter.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", false);
            return new ModelAndView("costcenters/images/create");
        }
        getCostCenterService().setImages(costCenter,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(CostCentersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
