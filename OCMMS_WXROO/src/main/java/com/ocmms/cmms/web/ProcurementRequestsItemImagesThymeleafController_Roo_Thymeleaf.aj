    /**
     * TODO Auto-generated method documentation
     * 
     * @param procurementRequest
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ProcurementRequestsItemImagesThymeleafController.create(@ModelAttribute ProcurementRequest procurementRequest, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, procurementRequest.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                procurementRequest.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                procurementRequest.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             procurementRequest.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("procurementRequest", procurementRequest);
            model.addAttribute("concurrency", true);
            return new ModelAndView("procurementrequests/images/create");
        }else if(!Objects.equals(version, procurementRequest.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("procurementRequest", procurementRequest);
            model.addAttribute("concurrency", false);
            return new ModelAndView("procurementrequests/images/create");
        }
        getProcurementRequestService().setImages(procurementRequest,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(ProcurementRequestsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
