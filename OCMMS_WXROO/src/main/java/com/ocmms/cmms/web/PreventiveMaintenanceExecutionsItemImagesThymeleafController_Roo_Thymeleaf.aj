    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceExecution
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceExecutionsItemImagesThymeleafController.create(@ModelAttribute PreventiveMaintenanceExecution preventiveMaintenanceExecution, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceExecution.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                preventiveMaintenanceExecution.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                preventiveMaintenanceExecution.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceExecution.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceExecution", preventiveMaintenanceExecution);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenanceexecutions/images/create");
        }else if(!Objects.equals(version, preventiveMaintenanceExecution.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceExecution", preventiveMaintenanceExecution);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenanceexecutions/images/create");
        }
        getPreventiveMaintenanceExecutionService().setImages(preventiveMaintenanceExecution,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceExecutionsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
