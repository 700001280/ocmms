    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ImageDocument>> PreventiveMaintenanceExecutionsItemImagesThymeleafController.datatables(@ModelAttribute PreventiveMaintenanceExecution preventiveMaintenanceExecution, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ImageDocument> images = getImageDocumentService().findByPreventiveMaintenanceExecution(preventiveMaintenanceExecution, search, pageable);
