    /**
     * TODO Auto-generated method documentation
     * 
     * @param bugReport
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView BugReportsItemDocumentsThymeleafController.create(@ModelAttribute BugReport bugReport, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, bugReport.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                bugReport.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                bugReport.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             bugReport.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("bugReport", bugReport);
            model.addAttribute("concurrency", true);
            return new ModelAndView("bugreports/documents/create");
        }else if(!Objects.equals(version, bugReport.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("bugReport", bugReport);
            model.addAttribute("concurrency", false);
            return new ModelAndView("bugreports/documents/create");
        }
        getBugReportService().setDocuments(bugReport,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(BugReportsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
