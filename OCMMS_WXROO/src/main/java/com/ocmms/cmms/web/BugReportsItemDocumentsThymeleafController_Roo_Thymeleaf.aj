    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> BugReportsItemDocumentsThymeleafController.datatables(@ModelAttribute BugReport systemBugReport, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findBySystemBugReport(systemBugReport, search, pageable);
        long totalDocumentsCount = getDocumentService().countBySystemBugReport(systemBugReport);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
