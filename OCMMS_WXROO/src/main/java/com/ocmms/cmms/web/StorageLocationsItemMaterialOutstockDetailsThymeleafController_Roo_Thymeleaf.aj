    /**
     * TODO Auto-generated method documentation
     * 
     * @param storageLocation
     * @param materialOutstockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView StorageLocationsItemMaterialOutstockDetailsThymeleafController.create(@ModelAttribute StorageLocation storageLocation, @RequestParam(value = "materialOutstockDetailsIds", required = false) List<Long> materialOutstockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialOutstockDetails != null) {
            for (Iterator<Long> iterator = materialOutstockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, storageLocation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialOutstockDetails != null) {
                storageLocation.setMaterialOutstockDetails(new HashSet<MaterialOutstockDetail>(getMaterialOutstockDetailService().findAll(materialOutstockDetails)));
            }else{
                storageLocation.setMaterialOutstockDetails(new HashSet<MaterialOutstockDetail>());
            }
            // Reset the version to prevent update
             storageLocation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("storageLocation", storageLocation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("storagelocations/materialOutstockDetails/create");
        }else if(!Objects.equals(version, storageLocation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("storageLocation", storageLocation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("storagelocations/materialOutstockDetails/create");
        }
        getStorageLocationService().setMaterialOutstockDetails(storageLocation,materialOutstockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(StorageLocationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
