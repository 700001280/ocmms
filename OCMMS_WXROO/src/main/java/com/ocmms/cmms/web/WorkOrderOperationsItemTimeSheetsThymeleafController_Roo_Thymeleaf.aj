    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<WorkOrderTimeSheet>> WorkOrderOperationsItemTimeSheetsThymeleafController.datatables(@ModelAttribute WorkOrderOperation workOrderOperation, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<WorkOrderTimeSheet> timeSheets = getWorkOrderTimeSheetService().findByWorkOrderOperation(workOrderOperation, search, pageable);
        long totalTimeSheetsCount = getWorkOrderTimeSheetService().countByWorkOrderOperation(workOrderOperation);
        ConvertedDatatablesData<WorkOrderTimeSheet> data =  new ConvertedDatatablesData<WorkOrderTimeSheet>(timeSheets, totalTimeSheetsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
