    /**
     * TODO Auto-generated method documentation
     * 
     * @param workOrderOperation
     * @param timeSheets
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView WorkOrderOperationsItemTimeSheetsThymeleafController.create(@ModelAttribute WorkOrderOperation workOrderOperation, @RequestParam(value = "timeSheetsIds", required = false) List<Long> timeSheets, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (timeSheets != null) {
            for (Iterator<Long> iterator = timeSheets.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, workOrderOperation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (timeSheets != null) {
                workOrderOperation.setTimeSheets(new HashSet<WorkOrderTimeSheet>(getWorkOrderTimeSheetService().findAll(timeSheets)));
            }else{
                workOrderOperation.setTimeSheets(new HashSet<WorkOrderTimeSheet>());
            }
            // Reset the version to prevent update
             workOrderOperation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workOrderOperation", workOrderOperation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("workorderoperations/timeSheets/create");
        }else if(!Objects.equals(version, workOrderOperation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workOrderOperation", workOrderOperation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("workorderoperations/timeSheets/create");
        }
        getWorkOrderOperationService().setTimeSheets(workOrderOperation,timeSheets);
        return new ModelAndView("redirect:" + getCollectionLink().to(WorkOrderOperationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
