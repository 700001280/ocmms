    /**
     * TODO Auto-generated method documentation
     * 
     * @param instockDetail
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView InstockDetailsItemImagesThymeleafController.create(@ModelAttribute InstockDetail instockDetail, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, instockDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                instockDetail.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                instockDetail.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             instockDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("instockDetail", instockDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("instockdetails/images/create");
        }else if(!Objects.equals(version, instockDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("instockDetail", instockDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("instockdetails/images/create");
        }
        getInstockDetailService().setImages(instockDetail,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(InstockDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
