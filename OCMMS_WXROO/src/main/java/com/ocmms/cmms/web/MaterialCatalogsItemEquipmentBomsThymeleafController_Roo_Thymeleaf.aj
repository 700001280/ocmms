    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     * @param equipmentBoms
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialCatalogsItemEquipmentBomsThymeleafController.create(@ModelAttribute MaterialCatalog materialCatalog, @RequestParam(value = "equipmentBomsIds", required = false) List<Long> equipmentBoms, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipmentBoms != null) {
            for (Iterator<Long> iterator = equipmentBoms.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialCatalog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipmentBoms != null) {
                materialCatalog.setEquipmentBoms(new HashSet<BillOfMaterial>(getBillOfMaterialService().findAll(equipmentBoms)));
            }else{
                materialCatalog.setEquipmentBoms(new HashSet<BillOfMaterial>());
            }
            // Reset the version to prevent update
             materialCatalog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialcatalogs/equipmentBoms/create");
        }else if(!Objects.equals(version, materialCatalog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialcatalogs/equipmentBoms/create");
        }
        getMaterialCatalogService().setEquipmentBoms(materialCatalog,equipmentBoms);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialCatalogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
