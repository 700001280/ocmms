    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<BillOfMaterial>> MaterialCatalogsItemEquipmentBomsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<BillOfMaterial> equipmentBoms = getBillOfMaterialService().findAllByIdsIn(ids, search, pageable);
        long totalEquipmentBomsCount = equipmentBoms.getTotalElements();
        ConvertedDatatablesData<BillOfMaterial> data =  new ConvertedDatatablesData<BillOfMaterial>(equipmentBoms, totalEquipmentBomsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
