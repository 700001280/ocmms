     * @param bomComponent
     * @param datatablesColumns
     * @param search
     * @param pageable
     * @param draw
     * @return ResponseEntity
     */
    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<BillOfMaterial>> MaterialCatalogsItemEquipmentBomsThymeleafController.datatables(@ModelAttribute MaterialCatalog bomComponent, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<BillOfMaterial> equipmentBoms = getBillOfMaterialService().findByBomComponent(bomComponent, search, pageable);
        long totalEquipmentBomsCount = getBillOfMaterialService().countByBomComponent(bomComponent);
        ConvertedDatatablesData<BillOfMaterial> data =  new ConvertedDatatablesData<BillOfMaterial>(equipmentBoms, totalEquipmentBomsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
     * TODO Auto-generated method documentation
