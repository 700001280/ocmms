    @PostMapping(name = "create")
    public ModelAndView WorkOrderHeadersItemMutiUserStatusesThymeleafController.create(@ModelAttribute WorkOrderHeader workOrderHeader, @RequestParam(value = "mutiUserStatusesIds", required = false) List<Long> mutiUserStatuses, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (mutiUserStatuses != null) {
            for (Iterator<Long> iterator = mutiUserStatuses.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, workOrderHeader.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (mutiUserStatuses != null) {
                workOrderHeader.setMutiUserStatuses(new HashSet<WorkOrderUserStatusWithoutNumber>(getWorkOrderUserStatusWithoutNumberService().findAll(mutiUserStatuses)));
            }else{
                workOrderHeader.setMutiUserStatuses(new HashSet<WorkOrderUserStatusWithoutNumber>());
            }
            // Reset the version to prevent update
             workOrderHeader.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workOrderHeader", workOrderHeader);
            model.addAttribute("concurrency", true);
            return new ModelAndView("workorderheaders/mutiUserStatuses/create");
        }else if(!Objects.equals(version, workOrderHeader.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workOrderHeader", workOrderHeader);
            model.addAttribute("concurrency", false);
            return new ModelAndView("workorderheaders/mutiUserStatuses/create");
        }
        getWorkOrderHeaderService().setMutiUserStatuses(workOrderHeader,mutiUserStatuses);
        return new ModelAndView("redirect:" + getCollectionLink().to(WorkOrderHeadersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
