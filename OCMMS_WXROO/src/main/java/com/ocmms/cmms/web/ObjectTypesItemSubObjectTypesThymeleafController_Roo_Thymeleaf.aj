    public ResponseEntity<ConvertedDatatablesData<SubObjectType>> ObjectTypesItemSubObjectTypesThymeleafController.datatables(@ModelAttribute ObjectType objectType, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<SubObjectType> subObjectTypes = getSubObjectTypeService().findByObjectType(objectType, search, pageable);
