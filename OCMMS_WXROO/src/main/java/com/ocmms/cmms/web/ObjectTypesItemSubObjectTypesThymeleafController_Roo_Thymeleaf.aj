     */
    @PostMapping(name = "create")
    public ModelAndView ObjectTypesItemSubObjectTypesThymeleafController.create(@ModelAttribute ObjectType objectType, @RequestParam(value = "subObjectTypesIds", required = false) List<Long> subObjectTypes, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (subObjectTypes != null) {
            for (Iterator<Long> iterator = subObjectTypes.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, objectType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (subObjectTypes != null) {
                objectType.setSubObjectTypes(new HashSet<SubObjectType>(getSubObjectTypeService().findAll(subObjectTypes)));
            }else{
                objectType.setSubObjectTypes(new HashSet<SubObjectType>());
            }
            // Reset the version to prevent update
             objectType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("objectType", objectType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("objecttypes/subObjectTypes/create");
        }else if(!Objects.equals(version, objectType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("objectType", objectType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("objecttypes/subObjectTypes/create");
        }
        getObjectTypeService().setSubObjectTypes(objectType,subObjectTypes);
        return new ModelAndView("redirect:" + getCollectionLink().to(ObjectTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
