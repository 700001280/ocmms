    /**
     * TODO Auto-generated method documentation
     * 
     * @param criticalClassification
     * @param equipments
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView CriticalClassificationsItemEquipmentsThymeleafController.create(@ModelAttribute CriticalClassification criticalClassification, @RequestParam(value = "equipmentsIds", required = false) List<Long> equipments, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipments != null) {
            for (Iterator<Long> iterator = equipments.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, criticalClassification.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipments != null) {
                criticalClassification.setEquipments(new HashSet<Equipment>(getEquipmentService().findAll(equipments)));
            }else{
                criticalClassification.setEquipments(new HashSet<Equipment>());
            }
            // Reset the version to prevent update
             criticalClassification.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("criticalClassification", criticalClassification);
            model.addAttribute("concurrency", true);
            return new ModelAndView("criticalclassifications/equipments/create");
        }else if(!Objects.equals(version, criticalClassification.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("criticalClassification", criticalClassification);
            model.addAttribute("concurrency", false);
            return new ModelAndView("criticalclassifications/equipments/create");
        }
        getCriticalClassificationService().setEquipments(criticalClassification,equipments);
        return new ModelAndView("redirect:" + getCollectionLink().to(CriticalClassificationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
