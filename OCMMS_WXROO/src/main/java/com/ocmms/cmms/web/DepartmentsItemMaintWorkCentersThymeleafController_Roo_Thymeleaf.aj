    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MainWorkCenter>> DepartmentsItemMaintWorkCentersThymeleafController.datatables(@ModelAttribute Department department, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MainWorkCenter> maintWorkCenters = getMainWorkCenterService().findByDepartment(department, search, pageable);
        long totalMaintWorkCentersCount = getMainWorkCenterService().countByDepartment(department);
        ConvertedDatatablesData<MainWorkCenter> data =  new ConvertedDatatablesData<MainWorkCenter>(maintWorkCenters, totalMaintWorkCentersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
