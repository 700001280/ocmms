    /**
     * TODO Auto-generated method documentation
     * 
     * @param department
     * @param maintWorkCenters
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView DepartmentsItemMaintWorkCentersThymeleafController.create(@ModelAttribute Department department, @RequestParam(value = "maintWorkCentersIds", required = false) List<Long> maintWorkCenters, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (maintWorkCenters != null) {
            for (Iterator<Long> iterator = maintWorkCenters.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, department.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (maintWorkCenters != null) {
                department.setMaintWorkCenters(new HashSet<MainWorkCenter>(getMainWorkCenterService().findAll(maintWorkCenters)));
            }else{
                department.setMaintWorkCenters(new HashSet<MainWorkCenter>());
            }
            // Reset the version to prevent update
             department.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("department", department);
            model.addAttribute("concurrency", true);
            return new ModelAndView("departments/maintWorkCenters/create");
        }else if(!Objects.equals(version, department.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("department", department);
            model.addAttribute("concurrency", false);
            return new ModelAndView("departments/maintWorkCenters/create");
        }
        getDepartmentService().setMaintWorkCenters(department,maintWorkCenters);
        return new ModelAndView("redirect:" + getCollectionLink().to(DepartmentsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
