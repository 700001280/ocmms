        Page<MainWorkCenter> maintWorkCenters = getMainWorkCenterService().findAllByIdsIn(ids, search, pageable);
        long totalMaintWorkCentersCount = maintWorkCenters.getTotalElements();
        ConvertedDatatablesData<MainWorkCenter> data =  new ConvertedDatatablesData<MainWorkCenter>(maintWorkCenters, totalMaintWorkCentersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
