    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<OperationalWorkCenter>> CostCentersItemOperationalWorkCentersThymeleafController.datatables(@ModelAttribute CostCenter costCenter, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<OperationalWorkCenter> operationalWorkCenters = getOperationalWorkCenterService().findByCostCenter(costCenter, search, pageable);
        long totalOperationalWorkCentersCount = getOperationalWorkCenterService().countByCostCenter(costCenter);
        ConvertedDatatablesData<OperationalWorkCenter> data =  new ConvertedDatatablesData<OperationalWorkCenter>(operationalWorkCenters, totalOperationalWorkCentersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
