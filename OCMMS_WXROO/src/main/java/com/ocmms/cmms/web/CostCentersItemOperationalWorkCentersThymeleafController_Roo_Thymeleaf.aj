    /**
     * TODO Auto-generated method documentation
     * 
     * @param costCenter
     * @param operationalWorkCenters
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView CostCentersItemOperationalWorkCentersThymeleafController.create(@ModelAttribute CostCenter costCenter, @RequestParam(value = "operationalWorkCentersIds", required = false) List<Long> operationalWorkCenters, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (operationalWorkCenters != null) {
            for (Iterator<Long> iterator = operationalWorkCenters.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, costCenter.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (operationalWorkCenters != null) {
                costCenter.setOperationalWorkCenters(new HashSet<OperationalWorkCenter>(getOperationalWorkCenterService().findAll(operationalWorkCenters)));
            }else{
                costCenter.setOperationalWorkCenters(new HashSet<OperationalWorkCenter>());
            }
            // Reset the version to prevent update
             costCenter.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", true);
            return new ModelAndView("costcenters/operationalWorkCenters/create");
        }else if(!Objects.equals(version, costCenter.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", false);
            return new ModelAndView("costcenters/operationalWorkCenters/create");
        }
        getCostCenterService().setOperationalWorkCenters(costCenter,operationalWorkCenters);
        return new ModelAndView("redirect:" + getCollectionLink().to(CostCentersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
