    /**
     * TODO Auto-generated method documentation
     * 
     * @param serviceCatalog
     * @param serviceProcurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ServiceCatalogsItemServiceProcurementItemDetailsThymeleafController.create(@ModelAttribute ServiceCatalog serviceCatalog, @RequestParam(value = "serviceProcurementItemDetailsIds", required = false) List<Long> serviceProcurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (serviceProcurementItemDetails != null) {
            for (Iterator<Long> iterator = serviceProcurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, serviceCatalog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (serviceProcurementItemDetails != null) {
                serviceCatalog.setServiceProcurementItemDetails(new HashSet<ServiceProcurementItemDetail>(getServiceProcurementItemDetailService().findAll(serviceProcurementItemDetails)));
            }else{
                serviceCatalog.setServiceProcurementItemDetails(new HashSet<ServiceProcurementItemDetail>());
            }
            // Reset the version to prevent update
             serviceCatalog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("serviceCatalog", serviceCatalog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("servicecatalogs/serviceProcurementItemDetails/create");
        }else if(!Objects.equals(version, serviceCatalog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("serviceCatalog", serviceCatalog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("servicecatalogs/serviceProcurementItemDetails/create");
        }
        getServiceCatalogService().setServiceProcurementItemDetails(serviceCatalog,serviceProcurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(ServiceCatalogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
