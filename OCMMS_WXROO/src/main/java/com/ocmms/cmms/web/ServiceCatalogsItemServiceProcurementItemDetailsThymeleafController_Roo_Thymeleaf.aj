    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ServiceProcurementItemDetail>> ServiceCatalogsItemServiceProcurementItemDetailsThymeleafController.datatables(@ModelAttribute ServiceCatalog serviceCatalog, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ServiceProcurementItemDetail> serviceProcurementItemDetails = getServiceProcurementItemDetailService().findByServiceCatalog(serviceCatalog, search, pageable);
        long totalServiceProcurementItemDetailsCount = getServiceProcurementItemDetailService().countByServiceCatalog(serviceCatalog);
        ConvertedDatatablesData<ServiceProcurementItemDetail> data =  new ConvertedDatatablesData<ServiceProcurementItemDetail>(serviceProcurementItemDetails, totalServiceProcurementItemDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
