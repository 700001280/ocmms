        ServiceCatalog serviceCatalog = null;
        if (HttpMethod.PUT.equals(method)) {
            serviceCatalog = serviceCatalogService.findOneForUpdate(id);
        } else {
            serviceCatalog = serviceCatalogService.findOne(id);
