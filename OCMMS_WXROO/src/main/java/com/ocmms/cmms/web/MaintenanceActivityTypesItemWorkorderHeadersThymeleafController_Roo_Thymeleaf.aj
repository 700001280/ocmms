    /**
     * TODO Auto-generated method documentation
     * 
     * @param maintenanceActivityType
     * @param workorderHeaders
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaintenanceActivityTypesItemWorkorderHeadersThymeleafController.create(@ModelAttribute MaintenanceActivityType maintenanceActivityType, @RequestParam(value = "workorderHeadersIds", required = false) List<Long> workorderHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (workorderHeaders != null) {
            for (Iterator<Long> iterator = workorderHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, maintenanceActivityType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (workorderHeaders != null) {
                maintenanceActivityType.setWorkorderHeaders(new HashSet<WorkOrderHeader>(getWorkOrderHeaderService().findAll(workorderHeaders)));
            }else{
                maintenanceActivityType.setWorkorderHeaders(new HashSet<WorkOrderHeader>());
            }
            // Reset the version to prevent update
             maintenanceActivityType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("maintenanceActivityType", maintenanceActivityType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("maintenanceactivitytypes/workorderHeaders/create");
        }else if(!Objects.equals(version, maintenanceActivityType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("maintenanceActivityType", maintenanceActivityType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("maintenanceactivitytypes/workorderHeaders/create");
        }
        getMaintenanceActivityTypeService().setWorkorderHeaders(maintenanceActivityType,workorderHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaintenanceActivityTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
