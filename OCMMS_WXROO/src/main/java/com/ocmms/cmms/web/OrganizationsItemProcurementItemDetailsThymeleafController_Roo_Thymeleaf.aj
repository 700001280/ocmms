    /**
     * TODO Auto-generated method documentation
     * 
     * @param organization
     * @param procurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView OrganizationsItemProcurementItemDetailsThymeleafController.create(@ModelAttribute Organization organization, @RequestParam(value = "procurementItemDetailsIds", required = false) List<Long> procurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (procurementItemDetails != null) {
            for (Iterator<Long> iterator = procurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, organization.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (procurementItemDetails != null) {
                organization.setProcurementItemDetails(new HashSet<ProcurementItemDetail>(getProcurementItemDetailService().findAll(procurementItemDetails)));
            }else{
                organization.setProcurementItemDetails(new HashSet<ProcurementItemDetail>());
            }
            // Reset the version to prevent update
             organization.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("organization", organization);
            model.addAttribute("concurrency", true);
            return new ModelAndView("organizations/procurementItemDetails/create");
        }else if(!Objects.equals(version, organization.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("organization", organization);
            model.addAttribute("concurrency", false);
            return new ModelAndView("organizations/procurementItemDetails/create");
        }
        getOrganizationService().setProcurementItemDetails(organization,procurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(OrganizationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
