    /**
     * TODO Auto-generated method documentation
     * 
     * @param plannerGroup
     * @param technicalObjects
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PlannerGroupsItemTechnicalObjectsThymeleafController.create(@ModelAttribute PlannerGroup plannerGroup, @RequestParam(value = "technicalObjectsIds", required = false) List<Long> technicalObjects, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (technicalObjects != null) {
            for (Iterator<Long> iterator = technicalObjects.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, plannerGroup.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (technicalObjects != null) {
                plannerGroup.setTechnicalObjects(new HashSet<TechnicalObject>(getTechnicalObjectService().findAll(technicalObjects)));
            }else{
                plannerGroup.setTechnicalObjects(new HashSet<TechnicalObject>());
            }
            // Reset the version to prevent update
             plannerGroup.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("plannerGroup", plannerGroup);
            model.addAttribute("concurrency", true);
            return new ModelAndView("plannergroups/technicalObjects/create");
        }else if(!Objects.equals(version, plannerGroup.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("plannerGroup", plannerGroup);
            model.addAttribute("concurrency", false);
            return new ModelAndView("plannergroups/technicalObjects/create");
        }
        getPlannerGroupService().setTechnicalObjects(plannerGroup,technicalObjects);
        return new ModelAndView("redirect:" + getCollectionLink().to(PlannerGroupsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
