    /**
     * TODO Auto-generated method documentation
     * 
     * @param plantLocation
     * @param notificationHeaders
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PlantLocationsItemNotificationHeadersThymeleafController.create(@ModelAttribute PlantLocation plantLocation, @RequestParam(value = "notificationHeadersIds", required = false) List<Long> notificationHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (notificationHeaders != null) {
            for (Iterator<Long> iterator = notificationHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, plantLocation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (notificationHeaders != null) {
                plantLocation.setNotificationHeaders(new HashSet<NotificationHeader>(getNotificationHeaderService().findAll(notificationHeaders)));
            }else{
                plantLocation.setNotificationHeaders(new HashSet<NotificationHeader>());
            }
            // Reset the version to prevent update
             plantLocation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("plantLocation", plantLocation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("plantlocations/notificationHeaders/create");
        }else if(!Objects.equals(version, plantLocation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("plantLocation", plantLocation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("plantlocations/notificationHeaders/create");
        }
        getPlantLocationService().setNotificationHeaders(plantLocation,notificationHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(PlantLocationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
