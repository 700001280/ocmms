    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentLubrication
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentLubricationsItemImagesThymeleafController.create(@ModelAttribute EquipmentLubrication equipmentLubrication, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipmentLubrication.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                equipmentLubrication.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                equipmentLubrication.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             equipmentLubrication.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipmentLubrication", equipmentLubrication);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipmentlubrications/images/create");
        }else if(!Objects.equals(version, equipmentLubrication.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipmentLubrication", equipmentLubrication);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipmentlubrications/images/create");
        }
        getEquipmentLubricationService().setImages(equipmentLubrication,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentLubricationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
