    /**
     * TODO Auto-generated method documentation
     * 
     * @param outstockDetail
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView OutstockDetailsItemDocumentsThymeleafController.create(@ModelAttribute OutstockDetail outstockDetail, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, outstockDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                outstockDetail.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                outstockDetail.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             outstockDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("outstockDetail", outstockDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("outstockdetails/documents/create");
        }else if(!Objects.equals(version, outstockDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("outstockDetail", outstockDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("outstockdetails/documents/create");
        }
        getOutstockDetailService().setDocuments(outstockDetail,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(OutstockDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
