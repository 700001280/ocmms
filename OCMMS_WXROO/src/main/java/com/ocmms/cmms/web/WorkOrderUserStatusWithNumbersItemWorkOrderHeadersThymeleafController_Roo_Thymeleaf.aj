                workOrderUserStatusWithNumber.setWorkOrderHeaders(new HashSet<WorkOrderHeader>(getWorkOrderHeaderService().findAll(workOrderHeaders)));
            }else{
                workOrderUserStatusWithNumber.setWorkOrderHeaders(new HashSet<WorkOrderHeader>());
            }
            // Reset the version to prevent update
             workOrderUserStatusWithNumber.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workOrderUserStatusWithNumber", workOrderUserStatusWithNumber);
            model.addAttribute("concurrency", true);
            return new ModelAndView("workorderuserstatuswithnumbers/workOrderHeaders/create");
        }else if(!Objects.equals(version, workOrderUserStatusWithNumber.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workOrderUserStatusWithNumber", workOrderUserStatusWithNumber);
            model.addAttribute("concurrency", false);
            return new ModelAndView("workorderuserstatuswithnumbers/workOrderHeaders/create");
        }
