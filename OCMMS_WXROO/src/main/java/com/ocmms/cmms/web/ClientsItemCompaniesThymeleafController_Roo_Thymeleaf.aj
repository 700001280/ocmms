    /**
     * TODO Auto-generated method documentation
     * 
     * @param client
     * @param companies
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ClientsItemCompaniesThymeleafController.create(@ModelAttribute Client client, @RequestParam(value = "companiesIds", required = false) List<Long> companies, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (companies != null) {
            for (Iterator<Long> iterator = companies.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, client.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (companies != null) {
                client.setCompanies(new HashSet<Company>(getCompanyService().findAll(companies)));
            }else{
                client.setCompanies(new HashSet<Company>());
            }
            // Reset the version to prevent update
             client.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("client", client);
            model.addAttribute("concurrency", true);
            return new ModelAndView("clients/companies/create");
        }else if(!Objects.equals(version, client.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("client", client);
            model.addAttribute("concurrency", false);
            return new ModelAndView("clients/companies/create");
        }
        getClientService().setCompanies(client,companies);
        return new ModelAndView("redirect:" + getCollectionLink().to(ClientsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
