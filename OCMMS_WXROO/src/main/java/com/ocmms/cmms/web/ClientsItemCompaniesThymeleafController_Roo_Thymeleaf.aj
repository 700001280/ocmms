    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Company>> ClientsItemCompaniesThymeleafController.datatables(@ModelAttribute Client client, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Company> companies = getCompanyService().findByClient(client, search, pageable);
        long totalCompaniesCount = getCompanyService().countByClient(client);
        ConvertedDatatablesData<Company> data =  new ConvertedDatatablesData<Company>(companies, totalCompaniesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
