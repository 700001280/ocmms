    /**
     * TODO Auto-generated method documentation
     * 
     * @param lotoInfo
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView LotoInfoesItemDocumentsThymeleafController.create(@ModelAttribute LotoInfo lotoInfo, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, lotoInfo.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                lotoInfo.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                lotoInfo.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             lotoInfo.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("lotoInfo", lotoInfo);
            model.addAttribute("concurrency", true);
            return new ModelAndView("lotoinfoes/documents/create");
        }else if(!Objects.equals(version, lotoInfo.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("lotoInfo", lotoInfo);
            model.addAttribute("concurrency", false);
            return new ModelAndView("lotoinfoes/documents/create");
        }
        getLotoInfoService().setDocuments(lotoInfo,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(LotoInfoesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
