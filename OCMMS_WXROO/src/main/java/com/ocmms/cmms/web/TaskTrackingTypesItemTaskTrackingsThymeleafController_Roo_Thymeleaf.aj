    /**
     * TODO Auto-generated method documentation
     * 
     * @param taskTrackingType
     * @param taskTrackings
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TaskTrackingTypesItemTaskTrackingsThymeleafController.create(@ModelAttribute TaskTrackingType taskTrackingType, @RequestParam(value = "taskTrackingsIds", required = false) List<Long> taskTrackings, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (taskTrackings != null) {
            for (Iterator<Long> iterator = taskTrackings.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, taskTrackingType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (taskTrackings != null) {
                taskTrackingType.setTaskTrackings(new HashSet<TaskTracking>(getTaskTrackingService().findAll(taskTrackings)));
            }else{
                taskTrackingType.setTaskTrackings(new HashSet<TaskTracking>());
            }
            // Reset the version to prevent update
             taskTrackingType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("taskTrackingType", taskTrackingType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("tasktrackingtypes/taskTrackings/create");
        }else if(!Objects.equals(version, taskTrackingType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("taskTrackingType", taskTrackingType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("tasktrackingtypes/taskTrackings/create");
        }
        getTaskTrackingTypeService().setTaskTrackings(taskTrackingType,taskTrackings);
        return new ModelAndView("redirect:" + getCollectionLink().to(TaskTrackingTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
