    public ResponseEntity<ConvertedDatatablesData<TaskTracking>> TaskTrackingTypesItemTaskTrackingsThymeleafController.datatables(@ModelAttribute TaskTrackingType taskTrackingType, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<TaskTracking> taskTrackings = getTaskTrackingService().findByTaskTrackingType(taskTrackingType, search, pageable);
