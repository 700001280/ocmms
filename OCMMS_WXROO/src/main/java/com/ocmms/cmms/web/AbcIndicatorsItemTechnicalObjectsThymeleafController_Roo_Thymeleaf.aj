    /**
     * TODO Auto-generated method documentation
     * 
     * @param abcIndicator
     * @param technicalObjects
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView AbcIndicatorsItemTechnicalObjectsThymeleafController.create(@ModelAttribute AbcIndicator abcIndicator, @RequestParam(value = "technicalObjectsIds", required = false) List<Long> technicalObjects, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (technicalObjects != null) {
            for (Iterator<Long> iterator = technicalObjects.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, abcIndicator.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (technicalObjects != null) {
                abcIndicator.setTechnicalObjects(new HashSet<TechnicalObject>(getTechnicalObjectService().findAll(technicalObjects)));
            }else{
                abcIndicator.setTechnicalObjects(new HashSet<TechnicalObject>());
            }
            // Reset the version to prevent update
             abcIndicator.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("abcIndicator", abcIndicator);
            model.addAttribute("concurrency", true);
            return new ModelAndView("abcindicators/technicalObjects/create");
        }else if(!Objects.equals(version, abcIndicator.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("abcIndicator", abcIndicator);
            model.addAttribute("concurrency", false);
            return new ModelAndView("abcindicators/technicalObjects/create");
        }
        getAbcIndicatorService().setTechnicalObjects(abcIndicator,technicalObjects);
        return new ModelAndView("redirect:" + getCollectionLink().to(AbcIndicatorsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
