    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<TechnicalObject>> AbcIndicatorsItemTechnicalObjectsThymeleafController.datatables(@ModelAttribute AbcIndicator abcIndicator, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<TechnicalObject> technicalObjects = getTechnicalObjectService().findByAbcIndicator(abcIndicator, search, pageable);
        long totalTechnicalObjectsCount = getTechnicalObjectService().countByAbcIndicator(abcIndicator);
        ConvertedDatatablesData<TechnicalObject> data =  new ConvertedDatatablesData<TechnicalObject>(technicalObjects, totalTechnicalObjectsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
