    /**
     * TODO Auto-generated method documentation
     * 
     * @param taskTracking
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TaskTrackingsItemImagesThymeleafController.create(@ModelAttribute TaskTracking taskTracking, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, taskTracking.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                taskTracking.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                taskTracking.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             taskTracking.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("taskTracking", taskTracking);
            model.addAttribute("concurrency", true);
            return new ModelAndView("tasktrackings/images/create");
        }else if(!Objects.equals(version, taskTracking.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("taskTracking", taskTracking);
            model.addAttribute("concurrency", false);
            return new ModelAndView("tasktrackings/images/create");
        }
        getTaskTrackingService().setImages(taskTracking,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(TaskTrackingsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
