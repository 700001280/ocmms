    /**
     * TODO Auto-generated method documentation
     * 
     * @param serviceReceiveDetail
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ServiceReceiveDetailsItemDocumentsThymeleafController.create(@ModelAttribute ServiceReceiveDetail serviceReceiveDetail, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, serviceReceiveDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                serviceReceiveDetail.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                serviceReceiveDetail.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             serviceReceiveDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("serviceReceiveDetail", serviceReceiveDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("servicereceivedetails/documents/create");
        }else if(!Objects.equals(version, serviceReceiveDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("serviceReceiveDetail", serviceReceiveDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("servicereceivedetails/documents/create");
        }
        getServiceReceiveDetailService().setDocuments(serviceReceiveDetail,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(ServiceReceiveDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
