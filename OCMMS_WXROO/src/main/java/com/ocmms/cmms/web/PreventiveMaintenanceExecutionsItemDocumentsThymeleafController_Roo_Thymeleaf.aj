    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceExecution
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceExecutionsItemDocumentsThymeleafController.create(@ModelAttribute PreventiveMaintenanceExecution preventiveMaintenanceExecution, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceExecution.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                preventiveMaintenanceExecution.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                preventiveMaintenanceExecution.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceExecution.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceExecution", preventiveMaintenanceExecution);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenanceexecutions/documents/create");
        }else if(!Objects.equals(version, preventiveMaintenanceExecution.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceExecution", preventiveMaintenanceExecution);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenanceexecutions/documents/create");
        }
        getPreventiveMaintenanceExecutionService().setDocuments(preventiveMaintenanceExecution,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceExecutionsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
