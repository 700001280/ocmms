    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MaterialProcurementItemDetail>> MaterialCatalogsItemMaterialProcurementItemDetailsThymeleafController.datatables(@ModelAttribute MaterialCatalog materialCatalog, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MaterialProcurementItemDetail> materialProcurementItemDetails = getMaterialProcurementItemDetailService().findByMaterialCatalog(materialCatalog, search, pageable);
        long totalMaterialProcurementItemDetailsCount = getMaterialProcurementItemDetailService().countByMaterialCatalog(materialCatalog);
        ConvertedDatatablesData<MaterialProcurementItemDetail> data =  new ConvertedDatatablesData<MaterialProcurementItemDetail>(materialProcurementItemDetails, totalMaterialProcurementItemDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
