    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     * @param materialProcurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialCatalogsItemMaterialProcurementItemDetailsThymeleafController.create(@ModelAttribute MaterialCatalog materialCatalog, @RequestParam(value = "materialProcurementItemDetailsIds", required = false) List<Long> materialProcurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialProcurementItemDetails != null) {
            for (Iterator<Long> iterator = materialProcurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialCatalog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialProcurementItemDetails != null) {
                materialCatalog.setMaterialProcurementItemDetails(new HashSet<MaterialProcurementItemDetail>(getMaterialProcurementItemDetailService().findAll(materialProcurementItemDetails)));
            }else{
                materialCatalog.setMaterialProcurementItemDetails(new HashSet<MaterialProcurementItemDetail>());
            }
            // Reset the version to prevent update
             materialCatalog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialcatalogs/materialProcurementItemDetails/create");
        }else if(!Objects.equals(version, materialCatalog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialcatalogs/materialProcurementItemDetails/create");
        }
        getMaterialCatalogService().setMaterialProcurementItemDetails(materialCatalog,materialProcurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialCatalogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
