    /**
     * TODO Auto-generated method documentation
     * 
     * @param instockDetail
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView InstockDetailsItemDocumentsThymeleafController.create(@ModelAttribute InstockDetail instockDetail, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, instockDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                instockDetail.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                instockDetail.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             instockDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("instockDetail", instockDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("instockdetails/documents/create");
        }else if(!Objects.equals(version, instockDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("instockDetail", instockDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("instockdetails/documents/create");
        }
        getInstockDetailService().setDocuments(instockDetail,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(InstockDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
