    /**
     * TODO Auto-generated method documentation
     * 
     * @param organization
     * @param warehouses
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView OrganizationsItemWarehousesThymeleafController.create(@ModelAttribute Organization organization, @RequestParam(value = "warehousesIds", required = false) List<Long> warehouses, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (warehouses != null) {
            for (Iterator<Long> iterator = warehouses.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, organization.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (warehouses != null) {
                organization.setWarehouses(new HashSet<Warehouse>(getWarehouseService().findAll(warehouses)));
            }else{
                organization.setWarehouses(new HashSet<Warehouse>());
            }
            // Reset the version to prevent update
             organization.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("organization", organization);
            model.addAttribute("concurrency", true);
            return new ModelAndView("organizations/warehouses/create");
        }else if(!Objects.equals(version, organization.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("organization", organization);
            model.addAttribute("concurrency", false);
            return new ModelAndView("organizations/warehouses/create");
        }
        getOrganizationService().setWarehouses(organization,warehouses);
        return new ModelAndView("redirect:" + getCollectionLink().to(OrganizationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
