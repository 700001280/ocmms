    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Warehouse>> OrganizationsItemWarehousesThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Warehouse> warehouses = getWarehouseService().findAllByIdsIn(ids, search, pageable);
        long totalWarehousesCount = warehouses.getTotalElements();
        ConvertedDatatablesData<Warehouse> data =  new ConvertedDatatablesData<Warehouse>(warehouses, totalWarehousesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
