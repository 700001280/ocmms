    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> WorkOrderHeadersItemDocumentsThymeleafController.datatables(@ModelAttribute WorkOrderHeader workOrderHeader, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByWorkOrderHeader(workOrderHeader, search, pageable);
        long totalDocumentsCount = getDocumentService().countByWorkOrderHeader(workOrderHeader);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
