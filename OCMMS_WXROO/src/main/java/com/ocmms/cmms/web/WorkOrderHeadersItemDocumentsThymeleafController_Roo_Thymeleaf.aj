    /**
     * TODO Auto-generated method documentation
     * 
     * @param workOrderHeader
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView WorkOrderHeadersItemDocumentsThymeleafController.create(@ModelAttribute WorkOrderHeader workOrderHeader, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, workOrderHeader.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                workOrderHeader.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                workOrderHeader.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             workOrderHeader.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workOrderHeader", workOrderHeader);
            model.addAttribute("concurrency", true);
            return new ModelAndView("workorderheaders/documents/create");
        }else if(!Objects.equals(version, workOrderHeader.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workOrderHeader", workOrderHeader);
            model.addAttribute("concurrency", false);
            return new ModelAndView("workorderheaders/documents/create");
        }
        getWorkOrderHeaderService().setDocuments(workOrderHeader,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(WorkOrderHeadersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
