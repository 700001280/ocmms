    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<NotificationHeader>> EmployeesItemNotificationHeadersThymeleafController.datatables(@ModelAttribute Employee reportedBy, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<NotificationHeader> notificationHeaders = getNotificationHeaderService().findByReportedBy(reportedBy, search, pageable);
        long totalNotificationHeadersCount = getNotificationHeaderService().countByReportedBy(reportedBy);
        ConvertedDatatablesData<NotificationHeader> data =  new ConvertedDatatablesData<NotificationHeader>(notificationHeaders, totalNotificationHeadersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
