    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Employee>> CostCentersItemEmployeesThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Employee> employees = getEmployeeService().findAllByIdsIn(ids, search, pageable);
        long totalEmployeesCount = employees.getTotalElements();
        ConvertedDatatablesData<Employee> data =  new ConvertedDatatablesData<Employee>(employees, totalEmployeesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
