    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Employee>> CostCentersItemEmployeesThymeleafController.datatables(@ModelAttribute CostCenter costCenter, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Employee> employees = getEmployeeService().findByCostCenter(costCenter, search, pageable);
        long totalEmployeesCount = getEmployeeService().countByCostCenter(costCenter);
        ConvertedDatatablesData<Employee> data =  new ConvertedDatatablesData<Employee>(employees, totalEmployeesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
