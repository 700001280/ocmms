    /**
     * TODO Auto-generated method documentation
     * 
     * @param workOrderMaterial
     * @param materialProcurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView WorkOrderMaterialsItemMaterialProcurementItemDetailsThymeleafController.create(@ModelAttribute WorkOrderMaterial workOrderMaterial, @RequestParam(value = "materialProcurementItemDetailsIds", required = false) List<Long> materialProcurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialProcurementItemDetails != null) {
            for (Iterator<Long> iterator = materialProcurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, workOrderMaterial.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialProcurementItemDetails != null) {
                workOrderMaterial.setMaterialProcurementItemDetails(new HashSet<MaterialProcurementItemDetail>(getMaterialProcurementItemDetailService().findAll(materialProcurementItemDetails)));
            }else{
                workOrderMaterial.setMaterialProcurementItemDetails(new HashSet<MaterialProcurementItemDetail>());
            }
            // Reset the version to prevent update
             workOrderMaterial.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workOrderMaterial", workOrderMaterial);
            model.addAttribute("concurrency", true);
            return new ModelAndView("workordermaterials/materialProcurementItemDetails/create");
        }else if(!Objects.equals(version, workOrderMaterial.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workOrderMaterial", workOrderMaterial);
            model.addAttribute("concurrency", false);
            return new ModelAndView("workordermaterials/materialProcurementItemDetails/create");
        }
        getWorkOrderMaterialService().setMaterialProcurementItemDetails(workOrderMaterial,materialProcurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(WorkOrderMaterialsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
