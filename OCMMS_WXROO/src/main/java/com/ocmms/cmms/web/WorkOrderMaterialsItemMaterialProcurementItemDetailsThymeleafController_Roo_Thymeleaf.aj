        Page<MaterialProcurementItemDetail> materialProcurementItemDetails = getMaterialProcurementItemDetailService().findByWorkOrderMaterial(workOrderMaterial, search, pageable);
        long totalMaterialProcurementItemDetailsCount = getMaterialProcurementItemDetailService().countByWorkOrderMaterial(workOrderMaterial);
        ConvertedDatatablesData<MaterialProcurementItemDetail> data =  new ConvertedDatatablesData<MaterialProcurementItemDetail>(materialProcurementItemDetails, totalMaterialProcurementItemDetailsCount, draw, getConversionService(), datatablesColumns);
