    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceStandard
     * @param preventiveMaintenanceContents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceStandardsItemPreventiveMaintenanceContentsThymeleafController.create(@ModelAttribute PreventiveMaintenanceStandard preventiveMaintenanceStandard, @RequestParam(value = "preventiveMaintenanceContentsIds", required = false) List<Long> preventiveMaintenanceContents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (preventiveMaintenanceContents != null) {
            for (Iterator<Long> iterator = preventiveMaintenanceContents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceStandard.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (preventiveMaintenanceContents != null) {
                preventiveMaintenanceStandard.setPreventiveMaintenanceContents(new HashSet<PreventiveMaintenanceContent>(getPreventiveMaintenanceContentService().findAll(preventiveMaintenanceContents)));
            }else{
                preventiveMaintenanceStandard.setPreventiveMaintenanceContents(new HashSet<PreventiveMaintenanceContent>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceStandard.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceStandard", preventiveMaintenanceStandard);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenancestandards/preventiveMaintenanceContents/create");
        }else if(!Objects.equals(version, preventiveMaintenanceStandard.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceStandard", preventiveMaintenanceStandard);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenancestandards/preventiveMaintenanceContents/create");
        }
        getPreventiveMaintenanceStandardService().setPreventiveMaintenanceContents(preventiveMaintenanceStandard,preventiveMaintenanceContents);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceStandardsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
