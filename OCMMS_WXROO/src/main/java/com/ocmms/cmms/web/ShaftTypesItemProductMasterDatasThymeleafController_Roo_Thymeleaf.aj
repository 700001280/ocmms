    /**
     * TODO Auto-generated method documentation
     * 
     * @param shaftType
     * @param productMasterDatas
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ShaftTypesItemProductMasterDatasThymeleafController.create(@ModelAttribute ShaftType shaftType, @RequestParam(value = "productMasterDatasIds", required = false) List<Long> productMasterDatas, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (productMasterDatas != null) {
            for (Iterator<Long> iterator = productMasterDatas.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, shaftType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (productMasterDatas != null) {
                shaftType.setProductMasterDatas(new HashSet<ProductMasterData>(getProductMasterDataService().findAll(productMasterDatas)));
            }else{
                shaftType.setProductMasterDatas(new HashSet<ProductMasterData>());
            }
            // Reset the version to prevent update
             shaftType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("shaftType", shaftType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("shafttypes/productMasterDatas/create");
        }else if(!Objects.equals(version, shaftType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("shaftType", shaftType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("shafttypes/productMasterDatas/create");
        }
        getShaftTypeService().setProductMasterDatas(shaftType,productMasterDatas);
        return new ModelAndView("redirect:" + getCollectionLink().to(ShaftTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
