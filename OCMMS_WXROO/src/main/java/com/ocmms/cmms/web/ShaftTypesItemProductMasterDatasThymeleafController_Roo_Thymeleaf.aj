    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ProductMasterData>> ShaftTypesItemProductMasterDatasThymeleafController.datatables(@ModelAttribute ShaftType shaftType, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ProductMasterData> productMasterDatas = getProductMasterDataService().findByShaftType(shaftType, search, pageable);
        long totalProductMasterDatasCount = getProductMasterDataService().countByShaftType(shaftType);
        ConvertedDatatablesData<ProductMasterData> data =  new ConvertedDatatablesData<ProductMasterData>(productMasterDatas, totalProductMasterDatasCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
