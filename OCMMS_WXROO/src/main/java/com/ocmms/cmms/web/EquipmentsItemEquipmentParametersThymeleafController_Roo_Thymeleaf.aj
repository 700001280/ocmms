    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<EquipmentParameter>> EquipmentsItemEquipmentParametersThymeleafController.datatables(@ModelAttribute Equipment equipments, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<EquipmentParameter> equipmentParameters = getEquipmentParameterService().findByEquipmentsContains(equipments, search, pageable);
        long totalEquipmentParametersCount = getEquipmentParameterService().countByEquipmentsContains(equipments);
        ConvertedDatatablesData<EquipmentParameter> data =  new ConvertedDatatablesData<EquipmentParameter>(equipmentParameters, totalEquipmentParametersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
