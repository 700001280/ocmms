    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<EquipmentParameter>> EquipmentsItemEquipmentParametersThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<EquipmentParameter> equipmentParameters = getEquipmentParameterService().findAllByIdsIn(ids, search, pageable);
        long totalEquipmentParametersCount = equipmentParameters.getTotalElements();
        ConvertedDatatablesData<EquipmentParameter> data =  new ConvertedDatatablesData<EquipmentParameter>(equipmentParameters, totalEquipmentParametersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
