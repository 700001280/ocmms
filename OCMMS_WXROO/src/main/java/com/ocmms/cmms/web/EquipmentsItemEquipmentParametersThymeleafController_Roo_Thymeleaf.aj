    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipment
     * @param equipmentParameters
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentsItemEquipmentParametersThymeleafController.create(@ModelAttribute Equipment equipment, @RequestParam(value = "equipmentParametersIds", required = false) List<Long> equipmentParameters, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipmentParameters != null) {
            for (Iterator<Long> iterator = equipmentParameters.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipment.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipmentParameters != null) {
                equipment.setEquipmentParameters(new HashSet<EquipmentParameter>(getEquipmentParameterService().findAll(equipmentParameters)));
            }else{
                equipment.setEquipmentParameters(new HashSet<EquipmentParameter>());
            }
            // Reset the version to prevent update
             equipment.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipments/equipmentParameters/create");
        }else if(!Objects.equals(version, equipment.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipments/equipmentParameters/create");
        }
        getEquipmentService().setEquipmentParameters(equipment,equipmentParameters);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
