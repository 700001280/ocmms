    public ResponseEntity<ConvertedDatatablesData<AssetInventoryRecord>> EquipmentsItemAssetInventoryRecordsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<AssetInventoryRecord> assetInventoryRecords = getAssetInventoryRecordService().findAllByIdsIn(ids, search, pageable);
        long totalAssetInventoryRecordsCount = assetInventoryRecords.getTotalElements();
        ConvertedDatatablesData<AssetInventoryRecord> data =  new ConvertedDatatablesData<AssetInventoryRecord>(assetInventoryRecords, totalAssetInventoryRecordsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
