    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<AssetInventoryRecord>> EquipmentsItemAssetInventoryRecordsThymeleafController.datatables(@ModelAttribute Equipment equipment, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<AssetInventoryRecord> assetInventoryRecords = getAssetInventoryRecordService().findByEquipment(equipment, search, pageable);
        long totalAssetInventoryRecordsCount = getAssetInventoryRecordService().countByEquipment(equipment);
        ConvertedDatatablesData<AssetInventoryRecord> data =  new ConvertedDatatablesData<AssetInventoryRecord>(assetInventoryRecords, totalAssetInventoryRecordsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
