    /**
     * TODO Auto-generated method documentation
     * 
     * @param lotoDetail
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView LotoDetailsItemDocumentsThymeleafController.create(@ModelAttribute LotoDetail lotoDetail, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, lotoDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                lotoDetail.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                lotoDetail.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             lotoDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("lotoDetail", lotoDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("lotodetails/documents/create");
        }else if(!Objects.equals(version, lotoDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("lotoDetail", lotoDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("lotodetails/documents/create");
        }
        getLotoDetailService().setDocuments(lotoDetail,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(LotoDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
