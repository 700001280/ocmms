    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentScrappingRecord
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentScrappingRecordsItemImagesThymeleafController.create(@ModelAttribute EquipmentScrappingRecord equipmentScrappingRecord, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipmentScrappingRecord.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                equipmentScrappingRecord.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                equipmentScrappingRecord.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             equipmentScrappingRecord.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipmentScrappingRecord", equipmentScrappingRecord);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipmentscrappingrecords/images/create");
        }else if(!Objects.equals(version, equipmentScrappingRecord.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipmentScrappingRecord", equipmentScrappingRecord);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipmentscrappingrecords/images/create");
        }
        getEquipmentScrappingRecordService().setImages(equipmentScrappingRecord,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentScrappingRecordsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
