    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ImageDocument>> EquipmentScrappingRecordsItemImagesThymeleafController.datatables(@ModelAttribute EquipmentScrappingRecord equipmentScrappingRecord, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ImageDocument> images = getImageDocumentService().findByEquipmentScrappingRecord(equipmentScrappingRecord, search, pageable);
        long totalImagesCount = getImageDocumentService().countByEquipmentScrappingRecord(equipmentScrappingRecord);
        ConvertedDatatablesData<ImageDocument> data =  new ConvertedDatatablesData<ImageDocument>(images, totalImagesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
