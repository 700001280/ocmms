    public ModelAndView EquipmentLubricationsCollectionThymeleafController.create(@Valid @ModelAttribute EquipmentLubrication equipmentLubrication, BindingResult result, Model model) {
        if (result.hasErrors()) {
            populateForm(model);
            
            return new ModelAndView("equipmentlubrications/create");
