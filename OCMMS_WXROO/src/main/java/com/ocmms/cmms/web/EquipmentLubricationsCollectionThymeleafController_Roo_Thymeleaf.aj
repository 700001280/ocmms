        UriComponents showURI = getItemLink().to(EquipmentLubricationsItemThymeleafLinkFactory.SHOW).with("equipmentLubrication", newEquipmentLubrication.getId()).toUri();
        return new ModelAndView("redirect:" + showURI.toUriString());
    }
    
