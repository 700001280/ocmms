    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialProcurementItemDetail
     * @param materialInstockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialProcurementItemDetailsItemMaterialInstockDetailsThymeleafController.create(@ModelAttribute MaterialProcurementItemDetail materialProcurementItemDetail, @RequestParam(value = "materialInstockDetailsIds", required = false) List<Long> materialInstockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialInstockDetails != null) {
            for (Iterator<Long> iterator = materialInstockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialProcurementItemDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialInstockDetails != null) {
                materialProcurementItemDetail.setMaterialInstockDetails(new HashSet<MaterialInstockDetail>(getMaterialInstockDetailService().findAll(materialInstockDetails)));
            }else{
                materialProcurementItemDetail.setMaterialInstockDetails(new HashSet<MaterialInstockDetail>());
            }
            // Reset the version to prevent update
             materialProcurementItemDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialProcurementItemDetail", materialProcurementItemDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialprocurementitemdetails/materialInstockDetails/create");
        }else if(!Objects.equals(version, materialProcurementItemDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialProcurementItemDetail", materialProcurementItemDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialprocurementitemdetails/materialInstockDetails/create");
        }
        getMaterialProcurementItemDetailService().setMaterialInstockDetails(materialProcurementItemDetail,materialInstockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialProcurementItemDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
