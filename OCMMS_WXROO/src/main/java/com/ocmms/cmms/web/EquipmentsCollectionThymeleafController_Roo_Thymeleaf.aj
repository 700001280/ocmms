     * @param model
     * @return ModelAndView
     */
    @GetMapping(value = "/create-form", name = "createForm")
    public ModelAndView EquipmentsCollectionThymeleafController.createForm(Model model) {
        populateForm(model);
        
        model.addAttribute("equipment", new Equipment());
        return new ModelAndView("equipments/create");
    }
    
