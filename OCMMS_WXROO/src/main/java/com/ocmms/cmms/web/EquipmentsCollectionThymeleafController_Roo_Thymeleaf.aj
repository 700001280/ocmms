            builder.addColumn(getMessageSource().getMessage("label_equipment_beginguaranteedate", null, "Begin Guarantee Date", locale), "beginGuaranteeDate", Calendar.class.getName(), 100);
        }
        else if (columnName.equals("warrantyEndDate")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_warrantyenddate", null, "Warranty End Date", locale), "warrantyEndDate", Calendar.class.getName(), 100);
        }
        else if (columnName.equals("contract")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_contract", null, "Contract", locale), "contract", String.class.getName(), 100);
        }
        else if (columnName.equals("ehssCritical")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_ehsscritical", null, "Ehss Critical", locale), "ehssCritical", Boolean.class.getName(), 100);
        }
        else if (columnName.equals("assetCode")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_assetcode", null, "Asset Code", locale), "assetCode", String.class.getName(), 100);
        }
        else if (columnName.equals("startDepreciationCost")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_startdepreciationcost", null, "Start Depreciation Cost", locale), "startDepreciationCost", BigDecimal.class.getName(), 100);
        }
        else if (columnName.equals("depreciationYear")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_depreciationyear", null, "Depreciation Year", locale), "depreciationYear", BigDecimal.class.getName(), 100);
        }
        else if (columnName.equals("capitalizedDate")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_capitalizeddate", null, "Capitalized Date", locale), "capitalizedDate", Calendar.class.getName(), 100);
        }
        else if (columnName.equals("currentBookValue")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_currentbookvalue", null, "Current Book Value", locale), "currentBookValue", BigDecimal.class.getName(), 100);
        }
        else if (columnName.equals("originalAssetId")) {
            builder.addColumn(getMessageSource().getMessage("label_equipment_originalassetid", null, "Original Asset Id", locale), "originalAssetId", String.class.getName(), 100);
        }
        }
        catch (ColumnBuilderException e) {
            String errorMessage = getMessageSource().getMessage("error_exportingErrorException", 
                new Object[] {StringUtils.substringAfterLast(fileName, ".").toUpperCase()}, 
                String.format("Error while exporting data to StringUtils file", StringUtils.
                    substringAfterLast(fileName, ".").toUpperCase()), locale);
            throw new ExportingErrorException(errorMessage);
        }
        catch (ClassNotFoundException e) {
            String errorMessage = getMessageSource().getMessage("error_exportingErrorException", 
                new Object[] {StringUtils.substringAfterLast(fileName, ".").toUpperCase()}, 
                String.format("Error while exporting data to StringUtils file", StringUtils.
                    substringAfterLast(fileName, ".").toUpperCase()), locale);
            throw new ExportingErrorException(errorMessage);
        }
    }
    
}
