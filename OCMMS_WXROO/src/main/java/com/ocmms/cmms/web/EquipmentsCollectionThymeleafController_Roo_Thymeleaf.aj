    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Equipment>> EquipmentsCollectionThymeleafController.datatables(DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        Page<Equipment> equipments = getEquipmentService().findAll(search, pageable);
        long totalEquipmentsCount = equipments.getTotalElements();
        if (search != null && StringUtils.isNotBlank(search.getText())) {
            totalEquipmentsCount = getEquipmentService().count();
        }
        ConvertedDatatablesData<Equipment> datatablesData = new ConvertedDatatablesData<Equipment>(equipments, totalEquipmentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(datatablesData);
    }
    
