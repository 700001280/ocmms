    /**
     * TODO Auto-generated method documentation
     * 
     * @param productType
     * @param productMasterDatas
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ProductTypesItemProductMasterDatasThymeleafController.create(@ModelAttribute ProductType productType, @RequestParam(value = "productMasterDatasIds", required = false) List<Long> productMasterDatas, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (productMasterDatas != null) {
            for (Iterator<Long> iterator = productMasterDatas.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, productType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (productMasterDatas != null) {
                productType.setProductMasterDatas(new HashSet<ProductMasterData>(getProductMasterDataService().findAll(productMasterDatas)));
            }else{
                productType.setProductMasterDatas(new HashSet<ProductMasterData>());
            }
            // Reset the version to prevent update
             productType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("productType", productType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("producttypes/productMasterDatas/create");
        }else if(!Objects.equals(version, productType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("productType", productType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("producttypes/productMasterDatas/create");
        }
        getProductTypeService().setProductMasterDatas(productType,productMasterDatas);
        return new ModelAndView("redirect:" + getCollectionLink().to(ProductTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
