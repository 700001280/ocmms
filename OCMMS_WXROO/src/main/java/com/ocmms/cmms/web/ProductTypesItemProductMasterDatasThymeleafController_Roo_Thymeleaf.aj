    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ProductMasterData>> ProductTypesItemProductMasterDatasThymeleafController.datatables(@ModelAttribute ProductType productType, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ProductMasterData> productMasterDatas = getProductMasterDataService().findByProductType(productType, search, pageable);
        long totalProductMasterDatasCount = getProductMasterDataService().countByProductType(productType);
        ConvertedDatatablesData<ProductMasterData> data =  new ConvertedDatatablesData<ProductMasterData>(productMasterDatas, totalProductMasterDatasCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
