    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<EquipmentLubrication>> EquipmentsItemEquipmentLubricationsThymeleafController.datatables(@ModelAttribute Equipment equipments, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<EquipmentLubrication> equipmentLubrications = getEquipmentLubricationService().findByEquipmentsContains(equipments, search, pageable);
        long totalEquipmentLubricationsCount = getEquipmentLubricationService().countByEquipmentsContains(equipments);
        ConvertedDatatablesData<EquipmentLubrication> data =  new ConvertedDatatablesData<EquipmentLubrication>(equipmentLubrications, totalEquipmentLubricationsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
