    /**
     * TODO Auto-generated method documentation
     * 
     * @param procurementRequest
     * @param serviceProcurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ProcurementRequestsItemServiceProcurementItemDetailsThymeleafController.create(@ModelAttribute ProcurementRequest procurementRequest, @RequestParam(value = "serviceProcurementItemDetailsIds", required = false) List<Long> serviceProcurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (serviceProcurementItemDetails != null) {
            for (Iterator<Long> iterator = serviceProcurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, procurementRequest.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (serviceProcurementItemDetails != null) {
                procurementRequest.setServiceProcurementItemDetails(new HashSet<ServiceProcurementItemDetail>(getServiceProcurementItemDetailService().findAll(serviceProcurementItemDetails)));
            }else{
                procurementRequest.setServiceProcurementItemDetails(new HashSet<ServiceProcurementItemDetail>());
            }
            // Reset the version to prevent update
             procurementRequest.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("procurementRequest", procurementRequest);
            model.addAttribute("concurrency", true);
            return new ModelAndView("procurementrequests/serviceProcurementItemDetails/create");
        }else if(!Objects.equals(version, procurementRequest.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("procurementRequest", procurementRequest);
            model.addAttribute("concurrency", false);
            return new ModelAndView("procurementrequests/serviceProcurementItemDetails/create");
        }
        getProcurementRequestService().setServiceProcurementItemDetails(procurementRequest,serviceProcurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(ProcurementRequestsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
