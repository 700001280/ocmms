    /**
     * TODO Auto-generated method documentation
     * 
     * @param lotoIssueReport
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView LotoIssueReportsItemImagesThymeleafController.create(@ModelAttribute LotoIssueReport lotoIssueReport, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, lotoIssueReport.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                lotoIssueReport.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                lotoIssueReport.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             lotoIssueReport.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("lotoIssueReport", lotoIssueReport);
            model.addAttribute("concurrency", true);
            return new ModelAndView("lotoissuereports/images/create");
        }else if(!Objects.equals(version, lotoIssueReport.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("lotoIssueReport", lotoIssueReport);
            model.addAttribute("concurrency", false);
            return new ModelAndView("lotoissuereports/images/create");
        }
        getLotoIssueReportService().setImages(lotoIssueReport,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(LotoIssueReportsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
