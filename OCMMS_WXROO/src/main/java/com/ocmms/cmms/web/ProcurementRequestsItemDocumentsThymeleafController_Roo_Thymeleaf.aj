     */
    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> ProcurementRequestsItemDocumentsThymeleafController.datatables(@ModelAttribute ProcurementRequest procurementRequest, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByProcurementRequest(procurementRequest, search, pageable);
        long totalDocumentsCount = getDocumentService().countByProcurementRequest(procurementRequest);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
