        EquipmentCategory equipmentCategory = null;
        if (HttpMethod.PUT.equals(method)) {
            equipmentCategory = equipmentCategoryService.findOneForUpdate(id);
        } else {
            equipmentCategory = equipmentCategoryService.findOne(id);
