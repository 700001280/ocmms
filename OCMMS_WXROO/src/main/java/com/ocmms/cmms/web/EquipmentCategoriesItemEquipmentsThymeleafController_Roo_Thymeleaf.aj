    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentCategory
     * @param equipments
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentCategoriesItemEquipmentsThymeleafController.create(@ModelAttribute EquipmentCategory equipmentCategory, @RequestParam(value = "equipmentsIds", required = false) List<Long> equipments, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipments != null) {
            for (Iterator<Long> iterator = equipments.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipmentCategory.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipments != null) {
                equipmentCategory.setEquipments(new HashSet<Equipment>(getEquipmentService().findAll(equipments)));
            }else{
                equipmentCategory.setEquipments(new HashSet<Equipment>());
            }
            // Reset the version to prevent update
             equipmentCategory.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipmentCategory", equipmentCategory);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipmentcategories/equipments/create");
        }else if(!Objects.equals(version, equipmentCategory.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipmentCategory", equipmentCategory);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipmentcategories/equipments/create");
        }
        getEquipmentCategoryService().setEquipments(equipmentCategory,equipments);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentCategoriesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
