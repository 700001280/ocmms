    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Equipment>> EquipmentCategoriesItemEquipmentsThymeleafController.datatables(@ModelAttribute EquipmentCategory equipmentCategory, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Equipment> equipments = getEquipmentService().findByEquipmentCategory(equipmentCategory, search, pageable);
        long totalEquipmentsCount = getEquipmentService().countByEquipmentCategory(equipmentCategory);
        ConvertedDatatablesData<Equipment> data =  new ConvertedDatatablesData<Equipment>(equipments, totalEquipmentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
