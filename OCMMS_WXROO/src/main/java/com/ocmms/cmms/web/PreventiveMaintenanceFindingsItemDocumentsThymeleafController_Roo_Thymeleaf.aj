    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceFinding
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceFindingsItemDocumentsThymeleafController.create(@ModelAttribute PreventiveMaintenanceFinding preventiveMaintenanceFinding, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceFinding.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                preventiveMaintenanceFinding.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                preventiveMaintenanceFinding.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceFinding.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceFinding", preventiveMaintenanceFinding);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenancefindings/documents/create");
        }else if(!Objects.equals(version, preventiveMaintenanceFinding.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceFinding", preventiveMaintenanceFinding);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenancefindings/documents/create");
        }
        getPreventiveMaintenanceFindingService().setDocuments(preventiveMaintenanceFinding,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceFindingsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
