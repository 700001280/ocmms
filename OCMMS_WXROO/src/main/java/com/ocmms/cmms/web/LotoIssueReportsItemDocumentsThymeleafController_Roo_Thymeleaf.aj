    /**
     * TODO Auto-generated method documentation
     * 
     * @param lotoIssueReport
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView LotoIssueReportsItemDocumentsThymeleafController.create(@ModelAttribute LotoIssueReport lotoIssueReport, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, lotoIssueReport.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                lotoIssueReport.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                lotoIssueReport.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             lotoIssueReport.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("lotoIssueReport", lotoIssueReport);
            model.addAttribute("concurrency", true);
            return new ModelAndView("lotoissuereports/documents/create");
        }else if(!Objects.equals(version, lotoIssueReport.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("lotoIssueReport", lotoIssueReport);
            model.addAttribute("concurrency", false);
            return new ModelAndView("lotoissuereports/documents/create");
        }
        getLotoIssueReportService().setDocuments(lotoIssueReport,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(LotoIssueReportsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
