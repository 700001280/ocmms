    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> LotoIssueReportsItemDocumentsThymeleafController.datatables(@ModelAttribute LotoIssueReport lotoIssueReport, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByLotoIssueReport(lotoIssueReport, search, pageable);
        long totalDocumentsCount = getDocumentService().countByLotoIssueReport(lotoIssueReport);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
