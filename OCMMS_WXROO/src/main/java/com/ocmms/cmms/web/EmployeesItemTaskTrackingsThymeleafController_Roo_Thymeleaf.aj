    @PostMapping(name = "create")
    public ModelAndView EmployeesItemTaskTrackingsThymeleafController.create(@ModelAttribute Employee employee, @RequestParam(value = "taskTrackingsIds", required = false) List<Long> taskTrackings, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (taskTrackings != null) {
            for (Iterator<Long> iterator = taskTrackings.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, employee.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (taskTrackings != null) {
                employee.setTaskTrackings(new HashSet<TaskTracking>(getTaskTrackingService().findAll(taskTrackings)));
            }else{
                employee.setTaskTrackings(new HashSet<TaskTracking>());
            }
            // Reset the version to prevent update
             employee.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", true);
            return new ModelAndView("employees/taskTrackings/create");
        }else if(!Objects.equals(version, employee.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", false);
            return new ModelAndView("employees/taskTrackings/create");
        }
        getEmployeeService().setTaskTrackings(employee,taskTrackings);
        return new ModelAndView("redirect:" + getCollectionLink().to(EmployeesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
