     * @param storageLocation
     * @param datatablesColumns
     * @param search
     * @param pageable
     * @param draw
     * @return ResponseEntity
     */
    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<InstockDetail>> StorageLocationsItemInstockDetailsThymeleafController.datatables(@ModelAttribute StorageLocation storageLocation, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<InstockDetail> instockDetails = getInstockDetailService().findByStorageLocation(storageLocation, search, pageable);
        long totalInstockDetailsCount = getInstockDetailService().countByStorageLocation(storageLocation);
        ConvertedDatatablesData<InstockDetail> data =  new ConvertedDatatablesData<InstockDetail>(instockDetails, totalInstockDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
     * TODO Auto-generated method documentation
