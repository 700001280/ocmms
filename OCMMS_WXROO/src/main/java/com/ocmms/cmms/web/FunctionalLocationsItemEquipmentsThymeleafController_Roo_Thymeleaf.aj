    /**
     * TODO Auto-generated method documentation
     * 
     * @param functionalLocation
     * @param equipments
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView FunctionalLocationsItemEquipmentsThymeleafController.create(@ModelAttribute FunctionalLocation functionalLocation, @RequestParam(value = "equipmentsIds", required = false) List<Long> equipments, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipments != null) {
            for (Iterator<Long> iterator = equipments.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, functionalLocation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipments != null) {
                functionalLocation.setEquipments(new HashSet<Equipment>(getEquipmentService().findAll(equipments)));
            }else{
                functionalLocation.setEquipments(new HashSet<Equipment>());
            }
            // Reset the version to prevent update
             functionalLocation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("functionalLocation", functionalLocation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("functionallocations/equipments/create");
        }else if(!Objects.equals(version, functionalLocation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("functionalLocation", functionalLocation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("functionallocations/equipments/create");
        }
        getFunctionalLocationService().setEquipments(functionalLocation,equipments);
        return new ModelAndView("redirect:" + getCollectionLink().to(FunctionalLocationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
