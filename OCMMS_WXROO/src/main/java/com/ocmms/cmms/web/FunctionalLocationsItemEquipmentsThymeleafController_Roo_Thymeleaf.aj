    @ModelAttribute
    public FunctionalLocation FunctionalLocationsItemEquipmentsThymeleafController.getFunctionalLocation(@PathVariable("functionalLocation") Long id, Locale locale, HttpMethod method) {
        FunctionalLocation functionalLocation = null;
        if (HttpMethod.PUT.equals(method)) {
            functionalLocation = functionalLocationService.findOneForUpdate(id);
        } else {
            functionalLocation = functionalLocationService.findOne(id);
        }
        
        if (functionalLocation == null) {
            String message = messageSource.getMessage("error_NotFound", new Object[] {"FunctionalLocation", id}, "The record couldn't be found", locale);
            throw new NotFoundException(message);
        }
        return functionalLocation;
    }
    
