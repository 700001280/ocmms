    /**
     * TODO Auto-generated method documentation
     * 
     * @param measuringPoint
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MeasuringPointsItemImagesThymeleafController.create(@ModelAttribute MeasuringPoint measuringPoint, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, measuringPoint.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                measuringPoint.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                measuringPoint.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             measuringPoint.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("measuringPoint", measuringPoint);
            model.addAttribute("concurrency", true);
            return new ModelAndView("measuringpoints/images/create");
        }else if(!Objects.equals(version, measuringPoint.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("measuringPoint", measuringPoint);
            model.addAttribute("concurrency", false);
            return new ModelAndView("measuringpoints/images/create");
        }
        getMeasuringPointService().setImages(measuringPoint,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(MeasuringPointsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
