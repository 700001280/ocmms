    /**
     * TODO Auto-generated method documentation
     * 
     * @param plant
     * @param plantLocations
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PlantsItemPlantLocationsThymeleafController.create(@ModelAttribute Plant plant, @RequestParam(value = "plantLocationsIds", required = false) List<Long> plantLocations, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (plantLocations != null) {
            for (Iterator<Long> iterator = plantLocations.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, plant.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (plantLocations != null) {
                plant.setPlantLocations(new HashSet<PlantLocation>(getPlantLocationService().findAll(plantLocations)));
            }else{
                plant.setPlantLocations(new HashSet<PlantLocation>());
            }
            // Reset the version to prevent update
             plant.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("plant", plant);
            model.addAttribute("concurrency", true);
            return new ModelAndView("plants/plantLocations/create");
        }else if(!Objects.equals(version, plant.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("plant", plant);
            model.addAttribute("concurrency", false);
            return new ModelAndView("plants/plantLocations/create");
        }
        getPlantService().setPlantLocations(plant,plantLocations);
        return new ModelAndView("redirect:" + getCollectionLink().to(PlantsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
