    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<PlantLocation>> PlantsItemPlantLocationsThymeleafController.datatables(@ModelAttribute Plant plant, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<PlantLocation> plantLocations = getPlantLocationService().findByPlant(plant, search, pageable);
        long totalPlantLocationsCount = getPlantLocationService().countByPlant(plant);
        ConvertedDatatablesData<PlantLocation> data =  new ConvertedDatatablesData<PlantLocation>(plantLocations, totalPlantLocationsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
