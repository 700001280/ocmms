    /**
     * TODO Auto-generated method documentation
     * 
     * @param notificationType
     * @param notificationHeaders
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView NotificationTypesItemNotificationHeadersThymeleafController.create(@ModelAttribute NotificationType notificationType, @RequestParam(value = "notificationHeadersIds", required = false) List<Long> notificationHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (notificationHeaders != null) {
            for (Iterator<Long> iterator = notificationHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, notificationType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (notificationHeaders != null) {
                notificationType.setNotificationHeaders(new HashSet<NotificationHeader>(getNotificationHeaderService().findAll(notificationHeaders)));
            }else{
                notificationType.setNotificationHeaders(new HashSet<NotificationHeader>());
            }
            // Reset the version to prevent update
             notificationType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("notificationType", notificationType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("notificationtypes/notificationHeaders/create");
        }else if(!Objects.equals(version, notificationType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("notificationType", notificationType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("notificationtypes/notificationHeaders/create");
        }
        getNotificationTypeService().setNotificationHeaders(notificationType,notificationHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(NotificationTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
