    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<NotificationHeader>> NotificationTypesItemNotificationHeadersThymeleafController.datatables(@ModelAttribute NotificationType notificationType, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<NotificationHeader> notificationHeaders = getNotificationHeaderService().findByNotificationType(notificationType, search, pageable);
        long totalNotificationHeadersCount = getNotificationHeaderService().countByNotificationType(notificationType);
        ConvertedDatatablesData<NotificationHeader> data =  new ConvertedDatatablesData<NotificationHeader>(notificationHeaders, totalNotificationHeadersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
