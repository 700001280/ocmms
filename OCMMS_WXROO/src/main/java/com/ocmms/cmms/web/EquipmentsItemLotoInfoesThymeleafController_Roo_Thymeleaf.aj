    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<LotoInfo>> EquipmentsItemLotoInfoesThymeleafController.datatables(@ModelAttribute Equipment equipment, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<LotoInfo> lotoInfoes = getLotoInfoService().findByEquipment(equipment, search, pageable);
        long totalLotoInfoesCount = getLotoInfoService().countByEquipment(equipment);
        ConvertedDatatablesData<LotoInfo> data =  new ConvertedDatatablesData<LotoInfo>(lotoInfoes, totalLotoInfoesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
