    public ResponseEntity<ConvertedDatatablesData<LotoInfo>> EquipmentsItemLotoInfoesThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<LotoInfo> lotoInfoes = getLotoInfoService().findAllByIdsIn(ids, search, pageable);
        long totalLotoInfoesCount = lotoInfoes.getTotalElements();
        ConvertedDatatablesData<LotoInfo> data =  new ConvertedDatatablesData<LotoInfo>(lotoInfoes, totalLotoInfoesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
