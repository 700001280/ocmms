    /**
     * TODO Auto-generated method documentation
     * 
     * @param notificationItem
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView NotificationItemsItemImagesThymeleafController.create(@ModelAttribute NotificationItem notificationItem, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, notificationItem.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                notificationItem.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                notificationItem.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             notificationItem.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("notificationItem", notificationItem);
            model.addAttribute("concurrency", true);
            return new ModelAndView("notificationitems/images/create");
        }else if(!Objects.equals(version, notificationItem.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("notificationItem", notificationItem);
            model.addAttribute("concurrency", false);
            return new ModelAndView("notificationitems/images/create");
        }
        getNotificationItemService().setImages(notificationItem,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(NotificationItemsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
