    @ModelAttribute
    public NotificationItem NotificationItemsItemImagesThymeleafController.getNotificationItem(@PathVariable("notificationItem") Long id, Locale locale, HttpMethod method) {
        NotificationItem notificationItem = null;
        if (HttpMethod.PUT.equals(method)) {
            notificationItem = notificationItemService.findOneForUpdate(id);
        } else {
            notificationItem = notificationItemService.findOne(id);
        }
        
