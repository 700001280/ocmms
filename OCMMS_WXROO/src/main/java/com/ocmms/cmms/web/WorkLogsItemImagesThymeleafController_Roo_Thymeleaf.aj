    /**
     * TODO Auto-generated method documentation
     * 
     * @param workLog
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView WorkLogsItemImagesThymeleafController.create(@ModelAttribute WorkLog workLog, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, workLog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                workLog.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                workLog.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             workLog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("workLog", workLog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("worklogs/images/create");
        }else if(!Objects.equals(version, workLog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("workLog", workLog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("worklogs/images/create");
        }
        getWorkLogService().setImages(workLog,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(WorkLogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
