    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ImageDocument>> PreventiveMaintenanceFindingsItemImagesThymeleafController.datatables(@ModelAttribute PreventiveMaintenanceFinding preventiveMaintenanceFinding, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ImageDocument> images = getImageDocumentService().findByPreventiveMaintenanceFinding(preventiveMaintenanceFinding, search, pageable);
        long totalImagesCount = getImageDocumentService().countByPreventiveMaintenanceFinding(preventiveMaintenanceFinding);
        ConvertedDatatablesData<ImageDocument> data =  new ConvertedDatatablesData<ImageDocument>(images, totalImagesCount, draw, getConversionService(), datatablesColumns);
