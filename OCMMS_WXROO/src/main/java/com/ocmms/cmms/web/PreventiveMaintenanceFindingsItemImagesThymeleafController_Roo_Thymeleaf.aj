    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceFinding
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceFindingsItemImagesThymeleafController.create(@ModelAttribute PreventiveMaintenanceFinding preventiveMaintenanceFinding, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceFinding.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                preventiveMaintenanceFinding.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                preventiveMaintenanceFinding.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceFinding.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceFinding", preventiveMaintenanceFinding);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenancefindings/images/create");
        }else if(!Objects.equals(version, preventiveMaintenanceFinding.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceFinding", preventiveMaintenanceFinding);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenancefindings/images/create");
        }
        getPreventiveMaintenanceFindingService().setImages(preventiveMaintenanceFinding,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceFindingsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
