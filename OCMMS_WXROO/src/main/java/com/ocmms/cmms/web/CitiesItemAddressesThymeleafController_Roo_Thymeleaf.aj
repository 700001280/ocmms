    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Address>> CitiesItemAddressesThymeleafController.datatables(@ModelAttribute City city, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Address> addresses = getAddressService().findByCity(city, search, pageable);
        long totalAddressesCount = getAddressService().countByCity(city);
        ConvertedDatatablesData<Address> data =  new ConvertedDatatablesData<Address>(addresses, totalAddressesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
