    /**
     * TODO Auto-generated method documentation
     * 
     * @param city
     * @param addresses
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView CitiesItemAddressesThymeleafController.create(@ModelAttribute City city, @RequestParam(value = "addressesIds", required = false) List<Long> addresses, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (addresses != null) {
            for (Iterator<Long> iterator = addresses.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, city.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (addresses != null) {
                city.setAddresses(new HashSet<Address>(getAddressService().findAll(addresses)));
            }else{
                city.setAddresses(new HashSet<Address>());
            }
            // Reset the version to prevent update
             city.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("city", city);
            model.addAttribute("concurrency", true);
            return new ModelAndView("cities/addresses/create");
        }else if(!Objects.equals(version, city.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("city", city);
            model.addAttribute("concurrency", false);
            return new ModelAndView("cities/addresses/create");
        }
        getCityService().setAddresses(city,addresses);
        return new ModelAndView("redirect:" + getCollectionLink().to(CitiesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
