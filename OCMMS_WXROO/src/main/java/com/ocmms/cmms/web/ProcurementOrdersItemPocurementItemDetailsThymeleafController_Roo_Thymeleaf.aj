    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ProcurementItemDetail>> ProcurementOrdersItemPocurementItemDetailsThymeleafController.datatables(@ModelAttribute ProcurementOrder procurementOrder, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ProcurementItemDetail> pocurementItemDetails = getProcurementItemDetailService().findByProcurementOrder(procurementOrder, search, pageable);
        long totalPocurementItemDetailsCount = getProcurementItemDetailService().countByProcurementOrder(procurementOrder);
        ConvertedDatatablesData<ProcurementItemDetail> data =  new ConvertedDatatablesData<ProcurementItemDetail>(pocurementItemDetails, totalPocurementItemDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
