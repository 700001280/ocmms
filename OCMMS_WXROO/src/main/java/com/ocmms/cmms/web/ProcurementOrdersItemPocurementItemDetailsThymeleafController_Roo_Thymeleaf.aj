    /**
     * TODO Auto-generated method documentation
     * 
     * @param procurementOrder
     * @param pocurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ProcurementOrdersItemPocurementItemDetailsThymeleafController.create(@ModelAttribute ProcurementOrder procurementOrder, @RequestParam(value = "pocurementItemDetailsIds", required = false) List<Long> pocurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (pocurementItemDetails != null) {
            for (Iterator<Long> iterator = pocurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, procurementOrder.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (pocurementItemDetails != null) {
                procurementOrder.setPocurementItemDetails(new HashSet<ProcurementItemDetail>(getProcurementItemDetailService().findAll(pocurementItemDetails)));
            }else{
                procurementOrder.setPocurementItemDetails(new HashSet<ProcurementItemDetail>());
            }
            // Reset the version to prevent update
             procurementOrder.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("procurementOrder", procurementOrder);
            model.addAttribute("concurrency", true);
            return new ModelAndView("procurementorders/pocurementItemDetails/create");
        }else if(!Objects.equals(version, procurementOrder.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("procurementOrder", procurementOrder);
            model.addAttribute("concurrency", false);
            return new ModelAndView("procurementorders/pocurementItemDetails/create");
        }
        getProcurementOrderService().setPocurementItemDetails(procurementOrder,pocurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(ProcurementOrdersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
