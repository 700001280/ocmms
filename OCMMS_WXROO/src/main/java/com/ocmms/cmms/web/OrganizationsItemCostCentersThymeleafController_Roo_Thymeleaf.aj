     */
    @PostMapping(name = "create")
    public ModelAndView OrganizationsItemCostCentersThymeleafController.create(@ModelAttribute Organization organization, @RequestParam(value = "costCentersIds", required = false) List<Long> costCenters, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (costCenters != null) {
            for (Iterator<Long> iterator = costCenters.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, organization.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (costCenters != null) {
                organization.setCostCenters(new HashSet<CostCenter>(getCostCenterService().findAll(costCenters)));
            }else{
                organization.setCostCenters(new HashSet<CostCenter>());
            }
            // Reset the version to prevent update
             organization.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("organization", organization);
            model.addAttribute("concurrency", true);
            return new ModelAndView("organizations/costCenters/create");
        }else if(!Objects.equals(version, organization.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("organization", organization);
            model.addAttribute("concurrency", false);
            return new ModelAndView("organizations/costCenters/create");
        }
        getOrganizationService().setCostCenters(organization,costCenters);
        return new ModelAndView("redirect:" + getCollectionLink().to(OrganizationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
