    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<CostCenter>> OrganizationsItemCostCentersThymeleafController.datatables(@ModelAttribute Organization organization, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<CostCenter> costCenters = getCostCenterService().findByOrganization(organization, search, pageable);
        long totalCostCentersCount = getCostCenterService().countByOrganization(organization);
        ConvertedDatatablesData<CostCenter> data =  new ConvertedDatatablesData<CostCenter>(costCenters, totalCostCentersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
