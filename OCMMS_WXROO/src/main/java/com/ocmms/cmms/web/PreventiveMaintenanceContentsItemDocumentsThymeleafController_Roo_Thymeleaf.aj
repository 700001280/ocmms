    /**
     * TODO Auto-generated method documentation
     * 
     * @param preventiveMaintenanceContent
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PreventiveMaintenanceContentsItemDocumentsThymeleafController.create(@ModelAttribute PreventiveMaintenanceContent preventiveMaintenanceContent, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, preventiveMaintenanceContent.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                preventiveMaintenanceContent.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                preventiveMaintenanceContent.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             preventiveMaintenanceContent.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("preventiveMaintenanceContent", preventiveMaintenanceContent);
            model.addAttribute("concurrency", true);
            return new ModelAndView("preventivemaintenancecontents/documents/create");
        }else if(!Objects.equals(version, preventiveMaintenanceContent.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("preventiveMaintenanceContent", preventiveMaintenanceContent);
            model.addAttribute("concurrency", false);
            return new ModelAndView("preventivemaintenancecontents/documents/create");
        }
        getPreventiveMaintenanceContentService().setDocuments(preventiveMaintenanceContent,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(PreventiveMaintenanceContentsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
