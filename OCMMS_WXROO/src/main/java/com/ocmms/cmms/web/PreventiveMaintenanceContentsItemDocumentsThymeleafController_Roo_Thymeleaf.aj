    public ResponseEntity<ConvertedDatatablesData<Document>> PreventiveMaintenanceContentsItemDocumentsThymeleafController.datatables(@ModelAttribute PreventiveMaintenanceContent preventiveMaintenanceContent, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByPreventiveMaintenanceContent(preventiveMaintenanceContent, search, pageable);
