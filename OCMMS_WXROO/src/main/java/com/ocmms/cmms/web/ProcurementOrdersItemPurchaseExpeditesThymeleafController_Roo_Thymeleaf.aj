    /**
     * TODO Auto-generated method documentation
     * 
     * @param procurementOrder
     * @param purchaseExpedites
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ProcurementOrdersItemPurchaseExpeditesThymeleafController.create(@ModelAttribute ProcurementOrder procurementOrder, @RequestParam(value = "purchaseExpeditesIds", required = false) List<Long> purchaseExpedites, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (purchaseExpedites != null) {
            for (Iterator<Long> iterator = purchaseExpedites.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, procurementOrder.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (purchaseExpedites != null) {
                procurementOrder.setPurchaseExpedites(new HashSet<PurchaseExpedite>(getPurchaseExpediteService().findAll(purchaseExpedites)));
            }else{
                procurementOrder.setPurchaseExpedites(new HashSet<PurchaseExpedite>());
            }
            // Reset the version to prevent update
             procurementOrder.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("procurementOrder", procurementOrder);
            model.addAttribute("concurrency", true);
            return new ModelAndView("procurementorders/purchaseExpedites/create");
        }else if(!Objects.equals(version, procurementOrder.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("procurementOrder", procurementOrder);
            model.addAttribute("concurrency", false);
            return new ModelAndView("procurementorders/purchaseExpedites/create");
        }
        getProcurementOrderService().setPurchaseExpedites(procurementOrder,purchaseExpedites);
        return new ModelAndView("redirect:" + getCollectionLink().to(ProcurementOrdersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
