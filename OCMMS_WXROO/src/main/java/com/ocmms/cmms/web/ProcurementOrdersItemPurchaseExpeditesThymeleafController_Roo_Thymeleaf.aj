    @GetMapping(name = "datatablesByIdsIn", produces = Datatables.MEDIA_TYPE, value = "/dtByIdsIn")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<PurchaseExpedite>> ProcurementOrdersItemPurchaseExpeditesThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<PurchaseExpedite> purchaseExpedites = getPurchaseExpediteService().findAllByIdsIn(ids, search, pageable);
        long totalPurchaseExpeditesCount = purchaseExpedites.getTotalElements();
        ConvertedDatatablesData<PurchaseExpedite> data =  new ConvertedDatatablesData<PurchaseExpedite>(purchaseExpedites, totalPurchaseExpeditesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
