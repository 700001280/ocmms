    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<PlantSection>> PlantsItemPlantSectionsThymeleafController.datatables(@ModelAttribute Plant plant, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<PlantSection> plantSections = getPlantSectionService().findByPlant(plant, search, pageable);
        long totalPlantSectionsCount = getPlantSectionService().countByPlant(plant);
        ConvertedDatatablesData<PlantSection> data =  new ConvertedDatatablesData<PlantSection>(plantSections, totalPlantSectionsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
