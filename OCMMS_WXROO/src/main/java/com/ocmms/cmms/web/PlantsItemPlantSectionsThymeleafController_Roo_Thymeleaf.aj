    /**
     * TODO Auto-generated method documentation
     * 
     * @param plant
     * @param plantSections
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PlantsItemPlantSectionsThymeleafController.create(@ModelAttribute Plant plant, @RequestParam(value = "plantSectionsIds", required = false) List<Long> plantSections, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (plantSections != null) {
            for (Iterator<Long> iterator = plantSections.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, plant.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (plantSections != null) {
                plant.setPlantSections(new HashSet<PlantSection>(getPlantSectionService().findAll(plantSections)));
            }else{
                plant.setPlantSections(new HashSet<PlantSection>());
            }
            // Reset the version to prevent update
             plant.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("plant", plant);
            model.addAttribute("concurrency", true);
            return new ModelAndView("plants/plantSections/create");
        }else if(!Objects.equals(version, plant.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("plant", plant);
            model.addAttribute("concurrency", false);
            return new ModelAndView("plants/plantSections/create");
        }
        getPlantService().setPlantSections(plant,plantSections);
        return new ModelAndView("redirect:" + getCollectionLink().to(PlantsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
