    @ModelAttribute
    public PlantLocation PlantLocationsItemEquipmentsThymeleafController.getPlantLocation(@PathVariable("plantLocation") Long id, Locale locale, HttpMethod method) {
        PlantLocation plantLocation = null;
        if (HttpMethod.PUT.equals(method)) {
            plantLocation = plantLocationService.findOneForUpdate(id);
        } else {
            plantLocation = plantLocationService.findOne(id);
        }
        
        if (plantLocation == null) {
            String message = messageSource.getMessage("error_NotFound", new Object[] {"PlantLocation", id}, "The record couldn't be found", locale);
            throw new NotFoundException(message);
        }
        return plantLocation;
    }
    
