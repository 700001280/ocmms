    /**
     * TODO Auto-generated method documentation
     * 
     * @param plantLocation
     * @param equipments
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PlantLocationsItemEquipmentsThymeleafController.create(@ModelAttribute PlantLocation plantLocation, @RequestParam(value = "equipmentsIds", required = false) List<Long> equipments, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipments != null) {
            for (Iterator<Long> iterator = equipments.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, plantLocation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipments != null) {
                plantLocation.setEquipments(new HashSet<Equipment>(getEquipmentService().findAll(equipments)));
            }else{
                plantLocation.setEquipments(new HashSet<Equipment>());
            }
            // Reset the version to prevent update
             plantLocation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("plantLocation", plantLocation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("plantlocations/equipments/create");
        }else if(!Objects.equals(version, plantLocation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("plantLocation", plantLocation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("plantlocations/equipments/create");
        }
        getPlantLocationService().setEquipments(plantLocation,equipments);
        return new ModelAndView("redirect:" + getCollectionLink().to(PlantLocationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
