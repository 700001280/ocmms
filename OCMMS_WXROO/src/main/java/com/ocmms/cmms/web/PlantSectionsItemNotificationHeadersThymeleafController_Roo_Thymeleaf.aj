    /**
     * TODO Auto-generated method documentation
     * 
     * @param plantSection
     * @param notificationHeaders
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PlantSectionsItemNotificationHeadersThymeleafController.create(@ModelAttribute PlantSection plantSection, @RequestParam(value = "notificationHeadersIds", required = false) List<Long> notificationHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (notificationHeaders != null) {
            for (Iterator<Long> iterator = notificationHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, plantSection.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (notificationHeaders != null) {
                plantSection.setNotificationHeaders(new HashSet<NotificationHeader>(getNotificationHeaderService().findAll(notificationHeaders)));
            }else{
                plantSection.setNotificationHeaders(new HashSet<NotificationHeader>());
            }
            // Reset the version to prevent update
             plantSection.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("plantSection", plantSection);
            model.addAttribute("concurrency", true);
            return new ModelAndView("plantsections/notificationHeaders/create");
        }else if(!Objects.equals(version, plantSection.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("plantSection", plantSection);
            model.addAttribute("concurrency", false);
            return new ModelAndView("plantsections/notificationHeaders/create");
        }
        getPlantSectionService().setNotificationHeaders(plantSection,notificationHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(PlantSectionsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
