    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<NotificationHeader>> PlantSectionsItemNotificationHeadersThymeleafController.datatables(@ModelAttribute PlantSection plantSection, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<NotificationHeader> notificationHeaders = getNotificationHeaderService().findByPlantSection(plantSection, search, pageable);
        long totalNotificationHeadersCount = getNotificationHeaderService().countByPlantSection(plantSection);
        ConvertedDatatablesData<NotificationHeader> data =  new ConvertedDatatablesData<NotificationHeader>(notificationHeaders, totalNotificationHeadersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
