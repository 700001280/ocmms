    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<NotificationHeader>> PlantSectionsItemNotificationHeadersThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<NotificationHeader> notificationHeaders = getNotificationHeaderService().findAllByIdsIn(ids, search, pageable);
        long totalNotificationHeadersCount = notificationHeaders.getTotalElements();
        ConvertedDatatablesData<NotificationHeader> data =  new ConvertedDatatablesData<NotificationHeader>(notificationHeaders, totalNotificationHeadersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
