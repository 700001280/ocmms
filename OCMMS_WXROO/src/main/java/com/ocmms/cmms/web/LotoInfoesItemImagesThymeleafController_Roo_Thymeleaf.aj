    /**
     * TODO Auto-generated method documentation
     * 
     * @param lotoInfo
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView LotoInfoesItemImagesThymeleafController.create(@ModelAttribute LotoInfo lotoInfo, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, lotoInfo.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                lotoInfo.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                lotoInfo.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             lotoInfo.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("lotoInfo", lotoInfo);
            model.addAttribute("concurrency", true);
            return new ModelAndView("lotoinfoes/images/create");
        }else if(!Objects.equals(version, lotoInfo.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("lotoInfo", lotoInfo);
            model.addAttribute("concurrency", false);
            return new ModelAndView("lotoinfoes/images/create");
        }
        getLotoInfoService().setImages(lotoInfo,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(LotoInfoesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
