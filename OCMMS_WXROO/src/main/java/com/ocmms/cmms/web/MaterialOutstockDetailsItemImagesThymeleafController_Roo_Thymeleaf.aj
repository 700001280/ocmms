    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ImageDocument>> MaterialOutstockDetailsItemImagesThymeleafController.datatables(@ModelAttribute MaterialOutstockDetail materialOutstockDetail, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ImageDocument> images = getImageDocumentService().findByMaterialOutstockDetail(materialOutstockDetail, search, pageable);
        long totalImagesCount = getImageDocumentService().countByMaterialOutstockDetail(materialOutstockDetail);
        ConvertedDatatablesData<ImageDocument> data =  new ConvertedDatatablesData<ImageDocument>(images, totalImagesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
