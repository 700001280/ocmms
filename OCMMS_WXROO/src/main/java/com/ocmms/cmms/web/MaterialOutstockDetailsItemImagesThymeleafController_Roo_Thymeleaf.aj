    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialOutstockDetail
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialOutstockDetailsItemImagesThymeleafController.create(@ModelAttribute MaterialOutstockDetail materialOutstockDetail, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialOutstockDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                materialOutstockDetail.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                materialOutstockDetail.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             materialOutstockDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialOutstockDetail", materialOutstockDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialoutstockdetails/images/create");
        }else if(!Objects.equals(version, materialOutstockDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialOutstockDetail", materialOutstockDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialoutstockdetails/images/create");
        }
        getMaterialOutstockDetailService().setImages(materialOutstockDetail,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialOutstockDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
