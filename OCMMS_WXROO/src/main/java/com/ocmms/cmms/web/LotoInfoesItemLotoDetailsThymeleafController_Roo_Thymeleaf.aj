    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<LotoDetail>> LotoInfoesItemLotoDetailsThymeleafController.datatables(@ModelAttribute LotoInfo lotoInfo, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<LotoDetail> lotoDetails = getLotoDetailService().findByLotoInfo(lotoInfo, search, pageable);
        long totalLotoDetailsCount = getLotoDetailService().countByLotoInfo(lotoInfo);
        ConvertedDatatablesData<LotoDetail> data =  new ConvertedDatatablesData<LotoDetail>(lotoDetails, totalLotoDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
