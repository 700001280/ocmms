    /**
     * TODO Auto-generated method documentation
     * 
     * @param lotoInfo
     * @param lotoDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView LotoInfoesItemLotoDetailsThymeleafController.create(@ModelAttribute LotoInfo lotoInfo, @RequestParam(value = "lotoDetailsIds", required = false) List<Long> lotoDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (lotoDetails != null) {
            for (Iterator<Long> iterator = lotoDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, lotoInfo.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (lotoDetails != null) {
                lotoInfo.setLotoDetails(new HashSet<LotoDetail>(getLotoDetailService().findAll(lotoDetails)));
            }else{
                lotoInfo.setLotoDetails(new HashSet<LotoDetail>());
            }
            // Reset the version to prevent update
             lotoInfo.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("lotoInfo", lotoInfo);
            model.addAttribute("concurrency", true);
            return new ModelAndView("lotoinfoes/lotoDetails/create");
        }else if(!Objects.equals(version, lotoInfo.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("lotoInfo", lotoInfo);
            model.addAttribute("concurrency", false);
            return new ModelAndView("lotoinfoes/lotoDetails/create");
        }
        getLotoInfoService().setLotoDetails(lotoInfo,lotoDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(LotoInfoesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
