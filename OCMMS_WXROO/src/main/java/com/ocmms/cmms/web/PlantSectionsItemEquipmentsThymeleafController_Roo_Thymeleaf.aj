    /**
     * TODO Auto-generated method documentation
     * 
     * @param plantSection
     * @param equipments
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PlantSectionsItemEquipmentsThymeleafController.create(@ModelAttribute PlantSection plantSection, @RequestParam(value = "equipmentsIds", required = false) List<Long> equipments, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipments != null) {
            for (Iterator<Long> iterator = equipments.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, plantSection.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipments != null) {
                plantSection.setEquipments(new HashSet<Equipment>(getEquipmentService().findAll(equipments)));
            }else{
                plantSection.setEquipments(new HashSet<Equipment>());
            }
            // Reset the version to prevent update
             plantSection.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("plantSection", plantSection);
            model.addAttribute("concurrency", true);
            return new ModelAndView("plantsections/equipments/create");
        }else if(!Objects.equals(version, plantSection.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("plantSection", plantSection);
            model.addAttribute("concurrency", false);
            return new ModelAndView("plantsections/equipments/create");
        }
        getPlantSectionService().setEquipments(plantSection,equipments);
        return new ModelAndView("redirect:" + getCollectionLink().to(PlantSectionsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
