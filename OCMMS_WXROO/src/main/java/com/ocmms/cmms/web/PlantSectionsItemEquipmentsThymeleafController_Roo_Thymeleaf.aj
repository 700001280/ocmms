    @ModelAttribute
    public PlantSection PlantSectionsItemEquipmentsThymeleafController.getPlantSection(@PathVariable("plantSection") Long id, Locale locale, HttpMethod method) {
        PlantSection plantSection = null;
        if (HttpMethod.PUT.equals(method)) {
            plantSection = plantSectionService.findOneForUpdate(id);
        } else {
            plantSection = plantSectionService.findOne(id);
        }
        
        if (plantSection == null) {
            String message = messageSource.getMessage("error_NotFound", new Object[] {"PlantSection", id}, "The record couldn't be found", locale);
            throw new NotFoundException(message);
        }
        return plantSection;
    }
    
