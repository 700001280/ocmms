    /**
     * TODO Auto-generated method documentation
     * 
     * @param assetStatus
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView AssetStatusesItemDocumentsThymeleafController.create(@ModelAttribute AssetStatus assetStatus, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, assetStatus.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                assetStatus.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                assetStatus.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             assetStatus.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("assetStatus", assetStatus);
            model.addAttribute("concurrency", true);
            return new ModelAndView("assetstatuses/documents/create");
        }else if(!Objects.equals(version, assetStatus.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("assetStatus", assetStatus);
            model.addAttribute("concurrency", false);
            return new ModelAndView("assetstatuses/documents/create");
        }
        getAssetStatusService().setDocuments(assetStatus,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(AssetStatusesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
