    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     * @param outstockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialCatalogsItemOutstockDetailsThymeleafController.create(@ModelAttribute MaterialCatalog materialCatalog, @RequestParam(value = "outstockDetailsIds", required = false) List<Long> outstockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (outstockDetails != null) {
            for (Iterator<Long> iterator = outstockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialCatalog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (outstockDetails != null) {
                materialCatalog.setOutstockDetails(new HashSet<OutstockDetail>(getOutstockDetailService().findAll(outstockDetails)));
            }else{
                materialCatalog.setOutstockDetails(new HashSet<OutstockDetail>());
            }
            // Reset the version to prevent update
             materialCatalog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialcatalogs/outstockDetails/create");
        }else if(!Objects.equals(version, materialCatalog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialcatalogs/outstockDetails/create");
        }
        getMaterialCatalogService().setOutstockDetails(materialCatalog,outstockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialCatalogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
