    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     * @param datatablesColumns
     * @param search
     * @param pageable
     * @param draw
     * @return ResponseEntity
     */
    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<OutstockDetail>> MaterialCatalogsItemOutstockDetailsThymeleafController.datatables(@ModelAttribute MaterialCatalog materialCatalog, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<OutstockDetail> outstockDetails = getOutstockDetailService().findByMaterialCatalog(materialCatalog, search, pageable);
        long totalOutstockDetailsCount = getOutstockDetailService().countByMaterialCatalog(materialCatalog);
        ConvertedDatatablesData<OutstockDetail> data =  new ConvertedDatatablesData<OutstockDetail>(outstockDetails, totalOutstockDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param ids
     * @param datatablesColumns
     * @param search
