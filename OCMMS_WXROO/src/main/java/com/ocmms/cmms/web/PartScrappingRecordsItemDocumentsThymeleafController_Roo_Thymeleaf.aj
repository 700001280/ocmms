    /**
     * TODO Auto-generated method documentation
     * 
     * @param partScrappingRecord
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView PartScrappingRecordsItemDocumentsThymeleafController.create(@ModelAttribute PartScrappingRecord partScrappingRecord, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, partScrappingRecord.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                partScrappingRecord.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                partScrappingRecord.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             partScrappingRecord.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("partScrappingRecord", partScrappingRecord);
            model.addAttribute("concurrency", true);
            return new ModelAndView("partscrappingrecords/documents/create");
        }else if(!Objects.equals(version, partScrappingRecord.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("partScrappingRecord", partScrappingRecord);
            model.addAttribute("concurrency", false);
            return new ModelAndView("partscrappingrecords/documents/create");
        }
        getPartScrappingRecordService().setDocuments(partScrappingRecord,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(PartScrappingRecordsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
