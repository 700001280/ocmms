    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> PartScrappingRecordsItemDocumentsThymeleafController.datatables(@ModelAttribute PartScrappingRecord partScrappingRecord, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByPartScrappingRecord(partScrappingRecord, search, pageable);
        long totalDocumentsCount = getDocumentService().countByPartScrappingRecord(partScrappingRecord);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
