    @PostMapping(name = "create")
    public ModelAndView NotificationUserStatusWithNumbersItemNotificationHeadersThymeleafController.create(@ModelAttribute NotificationUserStatusWithNumber notificationUserStatusWithNumber, @RequestParam(value = "notificationHeadersIds", required = false) List<Long> notificationHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (notificationHeaders != null) {
            for (Iterator<Long> iterator = notificationHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, notificationUserStatusWithNumber.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (notificationHeaders != null) {
                notificationUserStatusWithNumber.setNotificationHeaders(new HashSet<NotificationHeader>(getNotificationHeaderService().findAll(notificationHeaders)));
            }else{
                notificationUserStatusWithNumber.setNotificationHeaders(new HashSet<NotificationHeader>());
            }
            // Reset the version to prevent update
             notificationUserStatusWithNumber.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("notificationUserStatusWithNumber", notificationUserStatusWithNumber);
            model.addAttribute("concurrency", true);
            return new ModelAndView("notificationuserstatuswithnumbers/notificationHeaders/create");
        }else if(!Objects.equals(version, notificationUserStatusWithNumber.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("notificationUserStatusWithNumber", notificationUserStatusWithNumber);
            model.addAttribute("concurrency", false);
            return new ModelAndView("notificationuserstatuswithnumbers/notificationHeaders/create");
        }
        getNotificationUserStatusWithNumberService().setNotificationHeaders(notificationUserStatusWithNumber,notificationHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(NotificationUserStatusWithNumbersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
