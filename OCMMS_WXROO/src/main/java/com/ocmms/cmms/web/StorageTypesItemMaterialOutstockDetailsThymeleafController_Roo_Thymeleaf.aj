    /**
     * TODO Auto-generated method documentation
     * 
     * @param storageType
     * @param materialOutstockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView StorageTypesItemMaterialOutstockDetailsThymeleafController.create(@ModelAttribute StorageType storageType, @RequestParam(value = "materialOutstockDetailsIds", required = false) List<Long> materialOutstockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialOutstockDetails != null) {
            for (Iterator<Long> iterator = materialOutstockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, storageType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialOutstockDetails != null) {
                storageType.setMaterialOutstockDetails(new HashSet<MaterialOutstockDetail>(getMaterialOutstockDetailService().findAll(materialOutstockDetails)));
            }else{
                storageType.setMaterialOutstockDetails(new HashSet<MaterialOutstockDetail>());
            }
            // Reset the version to prevent update
             storageType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("storageType", storageType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("storagetypes/materialOutstockDetails/create");
        }else if(!Objects.equals(version, storageType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("storageType", storageType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("storagetypes/materialOutstockDetails/create");
        }
        getStorageTypeService().setMaterialOutstockDetails(storageType,materialOutstockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(StorageTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
