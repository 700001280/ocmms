    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipment
     * @param measuringPoints
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentsItemMeasuringPointsThymeleafController.create(@ModelAttribute Equipment equipment, @RequestParam(value = "measuringPointsIds", required = false) List<Long> measuringPoints, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (measuringPoints != null) {
            for (Iterator<Long> iterator = measuringPoints.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipment.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (measuringPoints != null) {
                equipment.setMeasuringPoints(new HashSet<MeasuringPoint>(getMeasuringPointService().findAll(measuringPoints)));
            }else{
                equipment.setMeasuringPoints(new HashSet<MeasuringPoint>());
            }
            // Reset the version to prevent update
             equipment.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipments/measuringPoints/create");
        }else if(!Objects.equals(version, equipment.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipments/measuringPoints/create");
        }
        getEquipmentService().setMeasuringPoints(equipment,measuringPoints);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
