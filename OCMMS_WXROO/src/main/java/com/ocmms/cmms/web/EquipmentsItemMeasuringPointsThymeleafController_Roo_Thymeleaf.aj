    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MeasuringPoint>> EquipmentsItemMeasuringPointsThymeleafController.datatables(@ModelAttribute Equipment equipment, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MeasuringPoint> measuringPoints = getMeasuringPointService().findByEquipment(equipment, search, pageable);
        long totalMeasuringPointsCount = getMeasuringPointService().countByEquipment(equipment);
        ConvertedDatatablesData<MeasuringPoint> data =  new ConvertedDatatablesData<MeasuringPoint>(measuringPoints, totalMeasuringPointsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
