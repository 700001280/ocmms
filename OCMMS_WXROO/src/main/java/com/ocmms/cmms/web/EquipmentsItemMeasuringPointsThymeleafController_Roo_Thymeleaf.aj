    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MeasuringPoint>> EquipmentsItemMeasuringPointsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MeasuringPoint> measuringPoints = getMeasuringPointService().findAllByIdsIn(ids, search, pageable);
        long totalMeasuringPointsCount = measuringPoints.getTotalElements();
        ConvertedDatatablesData<MeasuringPoint> data =  new ConvertedDatatablesData<MeasuringPoint>(measuringPoints, totalMeasuringPointsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
