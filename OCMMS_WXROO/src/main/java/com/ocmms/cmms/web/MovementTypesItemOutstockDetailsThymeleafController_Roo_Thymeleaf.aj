    @GetMapping(name = "datatablesByIdsIn", produces = Datatables.MEDIA_TYPE, value = "/dtByIdsIn")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<OutstockDetail>> MovementTypesItemOutstockDetailsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<OutstockDetail> outstockDetails = getOutstockDetailService().findAllByIdsIn(ids, search, pageable);
        long totalOutstockDetailsCount = outstockDetails.getTotalElements();
        ConvertedDatatablesData<OutstockDetail> data =  new ConvertedDatatablesData<OutstockDetail>(outstockDetails, totalOutstockDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
