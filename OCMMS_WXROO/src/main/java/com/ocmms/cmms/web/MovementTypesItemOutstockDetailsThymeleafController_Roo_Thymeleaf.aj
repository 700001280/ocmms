    /**
     * TODO Auto-generated method documentation
     * 
     * @param movementType
     * @param outstockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MovementTypesItemOutstockDetailsThymeleafController.create(@ModelAttribute MovementType movementType, @RequestParam(value = "outstockDetailsIds", required = false) List<Long> outstockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (outstockDetails != null) {
            for (Iterator<Long> iterator = outstockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, movementType.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (outstockDetails != null) {
                movementType.setOutstockDetails(new HashSet<OutstockDetail>(getOutstockDetailService().findAll(outstockDetails)));
            }else{
                movementType.setOutstockDetails(new HashSet<OutstockDetail>());
            }
            // Reset the version to prevent update
             movementType.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("movementType", movementType);
            model.addAttribute("concurrency", true);
            return new ModelAndView("movementtypes/outstockDetails/create");
        }else if(!Objects.equals(version, movementType.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("movementType", movementType);
            model.addAttribute("concurrency", false);
            return new ModelAndView("movementtypes/outstockDetails/create");
        }
        getMovementTypeService().setOutstockDetails(movementType,outstockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(MovementTypesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
