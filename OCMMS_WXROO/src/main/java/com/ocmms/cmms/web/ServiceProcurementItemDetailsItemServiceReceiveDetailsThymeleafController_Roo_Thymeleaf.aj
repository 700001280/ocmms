    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ServiceReceiveDetail>> ServiceProcurementItemDetailsItemServiceReceiveDetailsThymeleafController.datatables(@ModelAttribute ServiceProcurementItemDetail serviceProcurementItemDetail, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ServiceReceiveDetail> serviceReceiveDetails = getServiceReceiveDetailService().findByServiceProcurementItemDetail(serviceProcurementItemDetail, search, pageable);
        long totalServiceReceiveDetailsCount = getServiceReceiveDetailService().countByServiceProcurementItemDetail(serviceProcurementItemDetail);
        ConvertedDatatablesData<ServiceReceiveDetail> data =  new ConvertedDatatablesData<ServiceReceiveDetail>(serviceReceiveDetails, totalServiceReceiveDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
