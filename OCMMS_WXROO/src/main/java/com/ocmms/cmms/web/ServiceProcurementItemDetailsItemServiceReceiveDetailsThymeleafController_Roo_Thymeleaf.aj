    /**
     * TODO Auto-generated method documentation
     * 
     * @param serviceProcurementItemDetail
     * @param serviceReceiveDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ServiceProcurementItemDetailsItemServiceReceiveDetailsThymeleafController.create(@ModelAttribute ServiceProcurementItemDetail serviceProcurementItemDetail, @RequestParam(value = "serviceReceiveDetailsIds", required = false) List<Long> serviceReceiveDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (serviceReceiveDetails != null) {
            for (Iterator<Long> iterator = serviceReceiveDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, serviceProcurementItemDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (serviceReceiveDetails != null) {
                serviceProcurementItemDetail.setServiceReceiveDetails(new HashSet<ServiceReceiveDetail>(getServiceReceiveDetailService().findAll(serviceReceiveDetails)));
            }else{
                serviceProcurementItemDetail.setServiceReceiveDetails(new HashSet<ServiceReceiveDetail>());
            }
            // Reset the version to prevent update
             serviceProcurementItemDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("serviceProcurementItemDetail", serviceProcurementItemDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("serviceprocurementitemdetails/serviceReceiveDetails/create");
        }else if(!Objects.equals(version, serviceProcurementItemDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("serviceProcurementItemDetail", serviceProcurementItemDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("serviceprocurementitemdetails/serviceReceiveDetails/create");
        }
        getServiceProcurementItemDetailService().setServiceReceiveDetails(serviceProcurementItemDetail,serviceReceiveDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(ServiceProcurementItemDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
