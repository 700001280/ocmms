    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MainWorkCenter>> HierarchyWorkCentersItemMainWorkCentersThymeleafController.datatables(@ModelAttribute HierarchyWorkCenter hierarchyWorkCenter, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MainWorkCenter> mainWorkCenters = getMainWorkCenterService().findByHierarchyWorkCenter(hierarchyWorkCenter, search, pageable);
        long totalMainWorkCentersCount = getMainWorkCenterService().countByHierarchyWorkCenter(hierarchyWorkCenter);
        ConvertedDatatablesData<MainWorkCenter> data =  new ConvertedDatatablesData<MainWorkCenter>(mainWorkCenters, totalMainWorkCentersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
