    /**
     * TODO Auto-generated method documentation
     * 
     * @param hierarchyWorkCenter
     * @param mainWorkCenters
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView HierarchyWorkCentersItemMainWorkCentersThymeleafController.create(@ModelAttribute HierarchyWorkCenter hierarchyWorkCenter, @RequestParam(value = "mainWorkCentersIds", required = false) List<Long> mainWorkCenters, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (mainWorkCenters != null) {
            for (Iterator<Long> iterator = mainWorkCenters.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, hierarchyWorkCenter.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (mainWorkCenters != null) {
                hierarchyWorkCenter.setMainWorkCenters(new HashSet<MainWorkCenter>(getMainWorkCenterService().findAll(mainWorkCenters)));
            }else{
                hierarchyWorkCenter.setMainWorkCenters(new HashSet<MainWorkCenter>());
            }
            // Reset the version to prevent update
             hierarchyWorkCenter.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("hierarchyWorkCenter", hierarchyWorkCenter);
            model.addAttribute("concurrency", true);
            return new ModelAndView("hierarchyworkcenters/mainWorkCenters/create");
        }else if(!Objects.equals(version, hierarchyWorkCenter.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("hierarchyWorkCenter", hierarchyWorkCenter);
            model.addAttribute("concurrency", false);
            return new ModelAndView("hierarchyworkcenters/mainWorkCenters/create");
        }
        getHierarchyWorkCenterService().setMainWorkCenters(hierarchyWorkCenter,mainWorkCenters);
        return new ModelAndView("redirect:" + getCollectionLink().to(HierarchyWorkCentersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
