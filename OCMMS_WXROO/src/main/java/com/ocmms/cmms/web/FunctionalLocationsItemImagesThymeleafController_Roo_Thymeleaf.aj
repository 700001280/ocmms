    /**
     * TODO Auto-generated method documentation
     * 
     * @param functionalLocation
     * @param images
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView FunctionalLocationsItemImagesThymeleafController.create(@ModelAttribute FunctionalLocation functionalLocation, @RequestParam(value = "imagesIds", required = false) List<Long> images, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (images != null) {
            for (Iterator<Long> iterator = images.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, functionalLocation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (images != null) {
                functionalLocation.setImages(new HashSet<ImageDocument>(getImageDocumentService().findAll(images)));
            }else{
                functionalLocation.setImages(new HashSet<ImageDocument>());
            }
            // Reset the version to prevent update
             functionalLocation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("functionalLocation", functionalLocation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("functionallocations/images/create");
        }else if(!Objects.equals(version, functionalLocation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("functionalLocation", functionalLocation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("functionallocations/images/create");
        }
        getFunctionalLocationService().setImages(functionalLocation,images);
        return new ModelAndView("redirect:" + getCollectionLink().to(FunctionalLocationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
