    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MeasuringRecord>> EquipmentsItemMeasuringRecordsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MeasuringRecord> measuringRecords = getMeasuringRecordService().findAllByIdsIn(ids, search, pageable);
        long totalMeasuringRecordsCount = measuringRecords.getTotalElements();
        ConvertedDatatablesData<MeasuringRecord> data =  new ConvertedDatatablesData<MeasuringRecord>(measuringRecords, totalMeasuringRecordsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
