    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipment
     * @param measuringRecords
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentsItemMeasuringRecordsThymeleafController.create(@ModelAttribute Equipment equipment, @RequestParam(value = "measuringRecordsIds", required = false) List<Long> measuringRecords, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (measuringRecords != null) {
            for (Iterator<Long> iterator = measuringRecords.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipment.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (measuringRecords != null) {
                equipment.setMeasuringRecords(new HashSet<MeasuringRecord>(getMeasuringRecordService().findAll(measuringRecords)));
            }else{
                equipment.setMeasuringRecords(new HashSet<MeasuringRecord>());
            }
            // Reset the version to prevent update
             equipment.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipments/measuringRecords/create");
        }else if(!Objects.equals(version, equipment.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipments/measuringRecords/create");
        }
        getEquipmentService().setMeasuringRecords(equipment,measuringRecords);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
