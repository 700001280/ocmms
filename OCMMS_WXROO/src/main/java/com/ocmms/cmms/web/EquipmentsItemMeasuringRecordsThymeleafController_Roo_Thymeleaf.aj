    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MeasuringRecord>> EquipmentsItemMeasuringRecordsThymeleafController.datatables(@ModelAttribute Equipment equipment, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MeasuringRecord> measuringRecords = getMeasuringRecordService().findByEquipment(equipment, search, pageable);
        long totalMeasuringRecordsCount = getMeasuringRecordService().countByEquipment(equipment);
        ConvertedDatatablesData<MeasuringRecord> data =  new ConvertedDatatablesData<MeasuringRecord>(measuringRecords, totalMeasuringRecordsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
