    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<EquipmentStatusChangeRecord>> EquipmentsItemEquipmentStatusChangeRecordsThymeleafController.datatables(@ModelAttribute Equipment equipment, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<EquipmentStatusChangeRecord> equipmentStatusChangeRecords = getEquipmentStatusChangeRecordService().findByEquipment(equipment, search, pageable);
        long totalEquipmentStatusChangeRecordsCount = getEquipmentStatusChangeRecordService().countByEquipment(equipment);
        ConvertedDatatablesData<EquipmentStatusChangeRecord> data =  new ConvertedDatatablesData<EquipmentStatusChangeRecord>(equipmentStatusChangeRecords, totalEquipmentStatusChangeRecordsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
