    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipment
     * @param equipmentStatusChangeRecords
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentsItemEquipmentStatusChangeRecordsThymeleafController.create(@ModelAttribute Equipment equipment, @RequestParam(value = "equipmentStatusChangeRecordsIds", required = false) List<Long> equipmentStatusChangeRecords, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (equipmentStatusChangeRecords != null) {
            for (Iterator<Long> iterator = equipmentStatusChangeRecords.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipment.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (equipmentStatusChangeRecords != null) {
                equipment.setEquipmentStatusChangeRecords(new HashSet<EquipmentStatusChangeRecord>(getEquipmentStatusChangeRecordService().findAll(equipmentStatusChangeRecords)));
            }else{
                equipment.setEquipmentStatusChangeRecords(new HashSet<EquipmentStatusChangeRecord>());
            }
            // Reset the version to prevent update
             equipment.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipments/equipmentStatusChangeRecords/create");
        }else if(!Objects.equals(version, equipment.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipment", equipment);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipments/equipmentStatusChangeRecords/create");
        }
        getEquipmentService().setEquipmentStatusChangeRecords(equipment,equipmentStatusChangeRecords);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
