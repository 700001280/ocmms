    public ResponseEntity<ConvertedDatatablesData<WorkLog>> EmployeesItemWorkLogsThymeleafController.datatables(@ModelAttribute Employee logger, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<WorkLog> workLogs = getWorkLogService().findByLogger(logger, search, pageable);
        long totalWorkLogsCount = getWorkLogService().countByLogger(logger);
        ConvertedDatatablesData<WorkLog> data =  new ConvertedDatatablesData<WorkLog>(workLogs, totalWorkLogsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
