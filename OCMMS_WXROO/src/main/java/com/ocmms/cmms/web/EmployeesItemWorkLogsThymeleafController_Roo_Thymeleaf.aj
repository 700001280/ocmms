    @PostMapping(name = "create")
    public ModelAndView EmployeesItemWorkLogsThymeleafController.create(@ModelAttribute Employee employee, @RequestParam(value = "workLogsIds", required = false) List<Long> workLogs, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (workLogs != null) {
            for (Iterator<Long> iterator = workLogs.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, employee.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (workLogs != null) {
                employee.setWorkLogs(new HashSet<WorkLog>(getWorkLogService().findAll(workLogs)));
            }else{
                employee.setWorkLogs(new HashSet<WorkLog>());
            }
            // Reset the version to prevent update
             employee.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", true);
            return new ModelAndView("employees/workLogs/create");
        }else if(!Objects.equals(version, employee.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", false);
            return new ModelAndView("employees/workLogs/create");
        }
        getEmployeeService().setWorkLogs(employee,workLogs);
        return new ModelAndView("redirect:" + getCollectionLink().to(EmployeesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
