    public ResponseEntity<ConvertedDatatablesData<Document>> AssetInventoryRecordsItemDocumentsThymeleafController.datatables(@ModelAttribute AssetInventoryRecord assetInventoryRecord, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByAssetInventoryRecord(assetInventoryRecord, search, pageable);
