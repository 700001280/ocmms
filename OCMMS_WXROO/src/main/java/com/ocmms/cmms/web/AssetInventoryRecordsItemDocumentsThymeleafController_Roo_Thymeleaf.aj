    /**
     * TODO Auto-generated method documentation
     * 
     * @param assetInventoryRecord
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView AssetInventoryRecordsItemDocumentsThymeleafController.create(@ModelAttribute AssetInventoryRecord assetInventoryRecord, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, assetInventoryRecord.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                assetInventoryRecord.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                assetInventoryRecord.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             assetInventoryRecord.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("assetInventoryRecord", assetInventoryRecord);
            model.addAttribute("concurrency", true);
            return new ModelAndView("assetinventoryrecords/documents/create");
        }else if(!Objects.equals(version, assetInventoryRecord.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("assetInventoryRecord", assetInventoryRecord);
            model.addAttribute("concurrency", false);
            return new ModelAndView("assetinventoryrecords/documents/create");
        }
        getAssetInventoryRecordService().setDocuments(assetInventoryRecord,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(AssetInventoryRecordsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
