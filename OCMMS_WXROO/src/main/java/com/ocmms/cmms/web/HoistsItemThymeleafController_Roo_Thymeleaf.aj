            public Hoist doInConcurrency(Hoist hoist) throws Exception {
                return getHoistService().save(hoist);
            }
        });
        UriComponents showURI = getItemLink().to(HoistsItemThymeleafLinkFactory.SHOW).with("hoist", savedHoist.getId()).toUri();
        return new ModelAndView("redirect:" + showURI.toUriString());
    }
    
