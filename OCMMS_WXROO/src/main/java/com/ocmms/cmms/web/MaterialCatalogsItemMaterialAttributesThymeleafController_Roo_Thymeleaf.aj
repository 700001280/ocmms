    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MaterialAttribute>> MaterialCatalogsItemMaterialAttributesThymeleafController.datatables(@ModelAttribute MaterialCatalog materialCatalog, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MaterialAttribute> materialAttributes = getMaterialAttributeService().findByMaterialCatalog(materialCatalog, search, pageable);
        long totalMaterialAttributesCount = getMaterialAttributeService().countByMaterialCatalog(materialCatalog);
        ConvertedDatatablesData<MaterialAttribute> data =  new ConvertedDatatablesData<MaterialAttribute>(materialAttributes, totalMaterialAttributesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
