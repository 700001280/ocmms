    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     * @param materialAttributes
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialCatalogsItemMaterialAttributesThymeleafController.create(@ModelAttribute MaterialCatalog materialCatalog, @RequestParam(value = "materialAttributesIds", required = false) List<Long> materialAttributes, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialAttributes != null) {
            for (Iterator<Long> iterator = materialAttributes.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialCatalog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialAttributes != null) {
                materialCatalog.setMaterialAttributes(new HashSet<MaterialAttribute>(getMaterialAttributeService().findAll(materialAttributes)));
            }else{
                materialCatalog.setMaterialAttributes(new HashSet<MaterialAttribute>());
            }
            // Reset the version to prevent update
             materialCatalog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialcatalogs/materialAttributes/create");
        }else if(!Objects.equals(version, materialCatalog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialcatalogs/materialAttributes/create");
        }
        getMaterialCatalogService().setMaterialAttributes(materialCatalog,materialAttributes);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialCatalogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
