    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentParameter
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentParametersItemDocumentsThymeleafController.create(@ModelAttribute EquipmentParameter equipmentParameter, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipmentParameter.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                equipmentParameter.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                equipmentParameter.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             equipmentParameter.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipmentParameter", equipmentParameter);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipmentparameters/documents/create");
        }else if(!Objects.equals(version, equipmentParameter.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipmentParameter", equipmentParameter);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipmentparameters/documents/create");
        }
        getEquipmentParameterService().setDocuments(equipmentParameter,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentParametersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
