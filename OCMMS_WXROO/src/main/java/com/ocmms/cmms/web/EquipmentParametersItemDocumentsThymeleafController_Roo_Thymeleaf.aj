    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> EquipmentParametersItemDocumentsThymeleafController.datatables(@ModelAttribute EquipmentParameter equipmentParameter, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByEquipmentParameter(equipmentParameter, search, pageable);
        long totalDocumentsCount = getDocumentService().countByEquipmentParameter(equipmentParameter);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
