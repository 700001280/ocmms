     */
    @PostMapping(name = "create")
    public ModelAndView NotificationHeadersItemNotificationItemsThymeleafController.create(@ModelAttribute NotificationHeader notificationHeader, @RequestParam(value = "notificationItemsIds", required = false) List<Long> notificationItems, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (notificationItems != null) {
            for (Iterator<Long> iterator = notificationItems.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, notificationHeader.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (notificationItems != null) {
                notificationHeader.setNotificationItems(new HashSet<NotificationItem>(getNotificationItemService().findAll(notificationItems)));
            }else{
                notificationHeader.setNotificationItems(new HashSet<NotificationItem>());
            }
            // Reset the version to prevent update
             notificationHeader.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("notificationHeader", notificationHeader);
            model.addAttribute("concurrency", true);
            return new ModelAndView("notificationheaders/notificationItems/create");
        }else if(!Objects.equals(version, notificationHeader.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("notificationHeader", notificationHeader);
            model.addAttribute("concurrency", false);
            return new ModelAndView("notificationheaders/notificationItems/create");
        }
        getNotificationHeaderService().setNotificationItems(notificationHeader,notificationItems);
        return new ModelAndView("redirect:" + getCollectionLink().to(NotificationHeadersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
