    public ResponseEntity<ConvertedDatatablesData<NotificationItem>> NotificationHeadersItemNotificationItemsThymeleafController.datatables(@ModelAttribute NotificationHeader notificationHeader, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<NotificationItem> notificationItems = getNotificationItemService().findByNotificationHeader(notificationHeader, search, pageable);
        long totalNotificationItemsCount = getNotificationItemService().countByNotificationHeader(notificationHeader);
        ConvertedDatatablesData<NotificationItem> data =  new ConvertedDatatablesData<NotificationItem>(notificationItems, totalNotificationItemsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
