    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MaterialProcurementItemDetail>> ProcurementRequestsItemMaterialProcurementItemDetailsThymeleafController.datatables(@ModelAttribute ProcurementRequest procurementRequest, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MaterialProcurementItemDetail> materialProcurementItemDetails = getMaterialProcurementItemDetailService().findByProcurementRequest(procurementRequest, search, pageable);
        long totalMaterialProcurementItemDetailsCount = getMaterialProcurementItemDetailService().countByProcurementRequest(procurementRequest);
        ConvertedDatatablesData<MaterialProcurementItemDetail> data =  new ConvertedDatatablesData<MaterialProcurementItemDetail>(materialProcurementItemDetails, totalMaterialProcurementItemDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
