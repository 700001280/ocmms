    /**
     * TODO Auto-generated method documentation
     * 
     * @param procurementRequest
     * @param materialProcurementItemDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ProcurementRequestsItemMaterialProcurementItemDetailsThymeleafController.create(@ModelAttribute ProcurementRequest procurementRequest, @RequestParam(value = "materialProcurementItemDetailsIds", required = false) List<Long> materialProcurementItemDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialProcurementItemDetails != null) {
            for (Iterator<Long> iterator = materialProcurementItemDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, procurementRequest.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialProcurementItemDetails != null) {
                procurementRequest.setMaterialProcurementItemDetails(new HashSet<MaterialProcurementItemDetail>(getMaterialProcurementItemDetailService().findAll(materialProcurementItemDetails)));
            }else{
                procurementRequest.setMaterialProcurementItemDetails(new HashSet<MaterialProcurementItemDetail>());
            }
            // Reset the version to prevent update
             procurementRequest.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("procurementRequest", procurementRequest);
            model.addAttribute("concurrency", true);
            return new ModelAndView("procurementrequests/materialProcurementItemDetails/create");
        }else if(!Objects.equals(version, procurementRequest.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("procurementRequest", procurementRequest);
            model.addAttribute("concurrency", false);
            return new ModelAndView("procurementrequests/materialProcurementItemDetails/create");
        }
        getProcurementRequestService().setMaterialProcurementItemDetails(procurementRequest,materialProcurementItemDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(ProcurementRequestsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
