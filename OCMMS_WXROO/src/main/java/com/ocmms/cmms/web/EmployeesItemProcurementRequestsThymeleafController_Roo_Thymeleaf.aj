    /**
     * TODO Auto-generated method documentation
     * 
     * @param employee
     * @param procurementRequests
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EmployeesItemProcurementRequestsThymeleafController.create(@ModelAttribute Employee employee, @RequestParam(value = "procurementRequestsIds", required = false) List<Long> procurementRequests, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (procurementRequests != null) {
            for (Iterator<Long> iterator = procurementRequests.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, employee.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (procurementRequests != null) {
                employee.setProcurementRequests(new HashSet<ProcurementRequest>(getProcurementRequestService().findAll(procurementRequests)));
            }else{
                employee.setProcurementRequests(new HashSet<ProcurementRequest>());
            }
            // Reset the version to prevent update
             employee.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", true);
            return new ModelAndView("employees/procurementRequests/create");
        }else if(!Objects.equals(version, employee.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("employee", employee);
            model.addAttribute("concurrency", false);
            return new ModelAndView("employees/procurementRequests/create");
        }
        getEmployeeService().setProcurementRequests(employee,procurementRequests);
        return new ModelAndView("redirect:" + getCollectionLink().to(EmployeesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
