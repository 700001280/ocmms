    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ProcurementRequest>> EmployeesItemProcurementRequestsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ProcurementRequest> procurementRequests = getProcurementRequestService().findAllByIdsIn(ids, search, pageable);
        long totalProcurementRequestsCount = procurementRequests.getTotalElements();
        ConvertedDatatablesData<ProcurementRequest> data =  new ConvertedDatatablesData<ProcurementRequest>(procurementRequests, totalProcurementRequestsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
