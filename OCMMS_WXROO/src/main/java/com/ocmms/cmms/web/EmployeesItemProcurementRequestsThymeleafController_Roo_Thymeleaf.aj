    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ProcurementRequest>> EmployeesItemProcurementRequestsThymeleafController.datatables(@ModelAttribute Employee requester, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ProcurementRequest> procurementRequests = getProcurementRequestService().findByRequester(requester, search, pageable);
        long totalProcurementRequestsCount = getProcurementRequestService().countByRequester(requester);
        ConvertedDatatablesData<ProcurementRequest> data =  new ConvertedDatatablesData<ProcurementRequest>(procurementRequests, totalProcurementRequestsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
