    @PostMapping(name = "create")
    public ModelAndView TechnicalObjectsItemTaskHeadersThymeleafController.create(@ModelAttribute TechnicalObject technicalObject, @RequestParam(value = "taskHeadersIds", required = false) List<Long> taskHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (taskHeaders != null) {
            for (Iterator<Long> iterator = taskHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, technicalObject.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (taskHeaders != null) {
                technicalObject.setTaskHeaders(new HashSet<TaskHeader>(getTaskHeaderService().findAll(taskHeaders)));
            }else{
                technicalObject.setTaskHeaders(new HashSet<TaskHeader>());
            }
            // Reset the version to prevent update
             technicalObject.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", true);
            return new ModelAndView("technicalobjects/taskHeaders/create");
        }else if(!Objects.equals(version, technicalObject.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", false);
            return new ModelAndView("technicalobjects/taskHeaders/create");
        }
        getTechnicalObjectService().setTaskHeaders(technicalObject,taskHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(TechnicalObjectsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
