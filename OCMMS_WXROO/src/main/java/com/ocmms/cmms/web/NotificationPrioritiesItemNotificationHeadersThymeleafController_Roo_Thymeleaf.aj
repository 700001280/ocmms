    /**
     * TODO Auto-generated method documentation
     * 
     * @param notificationPriority
     * @param notificationHeaders
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView NotificationPrioritiesItemNotificationHeadersThymeleafController.create(@ModelAttribute NotificationPriority notificationPriority, @RequestParam(value = "notificationHeadersIds", required = false) List<Long> notificationHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (notificationHeaders != null) {
            for (Iterator<Long> iterator = notificationHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, notificationPriority.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (notificationHeaders != null) {
                notificationPriority.setNotificationHeaders(new HashSet<NotificationHeader>(getNotificationHeaderService().findAll(notificationHeaders)));
            }else{
                notificationPriority.setNotificationHeaders(new HashSet<NotificationHeader>());
            }
            // Reset the version to prevent update
             notificationPriority.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("notificationPriority", notificationPriority);
            model.addAttribute("concurrency", true);
            return new ModelAndView("notificationpriorities/notificationHeaders/create");
        }else if(!Objects.equals(version, notificationPriority.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("notificationPriority", notificationPriority);
            model.addAttribute("concurrency", false);
            return new ModelAndView("notificationpriorities/notificationHeaders/create");
        }
        getNotificationPriorityService().setNotificationHeaders(notificationPriority,notificationHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(NotificationPrioritiesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
