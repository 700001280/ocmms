    /**
     * TODO Auto-generated method documentation
     * 
     * @param hoist
     * @param result
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView HoistsCollectionThymeleafController.create(@Valid @ModelAttribute Hoist hoist, BindingResult result, Model model) {
        if (result.hasErrors()) {
            populateForm(model);
            
            return new ModelAndView("hoists/create");
        }
        Hoist newHoist = getHoistService().save(hoist);
        UriComponents showURI = getItemLink().to(HoistsItemThymeleafLinkFactory.SHOW).with("hoist", newHoist.getId()).toUri();
        return new ModelAndView("redirect:" + showURI.toUriString());
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param model
     * @return ModelAndView
     */
    @GetMapping(value = "/create-form", name = "createForm")
    public ModelAndView HoistsCollectionThymeleafController.createForm(Model model) {
        populateForm(model);
        
        model.addAttribute("hoist", new Hoist());
        return new ModelAndView("hoists/create");
    }
    
