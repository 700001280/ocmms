    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Hoist>> HoistsCollectionThymeleafController.datatables(DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        Page<Hoist> hoists = getHoistService().findAll(search, pageable);
        long totalHoistsCount = hoists.getTotalElements();
        if (search != null && StringUtils.isNotBlank(search.getText())) {
            totalHoistsCount = getHoistService().count();
        }
        ConvertedDatatablesData<Hoist> datatablesData = new ConvertedDatatablesData<Hoist>(hoists, totalHoistsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(datatablesData);
    }
    
