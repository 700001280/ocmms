    @PostMapping(name = "create")
    public ModelAndView NotificationSystemStatusesItemNotificationHeadersThymeleafController.create(@ModelAttribute NotificationSystemStatus notificationSystemStatus, @RequestParam(value = "notificationHeadersIds", required = false) List<Long> notificationHeaders, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (notificationHeaders != null) {
            for (Iterator<Long> iterator = notificationHeaders.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, notificationSystemStatus.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (notificationHeaders != null) {
                notificationSystemStatus.setNotificationHeaders(new HashSet<NotificationHeader>(getNotificationHeaderService().findAll(notificationHeaders)));
            }else{
                notificationSystemStatus.setNotificationHeaders(new HashSet<NotificationHeader>());
            }
            // Reset the version to prevent update
             notificationSystemStatus.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("notificationSystemStatus", notificationSystemStatus);
            model.addAttribute("concurrency", true);
            return new ModelAndView("notificationsystemstatuses/notificationHeaders/create");
        }else if(!Objects.equals(version, notificationSystemStatus.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("notificationSystemStatus", notificationSystemStatus);
            model.addAttribute("concurrency", false);
            return new ModelAndView("notificationsystemstatuses/notificationHeaders/create");
        }
        getNotificationSystemStatusService().setNotificationHeaders(notificationSystemStatus,notificationHeaders);
        return new ModelAndView("redirect:" + getCollectionLink().to(NotificationSystemStatusesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
