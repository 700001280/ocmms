    /**
     * TODO Auto-generated method documentation
     * 
     * @param taskTrackingStatus
     * @param taskTrackings
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TaskTrackingStatusesItemTaskTrackingsThymeleafController.create(@ModelAttribute TaskTrackingStatus taskTrackingStatus, @RequestParam(value = "taskTrackingsIds", required = false) List<Long> taskTrackings, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (taskTrackings != null) {
            for (Iterator<Long> iterator = taskTrackings.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, taskTrackingStatus.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (taskTrackings != null) {
                taskTrackingStatus.setTaskTrackings(new HashSet<TaskTracking>(getTaskTrackingService().findAll(taskTrackings)));
            }else{
                taskTrackingStatus.setTaskTrackings(new HashSet<TaskTracking>());
            }
            // Reset the version to prevent update
             taskTrackingStatus.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("taskTrackingStatus", taskTrackingStatus);
            model.addAttribute("concurrency", true);
            return new ModelAndView("tasktrackingstatuses/taskTrackings/create");
        }else if(!Objects.equals(version, taskTrackingStatus.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("taskTrackingStatus", taskTrackingStatus);
            model.addAttribute("concurrency", false);
            return new ModelAndView("tasktrackingstatuses/taskTrackings/create");
        }
        getTaskTrackingStatusService().setTaskTrackings(taskTrackingStatus,taskTrackings);
        return new ModelAndView("redirect:" + getCollectionLink().to(TaskTrackingStatusesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
