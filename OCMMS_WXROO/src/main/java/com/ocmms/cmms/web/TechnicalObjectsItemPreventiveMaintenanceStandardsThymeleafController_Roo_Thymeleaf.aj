    /**
     * TODO Auto-generated method documentation
     * 
     * @param technicalObject
     * @param preventiveMaintenanceStandards
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TechnicalObjectsItemPreventiveMaintenanceStandardsThymeleafController.create(@ModelAttribute TechnicalObject technicalObject, @RequestParam(value = "preventiveMaintenanceStandardsIds", required = false) List<Long> preventiveMaintenanceStandards, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (preventiveMaintenanceStandards != null) {
            for (Iterator<Long> iterator = preventiveMaintenanceStandards.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, technicalObject.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (preventiveMaintenanceStandards != null) {
                technicalObject.setPreventiveMaintenanceStandards(new HashSet<PreventiveMaintenanceStandard>(getPreventiveMaintenanceStandardService().findAll(preventiveMaintenanceStandards)));
            }else{
                technicalObject.setPreventiveMaintenanceStandards(new HashSet<PreventiveMaintenanceStandard>());
            }
            // Reset the version to prevent update
             technicalObject.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", true);
            return new ModelAndView("technicalobjects/preventiveMaintenanceStandards/create");
        }else if(!Objects.equals(version, technicalObject.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", false);
            return new ModelAndView("technicalobjects/preventiveMaintenanceStandards/create");
        }
        getTechnicalObjectService().setPreventiveMaintenanceStandards(technicalObject,preventiveMaintenanceStandards);
        return new ModelAndView("redirect:" + getCollectionLink().to(TechnicalObjectsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
