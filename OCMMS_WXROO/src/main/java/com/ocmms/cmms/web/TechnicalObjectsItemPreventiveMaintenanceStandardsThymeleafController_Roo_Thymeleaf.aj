        Page<PreventiveMaintenanceStandard> preventiveMaintenanceStandards = getPreventiveMaintenanceStandardService().findAllByIdsIn(ids, search, pageable);
        long totalPreventiveMaintenanceStandardsCount = preventiveMaintenanceStandards.getTotalElements();
