    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<PreventiveMaintenanceStandard>> TechnicalObjectsItemPreventiveMaintenanceStandardsThymeleafController.datatables(@ModelAttribute TechnicalObject technicalObjects, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<PreventiveMaintenanceStandard> preventiveMaintenanceStandards = getPreventiveMaintenanceStandardService().findByTechnicalObjectsContains(technicalObjects, search, pageable);
        long totalPreventiveMaintenanceStandardsCount = getPreventiveMaintenanceStandardService().countByTechnicalObjectsContains(technicalObjects);
        ConvertedDatatablesData<PreventiveMaintenanceStandard> data =  new ConvertedDatatablesData<PreventiveMaintenanceStandard>(preventiveMaintenanceStandards, totalPreventiveMaintenanceStandardsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
