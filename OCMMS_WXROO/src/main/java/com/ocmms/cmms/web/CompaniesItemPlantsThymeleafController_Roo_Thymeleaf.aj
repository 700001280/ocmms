    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Plant>> CompaniesItemPlantsThymeleafController.datatables(@ModelAttribute Company company, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Plant> plants = getPlantService().findByCompany(company, search, pageable);
        long totalPlantsCount = getPlantService().countByCompany(company);
        ConvertedDatatablesData<Plant> data =  new ConvertedDatatablesData<Plant>(plants, totalPlantsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
