    /**
     * TODO Auto-generated method documentation
     * 
     * @param company
     * @param plants
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView CompaniesItemPlantsThymeleafController.create(@ModelAttribute Company company, @RequestParam(value = "plantsIds", required = false) List<Long> plants, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (plants != null) {
            for (Iterator<Long> iterator = plants.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, company.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (plants != null) {
                company.setPlants(new HashSet<Plant>(getPlantService().findAll(plants)));
            }else{
                company.setPlants(new HashSet<Plant>());
            }
            // Reset the version to prevent update
             company.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("company", company);
            model.addAttribute("concurrency", true);
            return new ModelAndView("companies/plants/create");
        }else if(!Objects.equals(version, company.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("company", company);
            model.addAttribute("concurrency", false);
            return new ModelAndView("companies/plants/create");
        }
        getCompanyService().setPlants(company,plants);
        return new ModelAndView("redirect:" + getCollectionLink().to(CompaniesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
