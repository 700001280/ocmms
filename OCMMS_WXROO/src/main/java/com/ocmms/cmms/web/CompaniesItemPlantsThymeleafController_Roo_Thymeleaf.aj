    @GetMapping(name = "datatablesByIdsIn", produces = Datatables.MEDIA_TYPE, value = "/dtByIdsIn")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Plant>> CompaniesItemPlantsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Plant> plants = getPlantService().findAllByIdsIn(ids, search, pageable);
        long totalPlantsCount = plants.getTotalElements();
        ConvertedDatatablesData<Plant> data =  new ConvertedDatatablesData<Plant>(plants, totalPlantsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
