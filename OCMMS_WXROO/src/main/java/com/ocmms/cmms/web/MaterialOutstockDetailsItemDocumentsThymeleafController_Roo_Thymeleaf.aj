    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialOutstockDetail
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialOutstockDetailsItemDocumentsThymeleafController.create(@ModelAttribute MaterialOutstockDetail materialOutstockDetail, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialOutstockDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                materialOutstockDetail.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                materialOutstockDetail.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             materialOutstockDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialOutstockDetail", materialOutstockDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialoutstockdetails/documents/create");
        }else if(!Objects.equals(version, materialOutstockDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialOutstockDetail", materialOutstockDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialoutstockdetails/documents/create");
        }
        getMaterialOutstockDetailService().setDocuments(materialOutstockDetail,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialOutstockDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
