    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> MaterialOutstockDetailsItemDocumentsThymeleafController.datatables(@ModelAttribute MaterialOutstockDetail materialOutstockDetail, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByMaterialOutstockDetail(materialOutstockDetail, search, pageable);
        long totalDocumentsCount = getDocumentService().countByMaterialOutstockDetail(materialOutstockDetail);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
