    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MaterialStorageLocationInfo>> StorageLocationsItemMaterialStorageLocationInfosThymeleafController.datatables(@ModelAttribute StorageLocation storageLocation, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MaterialStorageLocationInfo> materialStorageLocationInfos = getMaterialStorageLocationInfoService().findByStorageLocation(storageLocation, search, pageable);
        long totalMaterialStorageLocationInfosCount = getMaterialStorageLocationInfoService().countByStorageLocation(storageLocation);
        ConvertedDatatablesData<MaterialStorageLocationInfo> data =  new ConvertedDatatablesData<MaterialStorageLocationInfo>(materialStorageLocationInfos, totalMaterialStorageLocationInfosCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
