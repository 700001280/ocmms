    /**
     * TODO Auto-generated method documentation
     * 
     * @param storageLocation
     * @param materialStorageLocationInfos
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView StorageLocationsItemMaterialStorageLocationInfosThymeleafController.create(@ModelAttribute StorageLocation storageLocation, @RequestParam(value = "materialStorageLocationInfosIds", required = false) List<Long> materialStorageLocationInfos, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialStorageLocationInfos != null) {
            for (Iterator<Long> iterator = materialStorageLocationInfos.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, storageLocation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialStorageLocationInfos != null) {
                storageLocation.setMaterialStorageLocationInfos(new HashSet<MaterialStorageLocationInfo>(getMaterialStorageLocationInfoService().findAll(materialStorageLocationInfos)));
            }else{
                storageLocation.setMaterialStorageLocationInfos(new HashSet<MaterialStorageLocationInfo>());
            }
            // Reset the version to prevent update
             storageLocation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("storageLocation", storageLocation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("storagelocations/materialStorageLocationInfos/create");
        }else if(!Objects.equals(version, storageLocation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("storageLocation", storageLocation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("storagelocations/materialStorageLocationInfos/create");
        }
        getStorageLocationService().setMaterialStorageLocationInfos(storageLocation,materialStorageLocationInfos);
        return new ModelAndView("redirect:" + getCollectionLink().to(StorageLocationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
