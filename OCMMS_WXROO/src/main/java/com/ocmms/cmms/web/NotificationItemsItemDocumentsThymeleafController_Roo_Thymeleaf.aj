    /**
     * TODO Auto-generated method documentation
     * 
     * @param notificationItem
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView NotificationItemsItemDocumentsThymeleafController.create(@ModelAttribute NotificationItem notificationItem, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, notificationItem.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                notificationItem.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                notificationItem.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             notificationItem.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("notificationItem", notificationItem);
            model.addAttribute("concurrency", true);
            return new ModelAndView("notificationitems/documents/create");
        }else if(!Objects.equals(version, notificationItem.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("notificationItem", notificationItem);
            model.addAttribute("concurrency", false);
            return new ModelAndView("notificationitems/documents/create");
        }
        getNotificationItemService().setDocuments(notificationItem,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(NotificationItemsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
