    public ModelAndView AutonomousMaintenanceFindingsCollectionThymeleafController.create(@Valid @ModelAttribute AutonomousMaintenanceFinding autonomousMaintenanceFinding, BindingResult result, Model model) {
        if (result.hasErrors()) {
            populateForm(model);
            
            return new ModelAndView("autonomousmaintenancefindings/create");
        }
        AutonomousMaintenanceFinding newAutonomousMaintenanceFinding = getAutonomousMaintenanceFindingService().save(autonomousMaintenanceFinding);
        UriComponents showURI = getItemLink().to(AutonomousMaintenanceFindingsItemThymeleafLinkFactory.SHOW).with("autonomousMaintenanceFinding", newAutonomousMaintenanceFinding.getId()).toUri();
        return new ModelAndView("redirect:" + showURI.toUriString());
    }
    
