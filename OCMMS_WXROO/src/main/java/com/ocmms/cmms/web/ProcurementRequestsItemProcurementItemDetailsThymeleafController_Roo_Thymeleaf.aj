    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<ProcurementItemDetail>> ProcurementRequestsItemProcurementItemDetailsThymeleafController.datatables(@ModelAttribute ProcurementRequest procurementRequest, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<ProcurementItemDetail> procurementItemDetails = getProcurementItemDetailService().findByProcurementRequest(procurementRequest, search, pageable);
        long totalProcurementItemDetailsCount = getProcurementItemDetailService().countByProcurementRequest(procurementRequest);
        ConvertedDatatablesData<ProcurementItemDetail> data =  new ConvertedDatatablesData<ProcurementItemDetail>(procurementItemDetails, totalProcurementItemDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
     * TODO Auto-generated method documentation
