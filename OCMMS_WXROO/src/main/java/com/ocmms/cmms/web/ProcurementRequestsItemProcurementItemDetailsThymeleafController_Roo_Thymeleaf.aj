    public ProcurementRequest ProcurementRequestsItemProcurementItemDetailsThymeleafController.getProcurementRequest(@PathVariable("procurementRequest") Long id, Locale locale, HttpMethod method) {
        ProcurementRequest procurementRequest = null;
        if (HttpMethod.PUT.equals(method)) {
            procurementRequest = procurementRequestService.findOneForUpdate(id);
        } else {
            procurementRequest = procurementRequestService.findOne(id);
        }
        
        if (procurementRequest == null) {
            String message = messageSource.getMessage("error_NotFound", new Object[] {"ProcurementRequest", id}, "The record couldn't be found", locale);
            throw new NotFoundException(message);
        }
        return procurementRequest;
    }
    
