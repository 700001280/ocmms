        Page<EquipmentReplaceRecord> equipmentReplaceRecords = getEquipmentReplaceRecordService().findAllByIdsIn(ids, search, pageable);
        long totalEquipmentReplaceRecordsCount = equipmentReplaceRecords.getTotalElements();
