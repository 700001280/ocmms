    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<EquipmentReplaceRecord>> EquipmentsItemEquipmentReplaceRecordsThymeleafController.datatables(@ModelAttribute Equipment equipment, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<EquipmentReplaceRecord> equipmentReplaceRecords = getEquipmentReplaceRecordService().findByEquipment(equipment, search, pageable);
        long totalEquipmentReplaceRecordsCount = getEquipmentReplaceRecordService().countByEquipment(equipment);
        ConvertedDatatablesData<EquipmentReplaceRecord> data =  new ConvertedDatatablesData<EquipmentReplaceRecord>(equipmentReplaceRecords, totalEquipmentReplaceRecordsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
