    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<Document>> MaterialInstockDetailsItemDocumentsThymeleafController.datatables(@ModelAttribute MaterialInstockDetail materialInstockDetail, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<Document> documents = getDocumentService().findByMaterialInstockDetail(materialInstockDetail, search, pageable);
        long totalDocumentsCount = getDocumentService().countByMaterialInstockDetail(materialInstockDetail);
        ConvertedDatatablesData<Document> data =  new ConvertedDatatablesData<Document>(documents, totalDocumentsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
