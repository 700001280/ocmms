    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialInstockDetail
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialInstockDetailsItemDocumentsThymeleafController.create(@ModelAttribute MaterialInstockDetail materialInstockDetail, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialInstockDetail.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                materialInstockDetail.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                materialInstockDetail.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             materialInstockDetail.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialInstockDetail", materialInstockDetail);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialinstockdetails/documents/create");
        }else if(!Objects.equals(version, materialInstockDetail.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialInstockDetail", materialInstockDetail);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialinstockdetails/documents/create");
        }
        getMaterialInstockDetailService().setDocuments(materialInstockDetail,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialInstockDetailsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
