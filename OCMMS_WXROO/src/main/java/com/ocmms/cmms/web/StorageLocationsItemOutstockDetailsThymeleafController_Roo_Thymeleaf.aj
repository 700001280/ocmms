    /**
     * TODO Auto-generated method documentation
     * 
     * @param storageLocation
     * @param outstockDetails
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView StorageLocationsItemOutstockDetailsThymeleafController.create(@ModelAttribute StorageLocation storageLocation, @RequestParam(value = "outstockDetailsIds", required = false) List<Long> outstockDetails, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (outstockDetails != null) {
            for (Iterator<Long> iterator = outstockDetails.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, storageLocation.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (outstockDetails != null) {
                storageLocation.setOutstockDetails(new HashSet<OutstockDetail>(getOutstockDetailService().findAll(outstockDetails)));
            }else{
                storageLocation.setOutstockDetails(new HashSet<OutstockDetail>());
            }
            // Reset the version to prevent update
             storageLocation.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("storageLocation", storageLocation);
            model.addAttribute("concurrency", true);
            return new ModelAndView("storagelocations/outstockDetails/create");
        }else if(!Objects.equals(version, storageLocation.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("storageLocation", storageLocation);
            model.addAttribute("concurrency", false);
            return new ModelAndView("storagelocations/outstockDetails/create");
        }
        getStorageLocationService().setOutstockDetails(storageLocation,outstockDetails);
        return new ModelAndView("redirect:" + getCollectionLink().to(StorageLocationsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
