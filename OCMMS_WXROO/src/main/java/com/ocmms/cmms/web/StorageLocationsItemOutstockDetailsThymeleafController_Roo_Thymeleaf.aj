    /**
     * TODO Auto-generated method documentation
     * 
     * @param storageLocation
     * @param datatablesColumns
     * @param search
     * @param pageable
     * @param draw
     * @return ResponseEntity
     */
    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<OutstockDetail>> StorageLocationsItemOutstockDetailsThymeleafController.datatables(@ModelAttribute StorageLocation storageLocation, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<OutstockDetail> outstockDetails = getOutstockDetailService().findByStorageLocation(storageLocation, search, pageable);
        long totalOutstockDetailsCount = getOutstockDetailService().countByStorageLocation(storageLocation);
        ConvertedDatatablesData<OutstockDetail> data =  new ConvertedDatatablesData<OutstockDetail>(outstockDetails, totalOutstockDetailsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
     * TODO Auto-generated method documentation
