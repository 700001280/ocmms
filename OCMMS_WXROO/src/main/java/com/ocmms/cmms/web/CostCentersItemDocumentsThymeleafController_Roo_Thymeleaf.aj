    /**
     * TODO Auto-generated method documentation
     * 
     * @param costCenter
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView CostCentersItemDocumentsThymeleafController.create(@ModelAttribute CostCenter costCenter, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, costCenter.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                costCenter.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                costCenter.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             costCenter.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", true);
            return new ModelAndView("costcenters/documents/create");
        }else if(!Objects.equals(version, costCenter.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", false);
            return new ModelAndView("costcenters/documents/create");
        }
        getCostCenterService().setDocuments(costCenter,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(CostCentersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
