    /**
     * TODO Auto-generated method documentation
     * 
     * @param taskTrackingPriority
     * @param taskTrackings
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TaskTrackingPrioritiesItemTaskTrackingsThymeleafController.create(@ModelAttribute TaskTrackingPriority taskTrackingPriority, @RequestParam(value = "taskTrackingsIds", required = false) List<Long> taskTrackings, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (taskTrackings != null) {
            for (Iterator<Long> iterator = taskTrackings.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, taskTrackingPriority.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (taskTrackings != null) {
                taskTrackingPriority.setTaskTrackings(new HashSet<TaskTracking>(getTaskTrackingService().findAll(taskTrackings)));
            }else{
                taskTrackingPriority.setTaskTrackings(new HashSet<TaskTracking>());
            }
            // Reset the version to prevent update
             taskTrackingPriority.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("taskTrackingPriority", taskTrackingPriority);
            model.addAttribute("concurrency", true);
            return new ModelAndView("tasktrackingpriorities/taskTrackings/create");
        }else if(!Objects.equals(version, taskTrackingPriority.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("taskTrackingPriority", taskTrackingPriority);
            model.addAttribute("concurrency", false);
            return new ModelAndView("tasktrackingpriorities/taskTrackings/create");
        }
        getTaskTrackingPriorityService().setTaskTrackings(taskTrackingPriority,taskTrackings);
        return new ModelAndView("redirect:" + getCollectionLink().to(TaskTrackingPrioritiesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
