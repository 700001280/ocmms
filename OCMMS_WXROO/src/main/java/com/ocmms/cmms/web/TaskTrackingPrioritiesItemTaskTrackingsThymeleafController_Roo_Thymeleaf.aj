    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<TaskTracking>> TaskTrackingPrioritiesItemTaskTrackingsThymeleafController.datatables(@ModelAttribute TaskTrackingPriority taskTrackingPriority, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<TaskTracking> taskTrackings = getTaskTrackingService().findByTaskTrackingPriority(taskTrackingPriority, search, pageable);
