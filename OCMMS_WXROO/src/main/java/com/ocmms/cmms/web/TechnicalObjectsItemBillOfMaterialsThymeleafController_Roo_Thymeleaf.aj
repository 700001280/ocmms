    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<BillOfMaterial>> TechnicalObjectsItemBillOfMaterialsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<BillOfMaterial> billOfMaterials = getBillOfMaterialService().findAllByIdsIn(ids, search, pageable);
        long totalBillOfMaterialsCount = billOfMaterials.getTotalElements();
        ConvertedDatatablesData<BillOfMaterial> data =  new ConvertedDatatablesData<BillOfMaterial>(billOfMaterials, totalBillOfMaterialsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
