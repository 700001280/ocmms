    /**
     * TODO Auto-generated method documentation
     * 
     * @param technicalObject
     * @param billOfMaterials
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TechnicalObjectsItemBillOfMaterialsThymeleafController.create(@ModelAttribute TechnicalObject technicalObject, @RequestParam(value = "billOfMaterialsIds", required = false) List<Long> billOfMaterials, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (billOfMaterials != null) {
            for (Iterator<Long> iterator = billOfMaterials.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, technicalObject.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (billOfMaterials != null) {
                technicalObject.setBillOfMaterials(new HashSet<BillOfMaterial>(getBillOfMaterialService().findAll(billOfMaterials)));
            }else{
                technicalObject.setBillOfMaterials(new HashSet<BillOfMaterial>());
            }
            // Reset the version to prevent update
             technicalObject.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", true);
            return new ModelAndView("technicalobjects/billOfMaterials/create");
        }else if(!Objects.equals(version, technicalObject.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", false);
            return new ModelAndView("technicalobjects/billOfMaterials/create");
        }
        getTechnicalObjectService().setBillOfMaterials(technicalObject,billOfMaterials);
        return new ModelAndView("redirect:" + getCollectionLink().to(TechnicalObjectsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
