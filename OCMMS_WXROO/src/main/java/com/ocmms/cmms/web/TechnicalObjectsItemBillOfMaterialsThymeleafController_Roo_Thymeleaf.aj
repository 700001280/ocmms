    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<BillOfMaterial>> TechnicalObjectsItemBillOfMaterialsThymeleafController.datatables(@ModelAttribute TechnicalObject technicalObjects, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<BillOfMaterial> billOfMaterials = getBillOfMaterialService().findByTechnicalObjectsContains(technicalObjects, search, pageable);
        long totalBillOfMaterialsCount = getBillOfMaterialService().countByTechnicalObjectsContains(technicalObjects);
        ConvertedDatatablesData<BillOfMaterial> data =  new ConvertedDatatablesData<BillOfMaterial>(billOfMaterials, totalBillOfMaterialsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
