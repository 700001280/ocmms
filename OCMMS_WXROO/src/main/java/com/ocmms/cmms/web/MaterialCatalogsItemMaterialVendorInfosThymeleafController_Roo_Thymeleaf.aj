    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MaterialVendorInfo>> MaterialCatalogsItemMaterialVendorInfosThymeleafController.datatables(@ModelAttribute MaterialCatalog materialCatalog, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MaterialVendorInfo> materialVendorInfos = getMaterialVendorInfoService().findByMaterialCatalog(materialCatalog, search, pageable);
        long totalMaterialVendorInfosCount = getMaterialVendorInfoService().countByMaterialCatalog(materialCatalog);
        ConvertedDatatablesData<MaterialVendorInfo> data =  new ConvertedDatatablesData<MaterialVendorInfo>(materialVendorInfos, totalMaterialVendorInfosCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
