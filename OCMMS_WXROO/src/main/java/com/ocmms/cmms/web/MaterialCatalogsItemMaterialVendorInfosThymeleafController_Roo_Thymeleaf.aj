    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     * @param materialVendorInfos
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView MaterialCatalogsItemMaterialVendorInfosThymeleafController.create(@ModelAttribute MaterialCatalog materialCatalog, @RequestParam(value = "materialVendorInfosIds", required = false) List<Long> materialVendorInfos, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (materialVendorInfos != null) {
            for (Iterator<Long> iterator = materialVendorInfos.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, materialCatalog.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (materialVendorInfos != null) {
                materialCatalog.setMaterialVendorInfos(new HashSet<MaterialVendorInfo>(getMaterialVendorInfoService().findAll(materialVendorInfos)));
            }else{
                materialCatalog.setMaterialVendorInfos(new HashSet<MaterialVendorInfo>());
            }
            // Reset the version to prevent update
             materialCatalog.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", true);
            return new ModelAndView("materialcatalogs/materialVendorInfos/create");
        }else if(!Objects.equals(version, materialCatalog.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("materialCatalog", materialCatalog);
            model.addAttribute("concurrency", false);
            return new ModelAndView("materialcatalogs/materialVendorInfos/create");
        }
        getMaterialCatalogService().setMaterialVendorInfos(materialCatalog,materialVendorInfos);
        return new ModelAndView("redirect:" + getCollectionLink().to(MaterialCatalogsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
