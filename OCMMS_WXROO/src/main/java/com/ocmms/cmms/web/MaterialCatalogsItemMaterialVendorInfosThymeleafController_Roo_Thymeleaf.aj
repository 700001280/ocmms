    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MaterialVendorInfo>> MaterialCatalogsItemMaterialVendorInfosThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MaterialVendorInfo> materialVendorInfos = getMaterialVendorInfoService().findAllByIdsIn(ids, search, pageable);
        long totalMaterialVendorInfosCount = materialVendorInfos.getTotalElements();
        ConvertedDatatablesData<MaterialVendorInfo> data =  new ConvertedDatatablesData<MaterialVendorInfo>(materialVendorInfos, totalMaterialVendorInfosCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
