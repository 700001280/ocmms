    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentScrappingRecord
     * @param documents
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView EquipmentScrappingRecordsItemDocumentsThymeleafController.create(@ModelAttribute EquipmentScrappingRecord equipmentScrappingRecord, @RequestParam(value = "documentsIds", required = false) List<Long> documents, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (documents != null) {
            for (Iterator<Long> iterator = documents.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, equipmentScrappingRecord.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (documents != null) {
                equipmentScrappingRecord.setDocuments(new HashSet<Document>(getDocumentService().findAll(documents)));
            }else{
                equipmentScrappingRecord.setDocuments(new HashSet<Document>());
            }
            // Reset the version to prevent update
             equipmentScrappingRecord.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("equipmentScrappingRecord", equipmentScrappingRecord);
            model.addAttribute("concurrency", true);
            return new ModelAndView("equipmentscrappingrecords/documents/create");
        }else if(!Objects.equals(version, equipmentScrappingRecord.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("equipmentScrappingRecord", equipmentScrappingRecord);
            model.addAttribute("concurrency", false);
            return new ModelAndView("equipmentscrappingrecords/documents/create");
        }
        getEquipmentScrappingRecordService().setDocuments(equipmentScrappingRecord,documents);
        return new ModelAndView("redirect:" + getCollectionLink().to(EquipmentScrappingRecordsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
