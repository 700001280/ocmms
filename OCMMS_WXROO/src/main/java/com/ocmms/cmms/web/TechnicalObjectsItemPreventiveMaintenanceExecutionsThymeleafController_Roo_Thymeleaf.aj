    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<PreventiveMaintenanceExecution>> TechnicalObjectsItemPreventiveMaintenanceExecutionsThymeleafController.datatables(@ModelAttribute TechnicalObject technicalObject, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<PreventiveMaintenanceExecution> preventiveMaintenanceExecutions = getPreventiveMaintenanceExecutionService().findByTechnicalObject(technicalObject, search, pageable);
        long totalPreventiveMaintenanceExecutionsCount = getPreventiveMaintenanceExecutionService().countByTechnicalObject(technicalObject);
        ConvertedDatatablesData<PreventiveMaintenanceExecution> data =  new ConvertedDatatablesData<PreventiveMaintenanceExecution>(preventiveMaintenanceExecutions, totalPreventiveMaintenanceExecutionsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
