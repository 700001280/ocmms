    /**
     * TODO Auto-generated method documentation
     * 
     * @param technicalObject
     * @param preventiveMaintenanceExecutions
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView TechnicalObjectsItemPreventiveMaintenanceExecutionsThymeleafController.create(@ModelAttribute TechnicalObject technicalObject, @RequestParam(value = "preventiveMaintenanceExecutionsIds", required = false) List<Long> preventiveMaintenanceExecutions, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (preventiveMaintenanceExecutions != null) {
            for (Iterator<Long> iterator = preventiveMaintenanceExecutions.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, technicalObject.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (preventiveMaintenanceExecutions != null) {
                technicalObject.setPreventiveMaintenanceExecutions(new HashSet<PreventiveMaintenanceExecution>(getPreventiveMaintenanceExecutionService().findAll(preventiveMaintenanceExecutions)));
            }else{
                technicalObject.setPreventiveMaintenanceExecutions(new HashSet<PreventiveMaintenanceExecution>());
            }
            // Reset the version to prevent update
             technicalObject.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", true);
            return new ModelAndView("technicalobjects/preventiveMaintenanceExecutions/create");
        }else if(!Objects.equals(version, technicalObject.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("technicalObject", technicalObject);
            model.addAttribute("concurrency", false);
            return new ModelAndView("technicalobjects/preventiveMaintenanceExecutions/create");
        }
        getTechnicalObjectService().setPreventiveMaintenanceExecutions(technicalObject,preventiveMaintenanceExecutions);
        return new ModelAndView("redirect:" + getCollectionLink().to(TechnicalObjectsCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
