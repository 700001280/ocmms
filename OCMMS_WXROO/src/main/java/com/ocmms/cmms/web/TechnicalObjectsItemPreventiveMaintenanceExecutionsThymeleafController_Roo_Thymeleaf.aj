    public ResponseEntity<ConvertedDatatablesData<PreventiveMaintenanceExecution>> TechnicalObjectsItemPreventiveMaintenanceExecutionsThymeleafController.datatablesByIdsIn(@RequestParam("ids") List<Long> ids, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<PreventiveMaintenanceExecution> preventiveMaintenanceExecutions = getPreventiveMaintenanceExecutionService().findAllByIdsIn(ids, search, pageable);
        long totalPreventiveMaintenanceExecutionsCount = preventiveMaintenanceExecutions.getTotalElements();
        ConvertedDatatablesData<PreventiveMaintenanceExecution> data =  new ConvertedDatatablesData<PreventiveMaintenanceExecution>(preventiveMaintenanceExecutions, totalPreventiveMaintenanceExecutionsCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
