    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<MainWorkCenter>> CostCentersItemMainWorkCentersThymeleafController.datatables(@ModelAttribute CostCenter costCenter, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<MainWorkCenter> mainWorkCenters = getMainWorkCenterService().findByCostCenter(costCenter, search, pageable);
        long totalMainWorkCentersCount = getMainWorkCenterService().countByCostCenter(costCenter);
        ConvertedDatatablesData<MainWorkCenter> data =  new ConvertedDatatablesData<MainWorkCenter>(mainWorkCenters, totalMainWorkCentersCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
