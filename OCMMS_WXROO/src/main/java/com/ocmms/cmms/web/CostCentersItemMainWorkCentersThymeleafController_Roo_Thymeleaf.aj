    /**
     * TODO Auto-generated method documentation
     * 
     * @param costCenter
     * @param mainWorkCenters
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView CostCentersItemMainWorkCentersThymeleafController.create(@ModelAttribute CostCenter costCenter, @RequestParam(value = "mainWorkCentersIds", required = false) List<Long> mainWorkCenters, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (mainWorkCenters != null) {
            for (Iterator<Long> iterator = mainWorkCenters.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, costCenter.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (mainWorkCenters != null) {
                costCenter.setMainWorkCenters(new HashSet<MainWorkCenter>(getMainWorkCenterService().findAll(mainWorkCenters)));
            }else{
                costCenter.setMainWorkCenters(new HashSet<MainWorkCenter>());
            }
            // Reset the version to prevent update
             costCenter.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", true);
            return new ModelAndView("costcenters/mainWorkCenters/create");
        }else if(!Objects.equals(version, costCenter.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("costCenter", costCenter);
            model.addAttribute("concurrency", false);
            return new ModelAndView("costcenters/mainWorkCenters/create");
        }
        getCostCenterService().setMainWorkCenters(costCenter,mainWorkCenters);
        return new ModelAndView("redirect:" + getCollectionLink().to(CostCentersCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
