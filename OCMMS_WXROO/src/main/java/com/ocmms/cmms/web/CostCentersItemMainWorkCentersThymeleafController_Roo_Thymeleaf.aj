    @ModelAttribute
    public CostCenter CostCentersItemMainWorkCentersThymeleafController.getCostCenter(@PathVariable("costCenter") Long id, Locale locale, HttpMethod method) {
        CostCenter costCenter = null;
        if (HttpMethod.PUT.equals(method)) {
            costCenter = costCenterService.findOneForUpdate(id);
        } else {
            costCenter = costCenterService.findOne(id);
        }
        
