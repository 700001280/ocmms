    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<LotoInfo>> LotoBaseInfoesItemLotoInfoesThymeleafController.datatables(@ModelAttribute LotoBaseInfo lotoBaseInfo, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<LotoInfo> lotoInfoes = getLotoInfoService().findByLotoBaseInfo(lotoBaseInfo, search, pageable);
        long totalLotoInfoesCount = getLotoInfoService().countByLotoBaseInfo(lotoBaseInfo);
