    /**
     * TODO Auto-generated method documentation
     * 
     * @param lotoBaseInfo
     * @param lotoInfoes
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView LotoBaseInfoesItemLotoInfoesThymeleafController.create(@ModelAttribute LotoBaseInfo lotoBaseInfo, @RequestParam(value = "lotoInfoesIds", required = false) List<Long> lotoInfoes, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (lotoInfoes != null) {
            for (Iterator<Long> iterator = lotoInfoes.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, lotoBaseInfo.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (lotoInfoes != null) {
                lotoBaseInfo.setLotoInfoes(new HashSet<LotoInfo>(getLotoInfoService().findAll(lotoInfoes)));
            }else{
                lotoBaseInfo.setLotoInfoes(new HashSet<LotoInfo>());
            }
            // Reset the version to prevent update
             lotoBaseInfo.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("lotoBaseInfo", lotoBaseInfo);
            model.addAttribute("concurrency", true);
            return new ModelAndView("lotobaseinfoes/lotoInfoes/create");
        }else if(!Objects.equals(version, lotoBaseInfo.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("lotoBaseInfo", lotoBaseInfo);
            model.addAttribute("concurrency", false);
            return new ModelAndView("lotobaseinfoes/lotoInfoes/create");
        }
        getLotoBaseInfoService().setLotoInfoes(lotoBaseInfo,lotoInfoes);
        return new ModelAndView("redirect:" + getCollectionLink().to(LotoBaseInfoesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
