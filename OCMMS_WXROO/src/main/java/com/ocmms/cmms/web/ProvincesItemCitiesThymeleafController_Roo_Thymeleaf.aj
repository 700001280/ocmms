    /**
     * TODO Auto-generated method documentation
     * 
     * @param province
     * @param cities
     * @param version
     * @param concurrencyControl
     * @param model
     * @return ModelAndView
     */
    @PostMapping(name = "create")
    public ModelAndView ProvincesItemCitiesThymeleafController.create(@ModelAttribute Province province, @RequestParam(value = "citiesIds", required = false) List<Long> cities, @RequestParam("parentVersion") Long version, @RequestParam(value = "concurrency", required = false, defaultValue = "") String concurrencyControl, Model model) {
        // Remove empty values
        if (cities != null) {
            for (Iterator<Long> iterator = cities.iterator(); iterator.hasNext();) {
                if (iterator.next() == null) {
                    iterator.remove();
                }
            }
        }
        // Concurrency control
        if(!Objects.equals(version, province.getVersion()) && StringUtils.isEmpty(concurrencyControl)){
            populateForm(model);
            // Obtain the selected books and include them in the author that will be 
            // included in the view
            if (cities != null) {
                province.setCities(new HashSet<City>(getCityService().findAll(cities)));
            }else{
                province.setCities(new HashSet<City>());
            }
            // Reset the version to prevent update
             province.setVersion(version);
            // Include the updated element in the model
            model.addAttribute("province", province);
            model.addAttribute("concurrency", true);
            return new ModelAndView("provinces/cities/create");
        }else if(!Objects.equals(version, province.getVersion()) && "discard".equals(concurrencyControl)){
            populateForm(model);
            // Provide the original element from the Database
            model.addAttribute("province", province);
            model.addAttribute("concurrency", false);
            return new ModelAndView("provinces/cities/create");
        }
        getProvinceService().setCities(province,cities);
        return new ModelAndView("redirect:" + getCollectionLink().to(ProvincesCollectionThymeleafLinkFactory.LIST).toUriString());
    }
    
