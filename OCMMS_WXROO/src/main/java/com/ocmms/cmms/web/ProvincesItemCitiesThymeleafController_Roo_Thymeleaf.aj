    @ModelAttribute
    public Province ProvincesItemCitiesThymeleafController.getProvince(@PathVariable("province") Long id, Locale locale, HttpMethod method) {
        Province province = null;
        if (HttpMethod.PUT.equals(method)) {
            province = provinceService.findOneForUpdate(id);
        } else {
            province = provinceService.findOne(id);
        }
        
        if (province == null) {
            String message = messageSource.getMessage("error_NotFound", new Object[] {"Province", id}, "The record couldn't be found", locale);
            throw new NotFoundException(message);
        }
        return province;
    }
    
