    @GetMapping(name = "datatables", produces = Datatables.MEDIA_TYPE, value = "/dt")
    @ResponseBody
    public ResponseEntity<ConvertedDatatablesData<City>> ProvincesItemCitiesThymeleafController.datatables(@ModelAttribute Province province, DatatablesColumns datatablesColumns, GlobalSearch search, DatatablesPageable pageable, @RequestParam("draw") Integer draw) {
        
        Page<City> cities = getCityService().findByProvince(province, search, pageable);
        long totalCitiesCount = getCityService().countByProvince(province);
        ConvertedDatatablesData<City> data =  new ConvertedDatatablesData<City>(cities, totalCitiesCount, draw, getConversionService(), datatablesColumns);
        return ResponseEntity.ok(data);
    }
    
    /**
