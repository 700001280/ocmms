        notificationSystemStatus.removeFromNotificationHeaders(toRemove);
        notificationSystemStatus.addToNotificationHeaders(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        notificationSystemStatus.setVersion(notificationSystemStatus.getVersion() + 1);
        return getNotificationSystemStatusRepository().save(notificationSystemStatus);
    }
    
