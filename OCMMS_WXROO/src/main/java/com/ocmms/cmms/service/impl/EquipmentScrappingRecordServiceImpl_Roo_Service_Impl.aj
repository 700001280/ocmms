    @Transactional
    public EquipmentScrappingRecord EquipmentScrappingRecordServiceImpl.setDocuments(EquipmentScrappingRecord equipmentScrappingRecord, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = equipmentScrappingRecord.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        equipmentScrappingRecord.removeFromDocuments(toRemove);
        equipmentScrappingRecord.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        equipmentScrappingRecord.setVersion(equipmentScrappingRecord.getVersion() + 1);
        return getEquipmentScrappingRecordRepository().save(equipmentScrappingRecord);
    }
    
