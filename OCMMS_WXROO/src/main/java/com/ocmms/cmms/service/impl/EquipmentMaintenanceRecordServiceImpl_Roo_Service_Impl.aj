    @Transactional
    public void EquipmentMaintenanceRecordServiceImpl.delete(EquipmentMaintenanceRecord equipmentMaintenanceRecord) {
        // Clear bidirectional many-to-one child relationship with Equipment
        if (equipmentMaintenanceRecord.getEquipment() != null) {
            equipmentMaintenanceRecord.getEquipment().getEquipmentMaintenanceRecords().remove(equipmentMaintenanceRecord);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : equipmentMaintenanceRecord.getDocuments()) {
            item.setEquipmentMaintenanceRecord(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : equipmentMaintenanceRecord.getImages()) {
            item.setEquipmentMaintenanceRecord(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MaterialOutstockDetail
        for (MaterialOutstockDetail item : equipmentMaintenanceRecord.getMaterialOutstockDetails()) {
            item.setEquipmentMaintenanceRecord(null);
        }
        
        getEquipmentMaintenanceRecordRepository().delete(equipmentMaintenanceRecord);
    }
    
