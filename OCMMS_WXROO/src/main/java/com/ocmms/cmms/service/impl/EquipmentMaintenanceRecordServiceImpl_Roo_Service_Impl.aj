            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        equipmentMaintenanceRecord.removeFromDocuments(toRemove);
        equipmentMaintenanceRecord.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        equipmentMaintenanceRecord.setVersion(equipmentMaintenanceRecord.getVersion() + 1);
        return getEquipmentMaintenanceRecordRepository().save(equipmentMaintenanceRecord);
    }
    
