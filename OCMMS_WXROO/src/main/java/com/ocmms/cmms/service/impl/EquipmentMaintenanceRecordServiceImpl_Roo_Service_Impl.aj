    public EquipmentMaintenanceRecord EquipmentMaintenanceRecordServiceImpl.setDocuments(EquipmentMaintenanceRecord equipmentMaintenanceRecord, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = equipmentMaintenanceRecord.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
