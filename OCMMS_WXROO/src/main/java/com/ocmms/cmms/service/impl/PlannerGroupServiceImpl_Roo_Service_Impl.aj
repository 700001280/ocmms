     */
    @Transactional
    public void PlannerGroupServiceImpl.delete(PlannerGroup plannerGroup) {
        // Clear bidirectional one-to-many parent relationship with OperationalWorkCenter
        for (OperationalWorkCenter item : plannerGroup.getOperationalWorkCenters()) {
            item.setPlannerGroup(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with TechnicalObject
        for (TechnicalObject item : plannerGroup.getTechnicalObjects()) {
            item.setPlannerGroup(null);
        }
        
        getPlannerGroupRepository().delete(plannerGroup);
    }
    
