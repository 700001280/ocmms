    @Transactional
    public PlannerGroup PlannerGroupServiceImpl.setOperationalWorkCenters(PlannerGroup plannerGroup, Iterable<Long> operationalWorkCenters) {
        List<OperationalWorkCenter> items = getOperationalWorkCenterService().findAll(operationalWorkCenters);
        Set<OperationalWorkCenter> currents = plannerGroup.getOperationalWorkCenters();
        Set<OperationalWorkCenter> toRemove = new HashSet<OperationalWorkCenter>();
        for (Iterator<OperationalWorkCenter> iterator = currents.iterator(); iterator.hasNext();) {
            OperationalWorkCenter nextOperationalWorkCenter = iterator.next();
            if (items.contains(nextOperationalWorkCenter)) {
                items.remove(nextOperationalWorkCenter);
            } else {
                toRemove.add(nextOperationalWorkCenter);
            }
        }
        plannerGroup.removeFromOperationalWorkCenters(toRemove);
        plannerGroup.addToOperationalWorkCenters(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        plannerGroup.setVersion(plannerGroup.getVersion() + 1);
        return getPlannerGroupRepository().save(plannerGroup);
    }
    
