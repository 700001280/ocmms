        // Clear bidirectional many-to-one child relationship with WorkOrderMaterial
        if (materialProcurementItemDetail.getWorkOrderMaterial() != null) {
            materialProcurementItemDetail.getWorkOrderMaterial().getMaterialProcurementItemDetails().remove(materialProcurementItemDetail);
        }
        
        // Clear bidirectional one-to-many parent relationship with MaterialInstockDetail
        for (MaterialInstockDetail item : materialProcurementItemDetail.getMaterialInstockDetails()) {
            item.setMaterialProcurementItemDetail(null);
        }
        
        getMaterialProcurementItemDetailRepository().delete(materialProcurementItemDetail);
    }
    
