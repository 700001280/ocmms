    @Transactional
    public MaterialProcurementItemDetail MaterialProcurementItemDetailServiceImpl.setMaterialInstockDetails(MaterialProcurementItemDetail materialProcurementItemDetail, Iterable<Long> materialInstockDetails) {
        List<MaterialInstockDetail> items = getMaterialInstockDetailService().findAll(materialInstockDetails);
        Set<MaterialInstockDetail> currents = materialProcurementItemDetail.getMaterialInstockDetails();
        Set<MaterialInstockDetail> toRemove = new HashSet<MaterialInstockDetail>();
        for (Iterator<MaterialInstockDetail> iterator = currents.iterator(); iterator.hasNext();) {
            MaterialInstockDetail nextMaterialInstockDetail = iterator.next();
            if (items.contains(nextMaterialInstockDetail)) {
                items.remove(nextMaterialInstockDetail);
            } else {
                toRemove.add(nextMaterialInstockDetail);
            }
        }
        materialProcurementItemDetail.removeFromMaterialInstockDetails(toRemove);
        materialProcurementItemDetail.addToMaterialInstockDetails(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        materialProcurementItemDetail.setVersion(materialProcurementItemDetail.getVersion() + 1);
        return getMaterialProcurementItemDetailRepository().save(materialProcurementItemDetail);
    }
    
