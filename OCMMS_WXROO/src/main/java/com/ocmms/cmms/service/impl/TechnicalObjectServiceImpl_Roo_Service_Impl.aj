            technicalObject.getMainWorkCenter().getTechnicalObjects().remove(technicalObject);
        }
        
        // Clear bidirectional many-to-one child relationship with PlannerGroup
        if (technicalObject.getPlannerGroup() != null) {
            technicalObject.getPlannerGroup().getTechnicalObjects().remove(technicalObject);
        }
        
        // Clear bidirectional many-to-one child relationship with Organization
        if (technicalObject.getOrganization() != null) {
            technicalObject.getOrganization().getTechnicalObjects().remove(technicalObject);
        }
        
        // Clear bidirectional many-to-one child relationship with AbcIndicator
        if (technicalObject.getAbcIndicator() != null) {
            technicalObject.getAbcIndicator().getTechnicalObjects().remove(technicalObject);
        }
        
        // Clear bidirectional many-to-many parent relationship with BillOfMaterial
        for (BillOfMaterial item : technicalObject.getBillOfMaterials()) {
            item.getTechnicalObjects().remove(technicalObject);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : technicalObject.getDocuments()) {
            item.setTechnicalObject(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Equipment
        for (Equipment item : technicalObject.getEquipments()) {
            item.setSuperiorEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : technicalObject.getImages()) {
            item.setTechnicalObject(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with NotificationHeader
        for (NotificationHeader item : technicalObject.getNotificationHeaders()) {
            item.setTechnicalObject(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with PreventiveMaintenanceExecution
        for (PreventiveMaintenanceExecution item : technicalObject.getPreventiveMaintenanceExecutions()) {
            item.setTechnicalObject(null);
        }
        
        // Clear bidirectional many-to-many parent relationship with PreventiveMaintenanceStandard
        for (PreventiveMaintenanceStandard item : technicalObject.getPreventiveMaintenanceStandards()) {
            item.getTechnicalObjects().remove(technicalObject);
        }
        
        // Clear bidirectional one-to-many parent relationship with TaskHeader
        for (TaskHeader item : technicalObject.getTaskHeaders()) {
            item.setTechnicalObject(null);
        }
        
        getTechnicalObjectRepository().delete(technicalObject);
    }
    
