    /**
     * TODO Auto-generated method documentation
     * 
     * @param technicalObject
     * @param billOfMaterials
     * @return TechnicalObject
     */
    @Transactional
    public TechnicalObject TechnicalObjectServiceImpl.setBillOfMaterials(TechnicalObject technicalObject, Iterable<Long> billOfMaterials) {
        List<BillOfMaterial> items = getBillOfMaterialService().findAll(billOfMaterials);
        Set<BillOfMaterial> currents = technicalObject.getBillOfMaterials();
        Set<BillOfMaterial> toRemove = new HashSet<BillOfMaterial>();
        for (Iterator<BillOfMaterial> iterator = currents.iterator(); iterator.hasNext();) {
            BillOfMaterial nextBillOfMaterial = iterator.next();
            if (items.contains(nextBillOfMaterial)) {
                items.remove(nextBillOfMaterial);
            } else {
                toRemove.add(nextBillOfMaterial);
            }
        }
        technicalObject.removeFromBillOfMaterials(toRemove);
        technicalObject.addToBillOfMaterials(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        technicalObject.setVersion(technicalObject.getVersion() + 1);
        return getTechnicalObjectRepository().save(technicalObject);
    }
    
