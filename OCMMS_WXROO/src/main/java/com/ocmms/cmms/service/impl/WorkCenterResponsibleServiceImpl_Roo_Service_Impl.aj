    @Transactional
    public void WorkCenterResponsibleServiceImpl.delete(WorkCenterResponsible workCenterResponsible) {
        // Clear bidirectional many-to-one child relationship with Organization
        if (workCenterResponsible.getOrganization() != null) {
            workCenterResponsible.getOrganization().getWorkCenterResponsibles().remove(workCenterResponsible);
        }
        
        // Clear bidirectional one-to-many parent relationship with HierarchyWorkCenter
        for (HierarchyWorkCenter item : workCenterResponsible.getHierarchyWorkCenters()) {
            item.setResponsible(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MainWorkCenter
        for (MainWorkCenter item : workCenterResponsible.getMainWorkCenters()) {
            item.setResponsible(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with OperationalWorkCenter
        for (OperationalWorkCenter item : workCenterResponsible.getOperationalWorkCenters()) {
            item.setResponsible(null);
        }
        
        getWorkCenterResponsibleRepository().delete(workCenterResponsible);
    }
    
