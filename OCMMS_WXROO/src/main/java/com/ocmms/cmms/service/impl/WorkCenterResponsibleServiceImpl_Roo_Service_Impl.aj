        workCenterResponsible.addToHierarchyWorkCenters(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        workCenterResponsible.setVersion(workCenterResponsible.getVersion() + 1);
        return getWorkCenterResponsibleRepository().save(workCenterResponsible);
    }
    
