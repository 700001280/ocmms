    @Transactional
    public WorkOrderOperation WorkOrderOperationServiceImpl.setTimeSheets(WorkOrderOperation workOrderOperation, Iterable<Long> timeSheets) {
        List<WorkOrderTimeSheet> items = getWorkOrderTimeSheetService().findAll(timeSheets);
        Set<WorkOrderTimeSheet> currents = workOrderOperation.getTimeSheets();
        Set<WorkOrderTimeSheet> toRemove = new HashSet<WorkOrderTimeSheet>();
        for (Iterator<WorkOrderTimeSheet> iterator = currents.iterator(); iterator.hasNext();) {
            WorkOrderTimeSheet nextWorkOrderTimeSheet = iterator.next();
            if (items.contains(nextWorkOrderTimeSheet)) {
                items.remove(nextWorkOrderTimeSheet);
            } else {
                toRemove.add(nextWorkOrderTimeSheet);
            }
        }
        workOrderOperation.removeFromTimeSheets(toRemove);
        workOrderOperation.addToTimeSheets(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        workOrderOperation.setVersion(workOrderOperation.getVersion() + 1);
        return getWorkOrderOperationRepository().save(workOrderOperation);
    }
    
