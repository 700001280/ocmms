        // Clear bidirectional one-to-many parent relationship with WorkOrderTimeSheet
        for (WorkOrderTimeSheet item : workOrderOperation.getTimeSheets()) {
            item.setWorkOrderOperation(null);
        }
        
        getWorkOrderOperationRepository().delete(workOrderOperation);
    }
    
