    /**
     * TODO Auto-generated method documentation
     * 
     * @param notificationItem
     * @param documents
     * @return NotificationItem
     */
    @Transactional
    public NotificationItem NotificationItemServiceImpl.setDocuments(NotificationItem notificationItem, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = notificationItem.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        notificationItem.removeFromDocuments(toRemove);
        notificationItem.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        notificationItem.setVersion(notificationItem.getVersion() + 1);
        return getNotificationItemRepository().save(notificationItem);
    }
    
    /**
     * TODO Auto-generated method documentation
