    @Transactional
    public NotificationItem NotificationItemServiceImpl.setImages(NotificationItem notificationItem, Iterable<Long> images) {
        List<ImageDocument> items = getImageDocumentService().findAll(images);
        Set<ImageDocument> currents = notificationItem.getImages();
        Set<ImageDocument> toRemove = new HashSet<ImageDocument>();
        for (Iterator<ImageDocument> iterator = currents.iterator(); iterator.hasNext();) {
            ImageDocument nextImageDocument = iterator.next();
            if (items.contains(nextImageDocument)) {
                items.remove(nextImageDocument);
            } else {
                toRemove.add(nextImageDocument);
            }
        }
        notificationItem.removeFromImages(toRemove);
        notificationItem.addToImages(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        notificationItem.setVersion(notificationItem.getVersion() + 1);
        return getNotificationItemRepository().save(notificationItem);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param notificationItem
     */
    @Transactional
    public void NotificationItemServiceImpl.delete(NotificationItem notificationItem) {
        // Clear bidirectional many-to-one child relationship with NotificationHeader
        if (notificationItem.getNotificationHeader() != null) {
            notificationItem.getNotificationHeader().getNotificationItems().remove(notificationItem);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : notificationItem.getDocuments()) {
            item.setNotificationItem(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : notificationItem.getImages()) {
            item.setNotificationItem(null);
        }
        
        getNotificationItemRepository().delete(notificationItem);
    }
    
