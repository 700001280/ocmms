    @Transactional
    public void EquipmentCategoryServiceImpl.delete(EquipmentCategory equipmentCategory) {
        // Clear bidirectional one-to-many parent relationship with Equipment
        for (Equipment item : equipmentCategory.getEquipments()) {
            item.setEquipmentCategory(null);
        }
        
        getEquipmentCategoryRepository().delete(equipmentCategory);
    }
    
