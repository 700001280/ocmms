    @Transactional
    public EquipmentCategory EquipmentCategoryServiceImpl.setEquipments(EquipmentCategory equipmentCategory, Iterable<Long> equipments) {
        List<Equipment> items = getEquipmentService().findAll(equipments);
        Set<Equipment> currents = equipmentCategory.getEquipments();
        Set<Equipment> toRemove = new HashSet<Equipment>();
        for (Iterator<Equipment> iterator = currents.iterator(); iterator.hasNext();) {
            Equipment nextEquipment = iterator.next();
            if (items.contains(nextEquipment)) {
                items.remove(nextEquipment);
            } else {
                toRemove.add(nextEquipment);
            }
        }
        equipmentCategory.removeFromEquipments(toRemove);
        equipmentCategory.addToEquipments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        equipmentCategory.setVersion(equipmentCategory.getVersion() + 1);
        return getEquipmentCategoryRepository().save(equipmentCategory);
    }
    
