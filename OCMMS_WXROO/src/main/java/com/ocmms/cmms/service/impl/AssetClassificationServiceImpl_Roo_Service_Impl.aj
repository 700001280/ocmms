     * @param assetClassification
     * @param documents
     * @return AssetClassification
     */
    @Transactional
    public AssetClassification AssetClassificationServiceImpl.setDocuments(AssetClassification assetClassification, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = assetClassification.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        assetClassification.removeFromDocuments(toRemove);
        assetClassification.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        assetClassification.setVersion(assetClassification.getVersion() + 1);
        return getAssetClassificationRepository().save(assetClassification);
    }
    
