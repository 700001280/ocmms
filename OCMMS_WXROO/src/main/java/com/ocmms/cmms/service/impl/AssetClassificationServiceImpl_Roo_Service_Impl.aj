    /**
     * TODO Auto-generated method documentation
     * 
     * @param assetClassification
     */
    @Transactional
    public void AssetClassificationServiceImpl.delete(AssetClassification assetClassification) {
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : assetClassification.getDocuments()) {
            item.setAssetClassification(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Equipment
        for (Equipment item : assetClassification.getEquipments()) {
            item.setAssetClassification(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : assetClassification.getImages()) {
            item.setAssetClassification(null);
        }
        
        getAssetClassificationRepository().delete(assetClassification);
    }
    
