    public void TaskHeaderServiceImpl.delete(TaskHeader taskHeader) {
        // Clear bidirectional many-to-one child relationship with TechnicalObject
        if (taskHeader.getTechnicalObject() != null) {
            taskHeader.getTechnicalObject().getTaskHeaders().remove(taskHeader);
        }
        
        // Clear bidirectional one-to-many parent relationship with TaskHeaderText
        for (TaskHeaderText item : taskHeader.getTaskHeaderTexts()) {
            item.setTaskHeader(null);
        }
        
        getTaskHeaderRepository().delete(taskHeader);
    }
    
