    @Transactional
    public TaskHeader TaskHeaderServiceImpl.setTaskHeaderTexts(TaskHeader taskHeader, Iterable<Long> taskHeaderTexts) {
        List<TaskHeaderText> items = getTaskHeaderTextService().findAll(taskHeaderTexts);
        Set<TaskHeaderText> currents = taskHeader.getTaskHeaderTexts();
        Set<TaskHeaderText> toRemove = new HashSet<TaskHeaderText>();
        for (Iterator<TaskHeaderText> iterator = currents.iterator(); iterator.hasNext();) {
            TaskHeaderText nextTaskHeaderText = iterator.next();
            if (items.contains(nextTaskHeaderText)) {
                items.remove(nextTaskHeaderText);
            } else {
                toRemove.add(nextTaskHeaderText);
            }
        }
        taskHeader.removeFromTaskHeaderTexts(toRemove);
        taskHeader.addToTaskHeaderTexts(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        taskHeader.setVersion(taskHeader.getVersion() + 1);
        return getTaskHeaderRepository().save(taskHeader);
    }
    
