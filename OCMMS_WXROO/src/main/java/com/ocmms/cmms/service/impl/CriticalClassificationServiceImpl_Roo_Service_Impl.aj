    /**
     * TODO Auto-generated method documentation
     * 
     * @param criticalClassification
     * @param documents
     * @return CriticalClassification
     */
    @Transactional
    public CriticalClassification CriticalClassificationServiceImpl.setDocuments(CriticalClassification criticalClassification, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = criticalClassification.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        criticalClassification.removeFromDocuments(toRemove);
        criticalClassification.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        criticalClassification.setVersion(criticalClassification.getVersion() + 1);
        return getCriticalClassificationRepository().save(criticalClassification);
    }
    
