    /**
     * TODO Auto-generated method documentation
     * 
     * @param criticalClassification
     */
    @Transactional
    public void CriticalClassificationServiceImpl.delete(CriticalClassification criticalClassification) {
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : criticalClassification.getDocuments()) {
            item.setCriticalClassification(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Equipment
        for (Equipment item : criticalClassification.getEquipments()) {
            item.setCriticalClassification(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : criticalClassification.getImages()) {
            item.setCriticalClassification(null);
        }
        
        getCriticalClassificationRepository().delete(criticalClassification);
    }
    
