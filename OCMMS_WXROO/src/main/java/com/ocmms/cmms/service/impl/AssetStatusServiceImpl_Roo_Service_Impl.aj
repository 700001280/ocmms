    /**
     * TODO Auto-generated method documentation
     * 
     * @param assetStatus
     * @param documents
     * @return AssetStatus
     */
    @Transactional
    public AssetStatus AssetStatusServiceImpl.setDocuments(AssetStatus assetStatus, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = assetStatus.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        assetStatus.removeFromDocuments(toRemove);
        assetStatus.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        assetStatus.setVersion(assetStatus.getVersion() + 1);
        return getAssetStatusRepository().save(assetStatus);
    }
    
    /**
     * TODO Auto-generated method documentation
