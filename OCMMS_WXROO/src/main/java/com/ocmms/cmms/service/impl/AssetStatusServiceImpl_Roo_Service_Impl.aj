    @Transactional
    public void AssetStatusServiceImpl.delete(AssetStatus assetStatus) {
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : assetStatus.getDocuments()) {
            item.setAssetStatus(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : assetStatus.getImages()) {
            item.setAssetStatus(null);
        }
        
        getAssetStatusRepository().delete(assetStatus);
    }
    
