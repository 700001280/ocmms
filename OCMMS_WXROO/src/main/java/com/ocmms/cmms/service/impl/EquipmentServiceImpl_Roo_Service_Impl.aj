    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipment
     * @param assetInventoryRecords
     * @return Equipment
     */
    @Transactional
    public Equipment EquipmentServiceImpl.setAssetInventoryRecords(Equipment equipment, Iterable<Long> assetInventoryRecords) {
        List<AssetInventoryRecord> items = getAssetInventoryRecordService().findAll(assetInventoryRecords);
        Set<AssetInventoryRecord> currents = equipment.getAssetInventoryRecords();
        Set<AssetInventoryRecord> toRemove = new HashSet<AssetInventoryRecord>();
        for (Iterator<AssetInventoryRecord> iterator = currents.iterator(); iterator.hasNext();) {
            AssetInventoryRecord nextAssetInventoryRecord = iterator.next();
            if (items.contains(nextAssetInventoryRecord)) {
                items.remove(nextAssetInventoryRecord);
            } else {
                toRemove.add(nextAssetInventoryRecord);
            }
        }
        equipment.removeFromAssetInventoryRecords(toRemove);
        equipment.addToAssetInventoryRecords(items);
