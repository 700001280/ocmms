    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipment
     */
    @Transactional
    public void EquipmentServiceImpl.delete(Equipment equipment) {
        // Clear bidirectional many-to-one child relationship with PlannerGroup
        if (equipment.getPlannerGroup() != null) {
            equipment.getPlannerGroup().getTechnicalObjects().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with PlantSection
        if (equipment.getPlantSection() != null) {
            equipment.getPlantSection().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with AssetClassification
        if (equipment.getAssetClassification() != null) {
            equipment.getAssetClassification().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with PlantLocation
        if (equipment.getPlantLocation() != null) {
            equipment.getPlantLocation().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with EquipmentCategory
        if (equipment.getEquipmentCategory() != null) {
            equipment.getEquipmentCategory().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with ObjectType
        if (equipment.getObjectType() != null) {
            equipment.getObjectType().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with MainWorkCenter
        if (equipment.getMainWorkCenter() != null) {
            equipment.getMainWorkCenter().getTechnicalObjects().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with CriticalClassification
        if (equipment.getCriticalClassification() != null) {
            equipment.getCriticalClassification().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with FunctionalLocation
        if (equipment.getFunctionalLocation() != null) {
            equipment.getFunctionalLocation().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional many-to-one child relationship with TechnicalObject
        if (equipment.getSuperiorEquipment() != null) {
            equipment.getSuperiorEquipment().getEquipments().remove(equipment);
        }
        
        // Clear bidirectional one-to-many parent relationship with AssetInventoryRecord
        for (AssetInventoryRecord item : equipment.getAssetInventoryRecords()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with AssetStatusChangeRecord
        for (AssetStatusChangeRecord item : equipment.getAssetStatusChangeRecords()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : equipment.getEquipDocuments()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional many-to-many parent relationship with EquipmentLubrication
        for (EquipmentLubrication item : equipment.getEquipmentLubrications()) {
            item.getEquipments().remove(equipment);
        }
        
        // Clear bidirectional one-to-many parent relationship with EquipmentMaintenanceRecord
        for (EquipmentMaintenanceRecord item : equipment.getEquipmentMaintenanceRecords()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional many-to-many parent relationship with EquipmentParameter
        for (EquipmentParameter item : equipment.getEquipmentParameters()) {
            item.getEquipments().remove(equipment);
        }
        
        // Clear bidirectional one-to-many parent relationship with EquipmentReplaceRecord
        for (EquipmentReplaceRecord item : equipment.getEquipmentReplaceRecords()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with EquipmentStatusChangeRecord
        for (EquipmentStatusChangeRecord item : equipment.getEquipmentStatusChangeRecords()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : equipment.getImages()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with LotoInfo
        for (LotoInfo item : equipment.getLotoInfoes()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MeasuringPoint
        for (MeasuringPoint item : equipment.getMeasuringPoints()) {
            item.setEquipment(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MeasuringRecord
        for (MeasuringRecord item : equipment.getMeasuringRecords()) {
            item.setEquipment(null);
        }
        
        getEquipmentRepository().delete(equipment);
    }
    
