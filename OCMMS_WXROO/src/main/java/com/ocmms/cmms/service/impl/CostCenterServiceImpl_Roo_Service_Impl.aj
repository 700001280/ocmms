    /**
     * TODO Auto-generated method documentation
     * 
     * @param costCenter
     */
    @Transactional
    public void CostCenterServiceImpl.delete(CostCenter costCenter) {
        // Clear bidirectional many-to-one child relationship with Organization
        if (costCenter.getOrganization() != null) {
            costCenter.getOrganization().getCostCenters().remove(costCenter);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : costCenter.getDocuments()) {
            item.setCostCenter(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Employee
        for (Employee item : costCenter.getEmployees()) {
            item.setCostCenter(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : costCenter.getImages()) {
            item.setCostCenter(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MainWorkCenter
        for (MainWorkCenter item : costCenter.getMainWorkCenters()) {
            item.setCostCenter(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with OperationalWorkCenter
        for (OperationalWorkCenter item : costCenter.getOperationalWorkCenters()) {
            item.setCostCenter(null);
        }
        
        getCostCenterRepository().delete(costCenter);
    }
    
