    @Transactional
    public void AbcIndicatorServiceImpl.delete(AbcIndicator abcIndicator) {
        // Clear bidirectional one-to-many parent relationship with TechnicalObject
        for (TechnicalObject item : abcIndicator.getTechnicalObjects()) {
            item.setAbcIndicator(null);
        }
        
        getAbcIndicatorRepository().delete(abcIndicator);
    }
    
