    @Transactional
    public AbcIndicator AbcIndicatorServiceImpl.setTechnicalObjects(AbcIndicator abcIndicator, Iterable<Long> technicalObjects) {
        List<TechnicalObject> items = getTechnicalObjectService().findAll(technicalObjects);
        Set<TechnicalObject> currents = abcIndicator.getTechnicalObjects();
        Set<TechnicalObject> toRemove = new HashSet<TechnicalObject>();
        for (Iterator<TechnicalObject> iterator = currents.iterator(); iterator.hasNext();) {
            TechnicalObject nextTechnicalObject = iterator.next();
            if (items.contains(nextTechnicalObject)) {
                items.remove(nextTechnicalObject);
            } else {
                toRemove.add(nextTechnicalObject);
            }
        }
        abcIndicator.removeFromTechnicalObjects(toRemove);
        abcIndicator.addToTechnicalObjects(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        abcIndicator.setVersion(abcIndicator.getVersion() + 1);
        return getAbcIndicatorRepository().save(abcIndicator);
    }
    
