     * @param province
     * @param cities
     * @return Province
     */
    @Transactional
    public Province ProvinceServiceImpl.setCities(Province province, Iterable<Long> cities) {
        List<City> items = getCityService().findAll(cities);
        Set<City> currents = province.getCities();
        Set<City> toRemove = new HashSet<City>();
        for (Iterator<City> iterator = currents.iterator(); iterator.hasNext();) {
            City nextCity = iterator.next();
            if (items.contains(nextCity)) {
                items.remove(nextCity);
            } else {
                toRemove.add(nextCity);
            }
        }
        province.removeFromCities(toRemove);
        province.addToCities(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        province.setVersion(province.getVersion() + 1);
        return getProvinceRepository().save(province);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param province
     */
    @Transactional
    public void ProvinceServiceImpl.delete(Province province) {
        // Clear bidirectional many-to-one child relationship with Region
        if (province.getRegion() != null) {
            province.getRegion().getProvinces().remove(province);
        }
        
        // Clear bidirectional one-to-many parent relationship with City
        for (City item : province.getCities()) {
            item.setProvince(null);
        }
        
        getProvinceRepository().delete(province);
    }
    
