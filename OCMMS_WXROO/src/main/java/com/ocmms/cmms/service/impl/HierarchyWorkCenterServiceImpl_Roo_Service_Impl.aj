     */
    @Transactional
    public void HierarchyWorkCenterServiceImpl.delete(HierarchyWorkCenter hierarchyWorkCenter) {
        // Clear bidirectional many-to-one child relationship with Organization
        if (hierarchyWorkCenter.getOrganization() != null) {
            hierarchyWorkCenter.getOrganization().getHierarchyWorkCenters().remove(hierarchyWorkCenter);
        }
        
        // Clear bidirectional many-to-one child relationship with WorkCenterResponsible
        if (hierarchyWorkCenter.getResponsible() != null) {
            hierarchyWorkCenter.getResponsible().getHierarchyWorkCenters().remove(hierarchyWorkCenter);
        }
        
        // Clear bidirectional one-to-many parent relationship with MainWorkCenter
        for (MainWorkCenter item : hierarchyWorkCenter.getMainWorkCenters()) {
            item.setHierarchyWorkCenter(null);
        }
        
        getHierarchyWorkCenterRepository().delete(hierarchyWorkCenter);
    }
    
