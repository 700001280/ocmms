    @Transactional
    public HierarchyWorkCenter HierarchyWorkCenterServiceImpl.setMainWorkCenters(HierarchyWorkCenter hierarchyWorkCenter, Iterable<Long> mainWorkCenters) {
        List<MainWorkCenter> items = getMainWorkCenterService().findAll(mainWorkCenters);
        Set<MainWorkCenter> currents = hierarchyWorkCenter.getMainWorkCenters();
        Set<MainWorkCenter> toRemove = new HashSet<MainWorkCenter>();
        for (Iterator<MainWorkCenter> iterator = currents.iterator(); iterator.hasNext();) {
            MainWorkCenter nextMainWorkCenter = iterator.next();
            if (items.contains(nextMainWorkCenter)) {
                items.remove(nextMainWorkCenter);
            } else {
                toRemove.add(nextMainWorkCenter);
            }
        }
        hierarchyWorkCenter.removeFromMainWorkCenters(toRemove);
        hierarchyWorkCenter.addToMainWorkCenters(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        hierarchyWorkCenter.setVersion(hierarchyWorkCenter.getVersion() + 1);
        return getHierarchyWorkCenterRepository().save(hierarchyWorkCenter);
    }
    
