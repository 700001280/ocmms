    @Transactional
    public EquipmentLubrication EquipmentLubricationServiceImpl.setDocuments(EquipmentLubrication equipmentLubrication, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = equipmentLubrication.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        equipmentLubrication.removeFromDocuments(toRemove);
        equipmentLubrication.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        equipmentLubrication.setVersion(equipmentLubrication.getVersion() + 1);
        return getEquipmentLubricationRepository().save(equipmentLubrication);
    }
    
