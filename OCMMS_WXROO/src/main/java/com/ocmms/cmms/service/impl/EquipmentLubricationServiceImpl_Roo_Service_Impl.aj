     * @param equipmentLubrication
     */
    @Transactional
    public void EquipmentLubricationServiceImpl.delete(EquipmentLubrication equipmentLubrication) {
        // Clear bidirectional many-to-many child relationship with Equipment
        for (Equipment item : equipmentLubrication.getEquipments()) {
            item.getEquipmentLubrications().remove(equipmentLubrication);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : equipmentLubrication.getDocuments()) {
            item.setEquipmentLubrication(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : equipmentLubrication.getImages()) {
            item.setEquipmentLubrication(null);
        }
        
        getEquipmentLubricationRepository().delete(equipmentLubrication);
    }
    
