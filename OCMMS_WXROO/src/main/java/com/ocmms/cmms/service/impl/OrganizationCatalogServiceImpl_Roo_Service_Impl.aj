     * @param organizations
     * @return OrganizationCatalog
     */
    @Transactional
    public OrganizationCatalog OrganizationCatalogServiceImpl.setOrganizations(OrganizationCatalog organizationCatalog, Iterable<Long> organizations) {
        List<Organization> items = getOrganizationService().findAll(organizations);
        Set<Organization> currents = organizationCatalog.getOrganizations();
        Set<Organization> toRemove = new HashSet<Organization>();
        for (Iterator<Organization> iterator = currents.iterator(); iterator.hasNext();) {
            Organization nextOrganization = iterator.next();
            if (items.contains(nextOrganization)) {
                items.remove(nextOrganization);
            } else {
                toRemove.add(nextOrganization);
            }
        }
        organizationCatalog.removeFromOrganizations(toRemove);
        organizationCatalog.addToOrganizations(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        organizationCatalog.setVersion(organizationCatalog.getVersion() + 1);
        return getOrganizationCatalogRepository().save(organizationCatalog);
    }
    
