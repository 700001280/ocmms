    @Transactional
    public void OrganizationCatalogServiceImpl.delete(OrganizationCatalog organizationCatalog) {
        // Clear bidirectional one-to-many parent relationship with Organization
        for (Organization item : organizationCatalog.getOrganizations()) {
            item.setOrganizationCatalog(null);
        }
        
        getOrganizationCatalogRepository().delete(organizationCatalog);
    }
    
