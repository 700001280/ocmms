    @Transactional
    public void EquipmentReplaceRecordServiceImpl.delete(EquipmentReplaceRecord equipmentReplaceRecord) {
        // Clear bidirectional many-to-one child relationship with Equipment
        if (equipmentReplaceRecord.getEquipment() != null) {
            equipmentReplaceRecord.getEquipment().getEquipmentReplaceRecords().remove(equipmentReplaceRecord);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : equipmentReplaceRecord.getDocuments()) {
            item.setEquipmentReplaceRecord(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : equipmentReplaceRecord.getImages()) {
            item.setEquipmentReplaceRecord(null);
        }
        
        getEquipmentReplaceRecordRepository().delete(equipmentReplaceRecord);
    }
    
