    @Transactional
    public EquipmentReplaceRecord EquipmentReplaceRecordServiceImpl.setDocuments(EquipmentReplaceRecord equipmentReplaceRecord, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = equipmentReplaceRecord.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        equipmentReplaceRecord.removeFromDocuments(toRemove);
        equipmentReplaceRecord.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        equipmentReplaceRecord.setVersion(equipmentReplaceRecord.getVersion() + 1);
        return getEquipmentReplaceRecordRepository().save(equipmentReplaceRecord);
    }
    
