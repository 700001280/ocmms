    /**
     * TODO Auto-generated method documentation
     * 
     * @param organization
     * @param costCenters
     * @return Organization
     */
    @Transactional
    public Organization OrganizationServiceImpl.setCostCenters(Organization organization, Iterable<Long> costCenters) {
        List<CostCenter> items = getCostCenterService().findAll(costCenters);
        Set<CostCenter> currents = organization.getCostCenters();
        Set<CostCenter> toRemove = new HashSet<CostCenter>();
        for (Iterator<CostCenter> iterator = currents.iterator(); iterator.hasNext();) {
            CostCenter nextCostCenter = iterator.next();
            if (items.contains(nextCostCenter)) {
                items.remove(nextCostCenter);
            } else {
                toRemove.add(nextCostCenter);
            }
        }
        organization.removeFromCostCenters(toRemove);
        organization.addToCostCenters(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        organization.setVersion(organization.getVersion() + 1);
        return getOrganizationRepository().save(organization);
    }
    
