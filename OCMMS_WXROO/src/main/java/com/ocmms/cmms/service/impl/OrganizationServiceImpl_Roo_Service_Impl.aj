        for (Iterator<Warehouse> iterator = currents.iterator(); iterator.hasNext();) {
            Warehouse nextWarehouse = iterator.next();
            if (items.contains(nextWarehouse)) {
                items.remove(nextWarehouse);
            } else {
                toRemove.add(nextWarehouse);
            }
        }
        organization.removeFromWarehouses(toRemove);
        organization.addToWarehouses(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        organization.setVersion(organization.getVersion() + 1);
        return getOrganizationRepository().save(organization);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param organization
     * @param workCenterResponsibles
     * @return Organization
     */
    @Transactional
    public Organization OrganizationServiceImpl.setWorkCenterResponsibles(Organization organization, Iterable<Long> workCenterResponsibles) {
        List<WorkCenterResponsible> items = getWorkCenterResponsibleService().findAll(workCenterResponsibles);
        Set<WorkCenterResponsible> currents = organization.getWorkCenterResponsibles();
        Set<WorkCenterResponsible> toRemove = new HashSet<WorkCenterResponsible>();
        for (Iterator<WorkCenterResponsible> iterator = currents.iterator(); iterator.hasNext();) {
            WorkCenterResponsible nextWorkCenterResponsible = iterator.next();
            if (items.contains(nextWorkCenterResponsible)) {
                items.remove(nextWorkCenterResponsible);
            } else {
                toRemove.add(nextWorkCenterResponsible);
            }
        }
        organization.removeFromWorkCenterResponsibles(toRemove);
        organization.addToWorkCenterResponsibles(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        organization.setVersion(organization.getVersion() + 1);
        return getOrganizationRepository().save(organization);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param organization
     */
    @Transactional
    public void OrganizationServiceImpl.delete(Organization organization) {
        // Clear bidirectional many-to-one child relationship with OrganizationCatalog
        if (organization.getOrganizationCatalog() != null) {
            organization.getOrganizationCatalog().getOrganizations().remove(organization);
        }
        
        // Clear bidirectional one-to-many parent relationship with CostCenter
        for (CostCenter item : organization.getCostCenters()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Department
        for (Department item : organization.getDepartments()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Employee
        for (Employee item : organization.getEmployees()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with HierarchyWorkCenter
        for (HierarchyWorkCenter item : organization.getHierarchyWorkCenters()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with OperationalWorkCenter
        for (OperationalWorkCenter item : organization.getOperationalWorkCenters()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ProcurementItemDetail
        for (ProcurementItemDetail item : organization.getProcurementItemDetails()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with TechnicalObject
        for (TechnicalObject item : organization.getTechnicalObjects()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Warehouse
        for (Warehouse item : organization.getWarehouses()) {
            item.setOrganization(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with WorkCenterResponsible
        for (WorkCenterResponsible item : organization.getWorkCenterResponsibles()) {
            item.setOrganization(null);
        }
        
        getOrganizationRepository().delete(organization);
    }
    
