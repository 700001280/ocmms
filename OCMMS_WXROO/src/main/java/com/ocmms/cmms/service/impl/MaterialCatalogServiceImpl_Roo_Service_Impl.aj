    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     */
    @Transactional
    public void MaterialCatalogServiceImpl.delete(MaterialCatalog materialCatalog) {
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : materialCatalog.getDocuments()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with BillOfMaterial
        for (BillOfMaterial item : materialCatalog.getEquipmentBoms()) {
            item.setBomComponent(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : materialCatalog.getImages()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with InstockDetail
        for (InstockDetail item : materialCatalog.getInstockDetails()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MaterialAttribute
        for (MaterialAttribute item : materialCatalog.getMaterialAttributes()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MaterialPlantInfo
        for (MaterialPlantInfo item : materialCatalog.getMaterialPlantInfos()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MaterialProcurementItemDetail
        for (MaterialProcurementItemDetail item : materialCatalog.getMaterialProcurementItemDetails()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MaterialStorageLocationInfo
        for (MaterialStorageLocationInfo item : materialCatalog.getMaterialStorageLocationInfos()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with MaterialVendorInfo
        for (MaterialVendorInfo item : materialCatalog.getMaterialVendorInfos()) {
            item.setMaterialCatalog(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with OutstockDetail
        for (OutstockDetail item : materialCatalog.getOutstockDetails()) {
            item.setMaterialCatalog(null);
        }
        
        getMaterialCatalogRepository().delete(materialCatalog);
    }
    
