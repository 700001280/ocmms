    /**
     * TODO Auto-generated method documentation
     * 
     * @param materialCatalog
     * @param documents
     * @return MaterialCatalog
     */
    @Transactional
    public MaterialCatalog MaterialCatalogServiceImpl.setDocuments(MaterialCatalog materialCatalog, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = materialCatalog.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        materialCatalog.removeFromDocuments(toRemove);
        materialCatalog.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        materialCatalog.setVersion(materialCatalog.getVersion() + 1);
        return getMaterialCatalogRepository().save(materialCatalog);
    }
    
