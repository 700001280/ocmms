     * @return MaterialCatalog
     */
    @Transactional
    public MaterialCatalog MaterialCatalogServiceImpl.setMaterialAttributes(MaterialCatalog materialCatalog, Iterable<Long> materialAttributes) {
        List<MaterialAttribute> items = getMaterialAttributeService().findAll(materialAttributes);
        Set<MaterialAttribute> currents = materialCatalog.getMaterialAttributes();
        Set<MaterialAttribute> toRemove = new HashSet<MaterialAttribute>();
        for (Iterator<MaterialAttribute> iterator = currents.iterator(); iterator.hasNext();) {
            MaterialAttribute nextMaterialAttribute = iterator.next();
            if (items.contains(nextMaterialAttribute)) {
                items.remove(nextMaterialAttribute);
            } else {
                toRemove.add(nextMaterialAttribute);
            }
        }
        materialCatalog.removeFromMaterialAttributes(toRemove);
        materialCatalog.addToMaterialAttributes(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        materialCatalog.setVersion(materialCatalog.getVersion() + 1);
        return getMaterialCatalogRepository().save(materialCatalog);
    }
    
