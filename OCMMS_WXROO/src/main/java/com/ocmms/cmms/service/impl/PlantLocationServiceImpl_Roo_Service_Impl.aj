     * @param plantLocation
     * @param equipments
     * @return PlantLocation
     */
    @Transactional
    public PlantLocation PlantLocationServiceImpl.setEquipments(PlantLocation plantLocation, Iterable<Long> equipments) {
        List<Equipment> items = getEquipmentService().findAll(equipments);
        Set<Equipment> currents = plantLocation.getEquipments();
        Set<Equipment> toRemove = new HashSet<Equipment>();
        for (Iterator<Equipment> iterator = currents.iterator(); iterator.hasNext();) {
            Equipment nextEquipment = iterator.next();
            if (items.contains(nextEquipment)) {
                items.remove(nextEquipment);
            } else {
                toRemove.add(nextEquipment);
            }
        }
        plantLocation.removeFromEquipments(toRemove);
        plantLocation.addToEquipments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        plantLocation.setVersion(plantLocation.getVersion() + 1);
        return getPlantLocationRepository().save(plantLocation);
    }
    
