    @Transactional
    public PlantLocation PlantLocationServiceImpl.setNotificationHeaders(PlantLocation plantLocation, Iterable<Long> notificationHeaders) {
        List<NotificationHeader> items = getNotificationHeaderService().findAll(notificationHeaders);
        Set<NotificationHeader> currents = plantLocation.getNotificationHeaders();
        Set<NotificationHeader> toRemove = new HashSet<NotificationHeader>();
        for (Iterator<NotificationHeader> iterator = currents.iterator(); iterator.hasNext();) {
            NotificationHeader nextNotificationHeader = iterator.next();
            if (items.contains(nextNotificationHeader)) {
                items.remove(nextNotificationHeader);
            } else {
                toRemove.add(nextNotificationHeader);
            }
        }
        plantLocation.removeFromNotificationHeaders(toRemove);
        plantLocation.addToNotificationHeaders(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        plantLocation.setVersion(plantLocation.getVersion() + 1);
        return getPlantLocationRepository().save(plantLocation);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param plantLocation
     */
    @Transactional
    public void PlantLocationServiceImpl.delete(PlantLocation plantLocation) {
        // Clear bidirectional many-to-one child relationship with Plant
        if (plantLocation.getPlant() != null) {
            plantLocation.getPlant().getPlantLocations().remove(plantLocation);
        }
        
        // Clear bidirectional one-to-many parent relationship with Equipment
        for (Equipment item : plantLocation.getEquipments()) {
            item.setPlantLocation(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with NotificationHeader
        for (NotificationHeader item : plantLocation.getNotificationHeaders()) {
            item.setPlantLocation(null);
        }
        
        getPlantLocationRepository().delete(plantLocation);
    }
    
