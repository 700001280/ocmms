    @Transactional
    public AssetStatusChangeRecord AssetStatusChangeRecordServiceImpl.setDocuments(AssetStatusChangeRecord assetStatusChangeRecord, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = assetStatusChangeRecord.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        assetStatusChangeRecord.removeFromDocuments(toRemove);
        assetStatusChangeRecord.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        assetStatusChangeRecord.setVersion(assetStatusChangeRecord.getVersion() + 1);
        return getAssetStatusChangeRecordRepository().save(assetStatusChangeRecord);
    }
    
