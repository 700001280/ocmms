    public void AssetStatusChangeRecordServiceImpl.delete(AssetStatusChangeRecord assetStatusChangeRecord) {
        // Clear bidirectional many-to-one child relationship with Equipment
        if (assetStatusChangeRecord.getEquipment() != null) {
            assetStatusChangeRecord.getEquipment().getAssetStatusChangeRecords().remove(assetStatusChangeRecord);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : assetStatusChangeRecord.getDocuments()) {
            item.setAssetStatusChangeRecord(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : assetStatusChangeRecord.getImages()) {
            item.setAssetStatusChangeRecord(null);
        }
        
        getAssetStatusChangeRecordRepository().delete(assetStatusChangeRecord);
    }
    
