     * @param measuringRecord
     * @param documents
     * @return MeasuringRecord
     */
    @Transactional
    public MeasuringRecord MeasuringRecordServiceImpl.setDocuments(MeasuringRecord measuringRecord, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = measuringRecord.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        measuringRecord.removeFromDocuments(toRemove);
        measuringRecord.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        measuringRecord.setVersion(measuringRecord.getVersion() + 1);
        return getMeasuringRecordRepository().save(measuringRecord);
    }
    
