    @Transactional
    public MeasuringRecord MeasuringRecordServiceImpl.setImages(MeasuringRecord measuringRecord, Iterable<Long> images) {
        List<ImageDocument> items = getImageDocumentService().findAll(images);
        Set<ImageDocument> currents = measuringRecord.getImages();
        Set<ImageDocument> toRemove = new HashSet<ImageDocument>();
        for (Iterator<ImageDocument> iterator = currents.iterator(); iterator.hasNext();) {
            ImageDocument nextImageDocument = iterator.next();
            if (items.contains(nextImageDocument)) {
                items.remove(nextImageDocument);
            } else {
                toRemove.add(nextImageDocument);
            }
        }
        measuringRecord.removeFromImages(toRemove);
        measuringRecord.addToImages(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        measuringRecord.setVersion(measuringRecord.getVersion() + 1);
        return getMeasuringRecordRepository().save(measuringRecord);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param measuringRecord
     */
    @Transactional
    public void MeasuringRecordServiceImpl.delete(MeasuringRecord measuringRecord) {
        // Clear bidirectional many-to-one child relationship with Equipment
        if (measuringRecord.getEquipment() != null) {
            measuringRecord.getEquipment().getMeasuringRecords().remove(measuringRecord);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : measuringRecord.getDocuments()) {
            item.setMeasuringRecord(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : measuringRecord.getImages()) {
            item.setMeasuringRecord(null);
        }
        
        getMeasuringRecordRepository().delete(measuringRecord);
    }
    
