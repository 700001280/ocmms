        // Clear bidirectional many-to-one child relationship with NotificationPriority
        if (notificationHeader.getPriority() != null) {
            notificationHeader.getPriority().getNotificationHeaders().remove(notificationHeader);
        }
        
        // Clear bidirectional many-to-one child relationship with NotificationSystemStatus
        if (notificationHeader.getSystemStatus() != null) {
            notificationHeader.getSystemStatus().getNotificationHeaders().remove(notificationHeader);
        }
        
        // Clear bidirectional many-to-many parent relationship with NotificationUserStatusWithoutNumber
        for (NotificationUserStatusWithoutNumber item : notificationHeader.getMutiUserStatuses()) {
            item.getNotificationHeaders().remove(notificationHeader);
        }
        
        // Clear bidirectional one-to-many parent relationship with NotificationItem
        for (NotificationItem item : notificationHeader.getNotificationItems()) {
            item.setNotificationHeader(null);
        }
        
        // Clear bidirectional one-to-one parent relationship with WorkOrderHeader
        notificationHeader.removeFromWorkorderHeader();
        
        getNotificationHeaderRepository().delete(notificationHeader);
    }
    
