    @Transactional
    public NotificationHeader NotificationHeaderServiceImpl.setMutiUserStatuses(NotificationHeader notificationHeader, Iterable<Long> mutiUserStatuses) {
        List<NotificationUserStatusWithoutNumber> items = getNotificationUserStatusWithoutNumberService().findAll(mutiUserStatuses);
        Set<NotificationUserStatusWithoutNumber> currents = notificationHeader.getMutiUserStatuses();
        Set<NotificationUserStatusWithoutNumber> toRemove = new HashSet<NotificationUserStatusWithoutNumber>();
        for (Iterator<NotificationUserStatusWithoutNumber> iterator = currents.iterator(); iterator.hasNext();) {
            NotificationUserStatusWithoutNumber nextNotificationUserStatusWithoutNumber = iterator.next();
            if (items.contains(nextNotificationUserStatusWithoutNumber)) {
                items.remove(nextNotificationUserStatusWithoutNumber);
            } else {
                toRemove.add(nextNotificationUserStatusWithoutNumber);
            }
        }
        notificationHeader.removeFromMutiUserStatuses(toRemove);
        notificationHeader.addToMutiUserStatuses(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        notificationHeader.setVersion(notificationHeader.getVersion() + 1);
        return getNotificationHeaderRepository().save(notificationHeader);
    }
    
