     * @param warehouse
     */
    @Transactional
    public void WarehouseServiceImpl.delete(Warehouse warehouse) {
        // Clear bidirectional many-to-one child relationship with Organization
        if (warehouse.getOrganization() != null) {
            warehouse.getOrganization().getWarehouses().remove(warehouse);
        }
        
        // Clear bidirectional one-to-many parent relationship with StorageLocation
        for (StorageLocation item : warehouse.getStorageLocations()) {
            item.setWarehouse(null);
        }
        
        getWarehouseRepository().delete(warehouse);
    }
    
