    @Transactional
    public EquipmentParameter EquipmentParameterServiceImpl.setImages(EquipmentParameter equipmentParameter, Iterable<Long> images) {
        List<ImageDocument> items = getImageDocumentService().findAll(images);
        Set<ImageDocument> currents = equipmentParameter.getImages();
        Set<ImageDocument> toRemove = new HashSet<ImageDocument>();
        for (Iterator<ImageDocument> iterator = currents.iterator(); iterator.hasNext();) {
            ImageDocument nextImageDocument = iterator.next();
            if (items.contains(nextImageDocument)) {
                items.remove(nextImageDocument);
            } else {
                toRemove.add(nextImageDocument);
            }
        }
        equipmentParameter.removeFromImages(toRemove);
        equipmentParameter.addToImages(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        equipmentParameter.setVersion(equipmentParameter.getVersion() + 1);
        return getEquipmentParameterRepository().save(equipmentParameter);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentParameter
     */
    @Transactional
    public void EquipmentParameterServiceImpl.delete(EquipmentParameter equipmentParameter) {
        // Clear bidirectional many-to-many child relationship with Equipment
        for (Equipment item : equipmentParameter.getEquipments()) {
            item.getEquipmentParameters().remove(equipmentParameter);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : equipmentParameter.getDocuments()) {
            item.setEquipmentParameter(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : equipmentParameter.getImages()) {
            item.setEquipmentParameter(null);
        }
        
        getEquipmentParameterRepository().delete(equipmentParameter);
    }
    
