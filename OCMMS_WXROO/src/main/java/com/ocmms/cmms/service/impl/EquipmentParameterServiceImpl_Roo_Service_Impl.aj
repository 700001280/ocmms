    /**
     * TODO Auto-generated method documentation
     * 
     * @param equipmentParameter
     * @param documents
     * @return EquipmentParameter
     */
    @Transactional
    public EquipmentParameter EquipmentParameterServiceImpl.setDocuments(EquipmentParameter equipmentParameter, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = equipmentParameter.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        equipmentParameter.removeFromDocuments(toRemove);
        equipmentParameter.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        equipmentParameter.setVersion(equipmentParameter.getVersion() + 1);
        return getEquipmentParameterRepository().save(equipmentParameter);
    }
    
