    /**
     * TODO Auto-generated method documentation
     * 
     * @param functionalLocation
     * @param documents
     * @return FunctionalLocation
     */
    @Transactional
    public FunctionalLocation FunctionalLocationServiceImpl.setDocuments(FunctionalLocation functionalLocation, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = functionalLocation.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        functionalLocation.removeFromDocuments(toRemove);
        functionalLocation.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        functionalLocation.setVersion(functionalLocation.getVersion() + 1);
        return getFunctionalLocationRepository().save(functionalLocation);
    }
    
