    /**
     * TODO Auto-generated method documentation
     * 
     * @param functionalLocation
     */
    @Transactional
    public void FunctionalLocationServiceImpl.delete(FunctionalLocation functionalLocation) {
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : functionalLocation.getDocuments()) {
            item.setFunctionalLocation(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with Equipment
        for (Equipment item : functionalLocation.getEquipments()) {
            item.setFunctionalLocation(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : functionalLocation.getImages()) {
            item.setFunctionalLocation(null);
        }
        
        getFunctionalLocationRepository().delete(functionalLocation);
    }
    
