    @Transactional
    public AssetInventoryRecord AssetInventoryRecordServiceImpl.setImages(AssetInventoryRecord assetInventoryRecord, Iterable<Long> images) {
        List<ImageDocument> items = getImageDocumentService().findAll(images);
        Set<ImageDocument> currents = assetInventoryRecord.getImages();
        Set<ImageDocument> toRemove = new HashSet<ImageDocument>();
        for (Iterator<ImageDocument> iterator = currents.iterator(); iterator.hasNext();) {
            ImageDocument nextImageDocument = iterator.next();
            if (items.contains(nextImageDocument)) {
                items.remove(nextImageDocument);
            } else {
                toRemove.add(nextImageDocument);
            }
        }
        assetInventoryRecord.removeFromImages(toRemove);
        assetInventoryRecord.addToImages(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        assetInventoryRecord.setVersion(assetInventoryRecord.getVersion() + 1);
        return getAssetInventoryRecordRepository().save(assetInventoryRecord);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param assetInventoryRecord
     */
    @Transactional
    public void AssetInventoryRecordServiceImpl.delete(AssetInventoryRecord assetInventoryRecord) {
        // Clear bidirectional many-to-one child relationship with Equipment
        if (assetInventoryRecord.getEquipment() != null) {
            assetInventoryRecord.getEquipment().getAssetInventoryRecords().remove(assetInventoryRecord);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : assetInventoryRecord.getDocuments()) {
            item.setAssetInventoryRecord(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : assetInventoryRecord.getImages()) {
            item.setAssetInventoryRecord(null);
        }
        
        getAssetInventoryRecordRepository().delete(assetInventoryRecord);
    }
    
