     * @param assetInventoryRecord
     * @param documents
     * @return AssetInventoryRecord
     */
    @Transactional
    public AssetInventoryRecord AssetInventoryRecordServiceImpl.setDocuments(AssetInventoryRecord assetInventoryRecord, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = assetInventoryRecord.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        assetInventoryRecord.removeFromDocuments(toRemove);
        assetInventoryRecord.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        assetInventoryRecord.setVersion(assetInventoryRecord.getVersion() + 1);
        return getAssetInventoryRecordRepository().save(assetInventoryRecord);
    }
    
