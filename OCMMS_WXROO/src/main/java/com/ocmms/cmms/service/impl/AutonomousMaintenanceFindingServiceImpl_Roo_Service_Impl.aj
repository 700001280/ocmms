    @Transactional
    public AutonomousMaintenanceFinding AutonomousMaintenanceFindingServiceImpl.setDocuments(AutonomousMaintenanceFinding autonomousMaintenanceFinding, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = autonomousMaintenanceFinding.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        autonomousMaintenanceFinding.removeFromDocuments(toRemove);
        autonomousMaintenanceFinding.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        autonomousMaintenanceFinding.setVersion(autonomousMaintenanceFinding.getVersion() + 1);
        return getAutonomousMaintenanceFindingRepository().save(autonomousMaintenanceFinding);
    }
    
