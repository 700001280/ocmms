    @Transactional
    public void AutonomousMaintenanceFindingServiceImpl.delete(AutonomousMaintenanceFinding autonomousMaintenanceFinding) {
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : autonomousMaintenanceFinding.getDocuments()) {
            item.setAutonomousMaintenanceFinding(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : autonomousMaintenanceFinding.getImages()) {
            item.setAutonomousMaintenanceFinding(null);
        }
        
        getAutonomousMaintenanceFindingRepository().delete(autonomousMaintenanceFinding);
    }
    
