        }
        autonomousMaintenanceFinding.removeFromImages(toRemove);
        autonomousMaintenanceFinding.addToImages(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        autonomousMaintenanceFinding.setVersion(autonomousMaintenanceFinding.getVersion() + 1);
        return getAutonomousMaintenanceFindingRepository().save(autonomousMaintenanceFinding);
    }
    
