     * @param department
     */
    @Transactional
    public void DepartmentServiceImpl.delete(Department department) {
        // Clear bidirectional many-to-one child relationship with Organization
        if (department.getOrganization() != null) {
            department.getOrganization().getDepartments().remove(department);
        }
        
        // Clear bidirectional one-to-many parent relationship with MainWorkCenter
        for (MainWorkCenter item : department.getMaintWorkCenters()) {
            item.setDepartment(null);
        }
        
        getDepartmentRepository().delete(department);
    }
    
