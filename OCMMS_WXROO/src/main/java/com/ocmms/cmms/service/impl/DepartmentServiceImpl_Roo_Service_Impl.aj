     * @param department
     * @param maintWorkCenters
     * @return Department
     */
    @Transactional
    public Department DepartmentServiceImpl.setMaintWorkCenters(Department department, Iterable<Long> maintWorkCenters) {
        List<MainWorkCenter> items = getMainWorkCenterService().findAll(maintWorkCenters);
        Set<MainWorkCenter> currents = department.getMaintWorkCenters();
        Set<MainWorkCenter> toRemove = new HashSet<MainWorkCenter>();
        for (Iterator<MainWorkCenter> iterator = currents.iterator(); iterator.hasNext();) {
            MainWorkCenter nextMainWorkCenter = iterator.next();
            if (items.contains(nextMainWorkCenter)) {
                items.remove(nextMainWorkCenter);
            } else {
                toRemove.add(nextMainWorkCenter);
            }
        }
        department.removeFromMaintWorkCenters(toRemove);
        department.addToMaintWorkCenters(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        department.setVersion(department.getVersion() + 1);
        return getDepartmentRepository().save(department);
    }
    
    /**
     * TODO Auto-generated method documentation
