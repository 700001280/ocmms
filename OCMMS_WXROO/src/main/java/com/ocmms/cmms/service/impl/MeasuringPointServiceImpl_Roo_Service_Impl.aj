     * @param measuringPoint
     * @param documents
     * @return MeasuringPoint
     */
    @Transactional
    public MeasuringPoint MeasuringPointServiceImpl.setDocuments(MeasuringPoint measuringPoint, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = measuringPoint.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        measuringPoint.removeFromDocuments(toRemove);
        measuringPoint.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        measuringPoint.setVersion(measuringPoint.getVersion() + 1);
        return getMeasuringPointRepository().save(measuringPoint);
    }
    
