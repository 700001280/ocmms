    @Transactional
    public MeasuringPoint MeasuringPointServiceImpl.setImages(MeasuringPoint measuringPoint, Iterable<Long> images) {
        List<ImageDocument> items = getImageDocumentService().findAll(images);
        Set<ImageDocument> currents = measuringPoint.getImages();
        Set<ImageDocument> toRemove = new HashSet<ImageDocument>();
        for (Iterator<ImageDocument> iterator = currents.iterator(); iterator.hasNext();) {
            ImageDocument nextImageDocument = iterator.next();
            if (items.contains(nextImageDocument)) {
                items.remove(nextImageDocument);
            } else {
                toRemove.add(nextImageDocument);
            }
        }
        measuringPoint.removeFromImages(toRemove);
        measuringPoint.addToImages(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        measuringPoint.setVersion(measuringPoint.getVersion() + 1);
        return getMeasuringPointRepository().save(measuringPoint);
    }
    
    /**
     * TODO Auto-generated method documentation
     * 
     * @param measuringPoint
     */
    @Transactional
    public void MeasuringPointServiceImpl.delete(MeasuringPoint measuringPoint) {
        // Clear bidirectional many-to-one child relationship with Equipment
        if (measuringPoint.getEquipment() != null) {
            measuringPoint.getEquipment().getMeasuringPoints().remove(measuringPoint);
        }
        
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : measuringPoint.getDocuments()) {
            item.setMeasuringPoint(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : measuringPoint.getImages()) {
            item.setMeasuringPoint(null);
        }
        
        getMeasuringPointRepository().delete(measuringPoint);
    }
    
