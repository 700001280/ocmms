    /**
     * TODO Auto-generated method documentation
     * 
     * @param procurementOrder
     */
    @Transactional
    public void ProcurementOrderServiceImpl.delete(ProcurementOrder procurementOrder) {
        // Clear bidirectional one-to-many parent relationship with Document
        for (Document item : procurementOrder.getDocuments()) {
            item.setProcurementOrder(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ImageDocument
        for (ImageDocument item : procurementOrder.getImages()) {
            item.setProcurementOrder(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ProcurementItemDetail
        for (ProcurementItemDetail item : procurementOrder.getPocurementItemDetails()) {
            item.setProcurementOrder(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with ProcurementOrderFinanceTracking
        for (ProcurementOrderFinanceTracking item : procurementOrder.getProcurementOrderFinanceTrackings()) {
            item.setProcurementOrder(null);
        }
        
        // Clear bidirectional one-to-many parent relationship with PurchaseExpedite
        for (PurchaseExpedite item : procurementOrder.getPurchaseExpedites()) {
            item.setProcurementOrder(null);
        }
        
        getProcurementOrderRepository().delete(procurementOrder);
    }
    
