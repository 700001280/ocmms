    /**
     * TODO Auto-generated method documentation
     * 
     * @param procurementOrder
     * @param documents
     * @return ProcurementOrder
     */
    @Transactional
    public ProcurementOrder ProcurementOrderServiceImpl.setDocuments(ProcurementOrder procurementOrder, Iterable<Long> documents) {
        List<Document> items = getDocumentService().findAll(documents);
        Set<Document> currents = procurementOrder.getDocuments();
        Set<Document> toRemove = new HashSet<Document>();
        for (Iterator<Document> iterator = currents.iterator(); iterator.hasNext();) {
            Document nextDocument = iterator.next();
            if (items.contains(nextDocument)) {
                items.remove(nextDocument);
            } else {
                toRemove.add(nextDocument);
            }
        }
        procurementOrder.removeFromDocuments(toRemove);
        procurementOrder.addToDocuments(items);
        // Force the version update of the parent side to know that the parent has changed
        // because it has new books assigned
        procurementOrder.setVersion(procurementOrder.getVersion() + 1);
        return getProcurementOrderRepository().save(procurementOrder);
    }
    
